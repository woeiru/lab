#!/bin/bash

    # Alias generation
    alias ali='$UTL_DIR/cfg-ali'
    alias ap='ansible-playbook'

    # Bash
    alias b='bash'
    alias eb='exec bash'

    # BTRFS management
    alias bt='btrfs'
    alias btf='btrfs filesystem'

    # Cat (file viewing)
    alias c='cat'
    alias c.group='cat /etc/group'
    alias c.passwd='cat /etc/passwd'
    alias c.fstab='cat /etc/fstab'
    alias es.log='cat /mnt/bak/home/.es.log'

    # Directory navigation
    alias d='cd'
    alias ..='cd ..'
    alias dl="cd $LAB_DIR"

    alias d.samba='cd /etc/samba/'
    alias d.snapper='cd /etc/snapper/configs'
    alias d.pam='cd /usr/lib/pam_snapper'

    alias d.das='cd /mnt/das'
    alias d.nvm='cd /mnt/nvm'
    alias d.usb='cd /mnt/usb'

    # Disk usage
    alias u='du -bh -d1'
    alias uu='du -bh -d2'
    alias uuu='du -bh -d3'

    # Exit
    alias ee='exit'

    # Function chaining

    # ACU analysis aliases: variable full cross-component consistency analysis.
    # Wrapper functions are required because aliases cannot forward arguments reliably.
    _ffl_acu_core__all() {
        local acu_mode="${1:-}"
        aux_ffl ana_acu "$acu_mode" "$CFG_CORE_DIR" "$LIB_DIR" "$SRC_DIR" "$UTL_DIR"
    }

    _ffl_acu_env__all() {
        local acu_mode="${1:-}"
        aux_ffl ana_acu "$acu_mode" "$CFG_ENV_DIR" "$LIB_DIR" "$SRC_DIR" "$UTL_DIR"
    }

    _ffl_acu_cycle() {
        local acu_mode="${1:-}"
        _ffl_acu_core__all "$acu_mode" && _ffl_acu_env__all "$acu_mode"
    }

    alias ffl-acu_core__all='_ffl_acu_core__all'
    alias ffl-acu_env__all='_ffl_acu_env__all'
    alias ffl-acu_cycle='_ffl_acu_cycle'

    # LAF analysis aliases: function inventory and call-distribution summaries.
    # Wrapper functions are required because aliases cannot forward arguments reliably.
    _ffl_laf_core() {
        local laf_mode="${1:-}"
        aux_ffl ana_laf "$laf_mode" "$LIB_CORE_DIR"
    }

    _ffl_laf_ops() {
        local laf_mode="${1:-}"
        aux_ffl ana_laf "$laf_mode" "$LIB_OPS_DIR"
    }

    _ffl_laf_gen() {
        local laf_mode="${1:-}"
        aux_ffl ana_laf "$laf_mode" "$LIB_GEN_DIR"
    }

    _ffl_laf_utl() {
        local laf_mode="${1:-}"
        aux_ffl ana_laf "$laf_mode" "$UTL_DIR"
    }

    _ffl_laf_cycle() {
        local laf_mode="${1:-}"
        _ffl_laf_core "$laf_mode" && _ffl_laf_ops "$laf_mode" && _ffl_laf_gen "$laf_mode" && _ffl_laf_utl "$laf_mode"
    }

    alias ffl-laf_core='_ffl_laf_core'
    alias ffl-laf_ops='_ffl_laf_ops'
    alias ffl-laf_gen='_ffl_laf_gen'
    alias ffl-laf_utl='_ffl_laf_utl'
    alias ffl-laf_cycle='_ffl_laf_cycle'

    # RDP analysis aliases: function detect reverse dependencies across project modules.
    alias ffl-rdp_core__bin='aux_ffl ana_rdp "" "$LIB_CORE_DIR" "$DIR_BIN"'
    alias ffl-rdp_core__lib='aux_ffl ana_rdp "" "$LIB_CORE_DIR" "$LIB_DIR"'
    alias ffl-rdp_core__utl='aux_ffl ana_rdp "" "$LIB_CORE_DIR" "$UTL_DIR"'
    alias ffl-rdp_gen__bin='aux_ffl ana_rdp "" "$LIB_GEN_DIR" "$DIR_BIN"'
    alias ffl-rdp_gen__lib='aux_ffl ana_rdp "" "$LIB_GEN_DIR" "$LIB_DIR"'
    alias ffl-rdp_gen__src='aux_ffl ana_rdp "" "$LIB_GEN_DIR" "$SRC_DIR"'
    alias ffl-rdp_gen__utl='aux_ffl ana_rdp "" "$LIB_GEN_DIR" "$UTL_DIR"'
    alias ffl-rdp_ops__lib='aux_ffl ana_rdp "" "$LIB_OPS_DIR" "$LIB_DIR"'
    alias ffl-rdp_ops__src='aux_ffl ana_rdp "" "$LIB_OPS_DIR" "$SRC_DIR"'
    alias ffl-rdp_ops__utl='aux_ffl ana_rdp "" "$LIB_OPS_DIR" "$UTL_DIR"'
    alias ffl-rdp_cycle='ffl-rdp_core__bin && ffl-rdp_core__lib && ffl-rdp_core__utl && ffl-rdp_gen__bin && ffl-rdp_gen__lib && ffl-rdp_gen__src && ffl-rdp_gen__utl && ffl-rdp_ops__lib && ffl-rdp_ops__src && ffl-rdp_ops__utl'

    # DEP analysis aliases: direct module dependencies (imports + host commands).
    # Wrapper functions are required because aliases cannot forward arguments reliably.
    _ffl_dep_go() {
        local dep_mode="${1:-}"
        if [[ -n "$dep_mode" ]]; then
            ana_dep "$dep_mode" "$LAB_DIR/go"
        else
            ana_dep "$LAB_DIR/go"
        fi
    }

    _ffl_dep_bin() {
        local dep_mode="${1:-}"
        aux_ffl ana_dep "$dep_mode" "$DIR_BIN"
    }

    _ffl_dep_core() {
        local dep_mode="${1:-}"
        aux_ffl ana_dep "$dep_mode" "$LIB_CORE_DIR"
    }

    _ffl_dep_gen() {
        local dep_mode="${1:-}"
        aux_ffl ana_dep "$dep_mode" "$LIB_GEN_DIR"
    }

    _ffl_dep_ops() {
        local dep_mode="${1:-}"
        aux_ffl ana_dep "$dep_mode" "$LIB_OPS_DIR"
    }

    _ffl_dep_src() {
        local dep_mode="${1:-}"
        aux_ffl ana_dep "$dep_mode" "$SRC_DIR"
    }

    _ffl_dep_utl() {
        local dep_mode="${1:-}"
        aux_ffl ana_dep "$dep_mode" "$UTL_DIR"
    }

    _ffl_dep_cycle() {
        local dep_mode="${1:-}"
        _ffl_dep_go "$dep_mode" && _ffl_dep_bin "$dep_mode" && _ffl_dep_core "$dep_mode" && _ffl_dep_gen "$dep_mode" && _ffl_dep_ops "$dep_mode" && _ffl_dep_src "$dep_mode" && _ffl_dep_utl "$dep_mode"
    }

    alias ffl-dep_go='_ffl_dep_go'
    alias ffl-dep_bin='_ffl_dep_bin'
    alias ffl-dep_core='_ffl_dep_core'
    alias ffl-dep_gen='_ffl_dep_gen'
    alias ffl-dep_ops='_ffl_dep_ops'
    alias ffl-dep_src='_ffl_dep_src'
    alias ffl-dep_utl='_ffl_dep_utl'
    alias ffl-dep_cycle='_ffl_dep_cycle'

    # TST analysis aliases: test traceability and coverage summaries.
    # Wrapper functions are required because aliases cannot forward arguments reliably.
    _ffl_tst_go() {
        local tst_mode="${1:-}"
        if [[ -n "$tst_mode" ]]; then
            ana_tst "$tst_mode" "$LAB_DIR/go"
        else
            ana_tst "$LAB_DIR/go"
        fi
    }

    _ffl_tst_bin() {
        local tst_mode="${1:-}"
        aux_ffl ana_tst "$tst_mode" "$DIR_BIN"
    }

    _ffl_tst_core() {
        local tst_mode="${1:-}"
        aux_ffl ana_tst "$tst_mode" "$LIB_CORE_DIR"
    }

    _ffl_tst_gen() {
        local tst_mode="${1:-}"
        aux_ffl ana_tst "$tst_mode" "$LIB_GEN_DIR"
    }

    _ffl_tst_ops() {
        local tst_mode="${1:-}"
        aux_ffl ana_tst "$tst_mode" "$LIB_OPS_DIR"
    }

    _ffl_tst_src() {
        local tst_mode="${1:-}"
        aux_ffl ana_tst "$tst_mode" "$SRC_DIR"
    }

    _ffl_tst_utl() {
        local tst_mode="${1:-}"
        aux_ffl ana_tst "$tst_mode" "$UTL_DIR"
    }

    _ffl_tst_cycle() {
        local tst_mode="${1:-}"
        _ffl_tst_go "$tst_mode" && _ffl_tst_bin "$tst_mode" && _ffl_tst_core "$tst_mode" && _ffl_tst_gen "$tst_mode" && _ffl_tst_ops "$tst_mode" && _ffl_tst_src "$tst_mode" && _ffl_tst_utl "$tst_mode"
    }

    alias ffl-tst_go='_ffl_tst_go'
    alias ffl-tst_bin='_ffl_tst_bin'
    alias ffl-tst_core='_ffl_tst_core'
    alias ffl-tst_gen='_ffl_tst_gen'
    alias ffl-tst_ops='_ffl_tst_ops'
    alias ffl-tst_src='_ffl_tst_src'
    alias ffl-tst_utl='_ffl_tst_utl'
    alias ffl-tst_cycle='_ffl_tst_cycle'

    # Function makros
    alias v111='ops gpu ptd -d lookup && qm start 111'

    # Git commands
    alias g='git'
    alias gs='git status'
    alias gd='git diff'
    alias gl='git ls-files | xargs cat | wc -l'
    alias ga='git add'
    alias gc='git commit'
    alias gcmb='git commit -m "base"'
    alias go='git push origin master'
    alias gp='git pull'
    alias gg='sys_gio'
    alias gr1='git revert HEAD~1'

    # History
    alias h='history'

    # IPTables
    alias ipt='iptables -L -v -n'

    # Mounting
    alias m.sda.das='mount /dev/sda /mnt/das'
    alias m.sub.sda.bak='mount -o subvol=bak /dev/sda /bak'

    # Filesystem creation
    alias mbf='mkfs.btrfs -f'
    alias mbmd='mkfs.btrfs -m raid1 -d raid1'

    # PAM Snapper commands
    alias pam.convert='bash /usr/lib/pam_snapper/pam_snapper_homeconvert.sh'
    alias pam.config='bash /usr/lib/pam_snapper/pam_snapper_pamconfig.sh'
    alias pam.useradd='bash /usr/lib/pam_snapper/pam_snapper_useradd.sh'
    alias pam.userdel='bash /usr/lib/pam_snapper/pam_snapper_userdel.sh'

    # Podman (container management)
    alias pod='podman'
    alias podst='podman start'
    alias podps='podman ps'
    alias podpsa='podman ps -a'

    # System control
    alias sy='systemctl'

    # System configuration file editing
    alias v.samba.conf='vim /etc/samba/smb.conf'
    alias v.sambausers='vim /etc/samba/smbusers'
    alias v.firewall.conf='vim /etc/firewalld/firewalld.conf'
    alias v.fstab='vim /etc/fstab'

    # Snapper (filesystem snapshot management)
    if [ -s "$DIR_LIB/ops/sto" ]; then
        source "$DIR_LIB/ops/sto"
        alias shl='sto_bfs_shl home'
        alias shc='sto_bfs_shc home'
        alias shd='sto_bfs_shd'
    fi

    # System statistics
    alias sar='sar -d 1'
    alias ios='iostat -x 1'

    # SELinux
    alias ses='sestatus -v'
    alias seb='sudo semanage boolean -l'

    # Time zone setting
    alias berlintime="timedatectl set-timezone Europe/Berlin"

    # Transactional update
    alias tu='transactional-update'
    alias tua='transactional-update apply'
    alias tur='transactional-update reboot'
    alias tuar='transactional-update apply && transactional-update reboot'

    # Dynamic tree function with line count
    
    tree_with_count() {
     local depth=${1:-0}
     local tree_cmd="tree"

     if [ $depth -gt 0 ]; then
           tree_cmd="tree -L $depth"
     fi

     $tree_cmd
     echo "Total lines: $(find . -type f -exec wc -l {} + | tail -n1 | awk '{print $1}')"
   }

    alias t='tree_with_count'
    alias tt='tree_with_count 2'
    alias ttt='tree_with_count 3'
    alias tttt='tree_with_count 4'
    alias ttttt='tree_with_count 5'
   
    # Vim
    alias v='vim'

    # File listing
    alias l='ls -Al'

    # Unsorted (you may want to organize these later)
    alias pr='kquitapp5 plasmashell && kstart5 plasmashell'
    alias gdi='git diff --no-index -- /dev/null'
    alias light='plasma-apply-lookandfeel -a org.kde.breeze.desktop && usr_ckp 1'
    alias dark='plasma-apply-lookandfeel -a org.kde.breezedark.desktop && usr_ckp 2'

    # Environment Management
    alias env='$LIB_GEN_DIR/env'
    alias env-dev='env switch-env dev'
    alias env-test='env switch-env test'
    alias env-staging='env switch-env staging'
    alias env-prod='env switch-env prod'
    alias env-stat='env status'
    alias env-list='env list'
    alias env-check='env validate'

    # DIC Operations Engine
    alias ops='$SRC_DIC_OPS'

    # Development
    # OpenCode session database and config paths:
    #   ~/.local/share/opencode/opencode.db  — session history / recent list (SQLite)
    #   ~/.config/opencode/opencode.json     — main configuration
    alias osv='dev_osv -l 40 --watch 40 -t'
    alias olb='dev_olb --watch 40'

    # History
