#!/bin/bash
#######################################################################
# Lab Environment Function Metadata Table Generator
#######################################################################
# File: func
# Description: Automatic function metadata table generator using ana_laf -j
#              Parses JSON output for complete call-distribution and metadata.
#######################################################################

set +e

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -z "${LAB_DIR:-}" ]]; then
    readonly LAB_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
fi

source "$LAB_DIR/lib/gen/aux" >/dev/null 2>&1
source "$LAB_DIR/lib/gen/ana" >/dev/null 2>&1

TARGETS_FILE="$(dirname "$SCRIPT_DIR")/config/targets"
if [[ -f "$TARGETS_FILE" ]]; then
    source "$TARGETS_FILE"
fi

DOC_FILE="$LAB_DIR/${GENERATOR_OUTPUT_FILES[func]:-doc/ref/functions.md}"
TMP_BASE_DIR="$LAB_DIR/.tmp/doc"
TMP_DIR="$TMP_BASE_DIR/laf"
mkdir -p "$TMP_DIR"

# Target directories according to ffl-laf_cycle
TARGET_DIRECTORIES=("lib/core" "lib/ops" "lib/gen" "utl")

generate_function_table() {
    cat << HEADER_EOF
*Auto-updated function metadata table with real-time analysis*

> **Last Updated**: $(date '+%Y-%m-%d %H:%M:%S')  
> **Generated By**: utl/ref/generators/func  

This table provides a comprehensive overview of all functions available across the lab environment libraries:

### **📋 Function Library Overview**
Functions are organized by library modules for systematic access and reference.

### **📖 Function Metadata Table**

| Library | Module | Function | Arguments | Shortname | Description | Size | Loc | Calls (file) |
|---------|--------|----------|-----------|-----------|-------------|------|-----|--------------|
HEADER_EOF

    for target_dir in "${TARGET_DIRECTORIES[@]}"; do
        local full_path="$LAB_DIR/$target_dir"
        if [[ -d "$full_path" ]]; then
            local lib_name=$(basename "$target_dir")
            
            while IFS= read -r -d '' file; do
                ana_laf -j --json-dir "$TMP_DIR" "$file" >/dev/null 2>&1 || true
                
                local relative_path="${file#$LAB_DIR/}"
                local json_filename="${relative_path//\//_}.json"
                local json_file="$TMP_DIR/$json_filename"
                if [[ -f "$json_file" ]]; then
                    local module_name=$(basename "$file")
                    # jq parsing to markdown table
                    jq -r --arg lib "$lib_name" --arg mod "$module_name" '
                        .functions[]? | 
                        [
                            $lib, 
                            $mod, 
                            "`\(.name)`", 
                            (.arguments // ""), 
                            (.shortname // ""), 
                            (.description // ""), 
                            (.size // ""), 
                            (.location // ""),
                            (.calls_in_file // "")
                        ] | 
                        "| " + join(" | ") + " |"
                    ' "$json_file" 2>/dev/null
                fi
            done < <(find "$full_path" -type f -print0)
        fi
    done
}

update_documentation() {
    local temp_file=$(mktemp)
    local in_auto_section=false

    echo "Updating function metadata table in $DOC_FILE..."

    while IFS= read -r line; do
        if [[ "$line" == *"<!-- AUTO-GENERATED SECTION: "* ]]; then
            echo "$line" >> "$temp_file"
            generate_function_table >> "$temp_file"
            in_auto_section=true
            continue
        fi
        if [[ "$line" == *"<!-- END AUTO-GENERATED SECTION "* ]]; then
            echo "$line" >> "$temp_file"
            in_auto_section=false
            continue
        fi
        if [[ "$in_auto_section" == false ]]; then
            echo "$line" >> "$temp_file"
        fi
    done < "$DOC_FILE"

    mv "$temp_file" "$DOC_FILE"
    echo "Function metadata table updated successfully."
}

echo "Generating function metadata table..."
update_documentation
echo "Function metadata table generation complete."
