#!/bin/bash
#######################################################################
# Lab Environment Documentation Structure Generator
#######################################################################

set -e

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -z "${LAB_DIR:-}" ]]; then
    readonly LAB_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
fi

source "$LAB_DIR/lib/gen/aux"
source "$LAB_DIR/lib/gen/ana"

TARGETS_FILE="$(dirname "$SCRIPT_DIR")/config/targets"
if [[ -f "$TARGETS_FILE" ]]; then
    source "$TARGETS_FILE"
fi

if [[ -n "${GENERATOR_OUTPUT_FILES[hub]:-}" ]]; then
    DOC_FILE="$LAB_DIR/${GENERATOR_OUTPUT_FILES[hub]}"
else
    DOC_FILE="$LAB_DIR/doc/dev/generated-doc-injections.md"
fi

SECTION_NAME="${GENERATOR_SECTIONS[hub]:-Documentation Structure}"
DOC_SCAN_PATH="$LAB_DIR/doc"

generate_hub_section() {
    echo "*Auto-updated documentation structure analysis*"
    echo ""
    echo "> **Last Updated**: $(date '+%Y-%m-%d %H:%M:%S')"
    echo "> **Generated By**: \`utl/doc/generators/hub\`"
    echo "> **Source Path**: \`doc/\`"
    echo ""
    echo "\`\`\`text"
    ana_lad "$DOC_SCAN_PATH" || true
    echo "\`\`\`"
}

update_documentation() {
    local temp_file
    temp_file=$(mktemp)
    local in_auto_section=false

    echo "Updating documentation structure section '$SECTION_NAME' in $DOC_FILE..."

    while IFS= read -r line; do
        if [[ "$line" == *"<!-- AUTO-GENERATED SECTION: $SECTION_NAME -->"* ]]; then
            echo "$line" >> "$temp_file"
            echo "" >> "$temp_file"
            generate_hub_section >> "$temp_file"
            echo "" >> "$temp_file"
            in_auto_section=true
            continue
        fi
        if [[ "$line" == *"<!-- END AUTO-GENERATED SECTION -->"* && "$in_auto_section" == true ]]; then
            echo "$line" >> "$temp_file"
            in_auto_section=false
            continue
        fi
        if [[ "$in_auto_section" == false ]]; then
            echo "$line" >> "$temp_file"
        fi
    done < "$DOC_FILE"

    mv "$temp_file" "$DOC_FILE"
    echo "Documentation structure section updated successfully."
}

main() {
    if [[ ! -f "$DOC_FILE" ]]; then
        echo "Error: Documentation file $DOC_FILE not found"
        exit 1
    fi
    update_documentation
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
