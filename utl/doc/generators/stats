#!/bin/bash
#######################################################################
# Lab Environment System Metrics Generator
#######################################################################
# File: stats
# Description: Generates real-time system metrics and updates the 
#              System Metrics section in README.md automatically
#
# Usage: ./stats [--update|--markdown|--raw]
#   --update    Update the System Metrics section in README.md
#   --markdown  Output in markdown table format
#   --raw       Output raw numbers only
#   (default)   Output formatted statistics for terminal display
#######################################################################

set -e

# Initialize lab environment - simple approach
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Set LAB_DIR if not already set - PORTABLE for generators subfolder
if [[ -z "${LAB_DIR:-}" ]]; then
    # Script is now in utl/doc/generators, so LAB_DIR is three levels up
    readonly LAB_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
fi

# Load targets configuration
TARGETS_FILE="$(dirname "$SCRIPT_DIR")/config/targets"
if [[ -f "$TARGETS_FILE" ]]; then
    source "$TARGETS_FILE"
else
    echo "Warning: targets file not found at $TARGETS_FILE"
    # Fallback to default directories
    TARGET_DIRECTORIES=("lib" "src" "cfg" "doc")
fi

# Get output file from configuration
if [[ -n "${GENERATOR_OUTPUT_FILES[stats]:-}" ]]; then
    readonly OUTPUT_FILE="$LAB_DIR/${GENERATOR_OUTPUT_FILES[stats]}"
else
    # Fallback to single injection sink
    readonly OUTPUT_FILE="$LAB_DIR/doc/dev/generated-doc-injections.md"
fi
SECTION_NAME="${GENERATOR_SECTIONS[stats]:-System Metrics}"
readonly BACKUP_FILE="$OUTPUT_FILE.backup"

# Generate statistics from target directories
generate_stats() {
    local total_files=0
    local total_dirs=0
    local total_size=0
    
    if [[ "$FORMAT" == "markdown" ]]; then
        echo "*Auto-updated system metrics with real-time analysis*"
        echo ""
        echo "> **Last Updated**: $(date '+%Y-%m-%d %H:%M:%S')"
        echo "> **Generated By**: \`utl/doc/generators/stats\`"
        echo ""
        echo "| Directory | Files | Subdirs | Size (KB) |"
        echo "| :--- | :---: | :---: | ---: |"    
        
        # Process each target directory
        for target_dir in "${TARGET_DIRECTORIES[@]}"; do
            local full_path="$LAB_DIR/$target_dir"
            if [[ -d "$full_path" ]]; then
                # Get file count, dir count and size in as few operations as possible
                local stats_data=$(find "$full_path" -printf "%y\n" 2>/dev/null | sort | uniq -c)
                local files=$(echo "$stats_data" | awk '/f/ {print $1}' || echo 0)
                local dirs=$(echo "$stats_data" | awk '/d/ {print $1}' || echo 0)
                # du is still the most reliable way for size
                local size=$(du -sk "$full_path" 2>/dev/null | cut -f1)
                
                # Format with padding for markdown readability
                printf "| %-15s | %5d | %7d | %9d |\n" "$target_dir" "$files" "$dirs" "$size"
                
                total_files=$((total_files + files))
                total_dirs=$((total_dirs + dirs))
                total_size=$((total_size + size))
            fi
        done
        
        echo "| :--- | :---: | :---: | ---: |"    
        printf "| **%-15s** | **%5d** | **%7d** | **%9d** |\n" "TOTAL" "$total_files" "$total_dirs" "$total_size"
    elif [[ "$FORMAT" == "raw" ]]; then
        for target_dir in "${TARGET_DIRECTORIES[@]}"; do
            local full_path="$LAB_DIR/$target_dir"
            if [[ -d "$full_path" ]]; then
                local files=$(find "$full_path" -type f 2>/dev/null | wc -l)
                total_files=$((total_files + files))
            fi
        done
        echo "$total_files"
    else
        echo "Lab Environment Codebase Statistics"
        echo "=================================="
        # Process each target directory
        for target_dir in "${TARGET_DIRECTORIES[@]}"; do
            local full_path="$LAB_DIR/$target_dir"
            if [[ -d "$full_path" ]]; then
                local files=$(find "$full_path" -type f 2>/dev/null | wc -l)
                printf "%-20s : %d files\n" "$target_dir" "$files"
                total_files=$((total_files + files))
            fi
        done
        echo "----------------------------------"
        echo "Total Files: $total_files"
    fi
}

# Update the output file
update_output_file() {
    if [[ ! -f "$OUTPUT_FILE" ]]; then
        echo "Error: Output file not found at $OUTPUT_FILE"
        return 1
    fi
    
    echo "Updating $OUTPUT_FILE..."
    
    # Create temporary file
    local temp_file=$(mktemp)
    
    # Generate the stats
    local stats_content=$(FORMAT=markdown generate_stats)
    
    # Check if section markers exist
    if grep -q "<!-- AUTO-GENERATED SECTION: $SECTION_NAME -->" "$OUTPUT_FILE"; then
        # Use awk to replace the content between markers
        awk -v stats="$stats_content" -v section="$SECTION_NAME" '
            index($0, "<!-- AUTO-GENERATED SECTION: " section " -->") {
                print $0
                print stats
                skip = 1
                next
            }
            /<!-- END AUTO-GENERATED SECTION -->/ {
                skip = 0
            }
            !skip { print }
        ' "$OUTPUT_FILE" > "$temp_file"
        
        mv "$temp_file" "$OUTPUT_FILE"
        echo "Successfully updated $OUTPUT_FILE"
    else
        echo "Warning: AUTO-GENERATED SECTION marker for '$SECTION_NAME' not found in $OUTPUT_FILE"
        echo "Please add the following markers to $OUTPUT_FILE:"
        echo "<!-- AUTO-GENERATED SECTION: $SECTION_NAME -->"
        echo "<!-- END AUTO-GENERATED SECTION -->"
        rm "$temp_file"
        return 1
    fi
}

# Main function
main() {
    local update=false
    FORMAT="text"
    
    # Simple argument parsing
    for arg in "$@"; do
        case $arg in
            --update) update=true ;;
            --markdown) FORMAT="markdown" ;;
            --raw) FORMAT="raw" ;;
        esac
    done
    
    if [[ "$update" == "true" ]]; then
        update_output_file
    else
        generate_stats
    fi
}

# Execute if run directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
