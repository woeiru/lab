#!/bin/bash
#######################################################################
# Lab Environment System Metrics Generator
#######################################################################
# File: stats
# Description: Generates repository metrics and writes them to STATS.md
#
# Usage: ./stats [--update|--stdout|--markdown|--raw|--text]
#   --update    Write markdown report to the configured output file (default)
#   --stdout    Print report to stdout (uses selected format)
#   --markdown  Print markdown table to stdout
#   --raw       Print total file count only
#   --text      Print terminal-friendly text output
#######################################################################

set -e

# Initialize lab environment - simple approach
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Set LAB_DIR if not already set - PORTABLE for generators subfolder
if [[ -z "${LAB_DIR:-}" ]]; then
    # Script is now in utl/doc/generators, so LAB_DIR is three levels up
    readonly LAB_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
fi

# Load targets configuration
TARGETS_FILE="$(dirname "$SCRIPT_DIR")/config/targets"
if [[ -f "$TARGETS_FILE" ]]; then
    source "$TARGETS_FILE"
else
    echo "Warning: targets file not found at $TARGETS_FILE"
    # Fallback to default directories
    TARGET_DIRECTORIES=("lib" "src" "cfg" "doc")
fi

# Get output file from configuration
if [[ -n "${GENERATOR_OUTPUT_FILES[stats]:-}" ]]; then
    readonly OUTPUT_FILE="$LAB_DIR/${GENERATOR_OUTPUT_FILES[stats]}"
else
    readonly OUTPUT_FILE="$LAB_DIR/STATS.md"
fi

# Generate statistics from target directories
generate_stats() {
    local total_files=0
    local total_dirs=0
    local total_size=0
    
    if [[ "$FORMAT" == "markdown" ]]; then
        echo "*Auto-updated system metrics with real-time analysis*"
        echo ""
        echo "> **Last Updated**: $(date '+%Y-%m-%d %H:%M:%S')"
        echo "> **Generated By**: \`utl/doc/generators/stats\`"
        echo ""
        echo "| Directory | Files | Subdirs | Size (KB) |"
        echo "| :--- | :---: | :---: | ---: |"    
        
        # Process each target directory
        for target_dir in "${TARGET_DIRECTORIES[@]}"; do
            local full_path="$LAB_DIR/$target_dir"
            if [[ -d "$full_path" ]]; then
                # Get file count, dir count and size in as few operations as possible
                local stats_data=$(find "$full_path" -printf "%y\n" 2>/dev/null | sort | uniq -c)
                local files=$(echo "$stats_data" | awk '/f/ {print $1}' || echo 0)
                local dirs=$(echo "$stats_data" | awk '/d/ {print $1}' || echo 0)
                # du is still the most reliable way for size
                local size=$(du -sk "$full_path" 2>/dev/null | cut -f1)
                
                # Format with padding for markdown readability
                printf "| %-15s | %5d | %7d | %9d |\n" "$target_dir" "$files" "$dirs" "$size"
                
                total_files=$((total_files + files))
                total_dirs=$((total_dirs + dirs))
                total_size=$((total_size + size))
            fi
        done
        
        echo "| :--- | :---: | :---: | ---: |"    
        printf "| **%-15s** | **%5d** | **%7d** | **%9d** |\n" "TOTAL" "$total_files" "$total_dirs" "$total_size"
    elif [[ "$FORMAT" == "raw" ]]; then
        for target_dir in "${TARGET_DIRECTORIES[@]}"; do
            local full_path="$LAB_DIR/$target_dir"
            if [[ -d "$full_path" ]]; then
                local files=$(find "$full_path" -type f 2>/dev/null | wc -l)
                total_files=$((total_files + files))
            fi
        done
        echo "$total_files"
    else
        echo "Lab Environment Codebase Statistics"
        echo "=================================="
        # Process each target directory
        for target_dir in "${TARGET_DIRECTORIES[@]}"; do
            local full_path="$LAB_DIR/$target_dir"
            if [[ -d "$full_path" ]]; then
                local files=$(find "$full_path" -type f 2>/dev/null | wc -l)
                printf "%-20s : %d files\n" "$target_dir" "$files"
                total_files=$((total_files + files))
            fi
        done
        echo "----------------------------------"
        echo "Total Files: $total_files"
    fi
}

update_output_file() {
    local output_dir
    output_dir="$(dirname "$OUTPUT_FILE")"
    mkdir -p "$output_dir"

    local temp_file
    temp_file="$(mktemp)"

    local stats_content
    stats_content="$(FORMAT=markdown generate_stats)"

    {
        echo "# Repository Metrics"
        echo ""
        echo "This file is auto-generated by \`./utl/doc/generators/stats --update\`."
        echo ""
        printf '%s\n' "$stats_content"
    } > "$temp_file"

    mv "$temp_file" "$OUTPUT_FILE"
    echo "Updated $OUTPUT_FILE"
}

# Main function
main() {
    local action="update"
    FORMAT="markdown"

    for arg in "$@"; do
        case $arg in
            --update)
                action="update"
                ;;
            --stdout)
                action="stdout"
                ;;
            --markdown)
                action="stdout"
                FORMAT="markdown"
                ;;
            --raw)
                action="stdout"
                FORMAT="raw"
                ;;
            --text)
                action="stdout"
                FORMAT="text"
                ;;
            -h|--help)
                sed -n '1,14p' "$0"
                return 0
                ;;
            *)
                echo "Unknown option: $arg" >&2
                return 1
                ;;
        esac
    done

    if [[ "$action" == "update" ]]; then
        update_output_file
    else
        generate_stats
    fi
}

# Execute if run directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
