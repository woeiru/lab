  else
      for idx in "${!LONGEST_FUNCTION_NAMES[@]}"; do
          echo "      {"
          printf '        "function": "%s",\n' "$(json_escape "${LONGEST_FUNCTION_NAMES[$idx]}")"
          printf '        "file": "%s",\n' "$(json_escape "${LONGEST_FUNCTION_FILES[$idx]}")"
          printf '        "lines": %s\n' "${LONGEST_FUNCTION_LINES[$idx]}"
          if [[ "$idx" -lt "$((${#LONGEST_FUNCTION_NAMES[@]} - 1))" ]]; then
              echo "      },"
          else
              echo "      }"
          fi
      done
  fi
  echo "    ]"
  echo "  },"
  echo "  \"risk_signals\": {"
  echo "    \"counts\": {"
  printf '      "eval": %s,\n' "$RISK_COUNT_EVAL"
  printf '      "backticks": %s,\n' "$RISK_COUNT_BACKTICKS"
  printf '      "chmod_777": %s,\n' "$RISK_COUNT_CHMOD_777"
  printf '      "secret_patterns": %s\n' "$RISK_COUNT_SECRET_PATTERNS"
  echo "    },"
  echo "    \"delta_vs_previous\": {"
  printf '      "eval": %s,\n' "$RISK_DELTA_EVAL"
  printf '      "backticks": %s,\n' "$RISK_DELTA_BACKTICKS"
  printf '      "chmod_777": %s,\n' "$RISK_DELTA_CHMOD_777"
  printf '      "secret_patterns": %s\n' "$RISK_DELTA_SECRET_PATTERNS"
  echo "    },"
  printf '    "new_findings": %s,\n' "$RISK_NEW_FINDINGS"
  printf '    "resolved_findings": %s\n' "$RISK_RESOLVED_FINDINGS"
  echo "  },"
  echo "  \"trend\": {"
    printf '    "points": %s,\n' "$TREND_POINTS"
    printf '    "oldest": "%s",\n' "$(json_escape "$TREND_OLDEST_TIMESTAMP")"
    printf '    "latest": "%s",\n' "$(json_escape "$TREND_LATEST_TIMESTAMP")"
    printf '    "files_delta_10": %s,\n' "$TREND_FILES_DELTA_10"
    printf '    "size_kb_delta_10": %s\n' "$TREND_SIZE_DELTA_10"
    echo "  },"
    echo "  \"quality_gates\": {"
  printf '    "overall": "%s",\n' "$GATE_OVERALL"
  printf '    "syntax": "%s",\n' "$GATE_SYNTAX"
  printf '    "executable_bits": "%s",\n' "$GATE_EXECUTABLES"
  printf '    "growth": "%s",\n' "$GATE_GROWTH"
  printf '    "complexity": "%s",\n' "$GATE_COMPLEXITY"
  printf '    "risk_signals": "%s"\n' "$GATE_RISK_SIGNALS"
  echo "  },"
    echo "  \"history\": {"
    printf '    "previous_snapshot": "%s",\n' "$(json_escape "$PREV_SNAPSHOT_TIMESTAMP")"
    printf '    "history_snapshot": "%s"\n' "$history_snapshot_path"
    echo "  }"
    echo "}"
}

