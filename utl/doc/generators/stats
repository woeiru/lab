#!/bin/bash
#######################################################################
# Lab Environment System Metrics Generator
#######################################################################
# File: stats
# Description: Generates repository health metrics and writes:
#   - STATS.md (human summary)
#   - doc/ref/stats.json (machine metrics)
#   - doc/ref/stats-history/<timestamp>.json (snapshot history)
#
# Usage: ./stats [--update|--stdout|--markdown|--json|--text|--raw]
#######################################################################

set -euo pipefail
export LC_ALL=C
export LANG=C

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly TARGETS_FILE="$(dirname "$SCRIPT_DIR")/config/targets"

if [[ -z "${LAB_DIR:-}" ]]; then
    readonly LAB_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
fi

if [[ -f "$TARGETS_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$TARGETS_FILE"
fi

if [[ -n "${GENERATOR_OUTPUT_FILES[stats]:-}" ]]; then
    readonly STATS_MARKDOWN_FILE="$LAB_DIR/${GENERATOR_OUTPUT_FILES[stats]}"
else
    readonly STATS_MARKDOWN_FILE="$LAB_DIR/STATS.md"
fi

readonly STATS_JSON_FILE="$LAB_DIR/doc/ref/stats.json"
readonly STATS_HISTORY_DIR="$LAB_DIR/doc/ref/stats-history"
readonly METRIC_VERSION="2.0.0"
readonly TREND_HISTORY_LIMIT=10
readonly -a TOP_LEVEL_PATHS=("bin" "cfg" "lib" "src" "val" "utl" "doc")

declare -A PATH_FILES=()
declare -A PATH_DIRS=()
declare -A PATH_SIZE_KB=()
declare -A CHURN_ADD=()
declare -A CHURN_DEL=()

declare -a SYNTAX_FAILED_FILES=()
declare -a EXEC_MISSING_FILES=()
declare -a HOTSPOT_FILES=()
declare -a HOTSPOT_CHURN=()
declare -a HOTSPOT_AUTHORS=()

TOTAL_FILES=0
TOTAL_DIRS=0
TOTAL_SIZE_KB=0
PREV_TOTAL_FILES=0
PREV_TOTAL_DIRS=0
PREV_TOTAL_SIZE_KB=0
DELTA_FILES=0
DELTA_DIRS=0
DELTA_SIZE_KB=0
DELTA_FILES_PCT="n/a"
DELTA_DIRS_PCT="n/a"
DELTA_SIZE_PCT="n/a"

COMMITS_7D=0
COMMITS_30D=0
COMMITS_90D=0

SYNTAX_CHECKED=0
SYNTAX_FAILED=0
SYNTAX_PASSED=0
EXEC_EXPECTED=0
EXEC_ANOMALIES=0

TREND_POINTS=0
TREND_OLDEST_TIMESTAMP="none"
TREND_LATEST_TIMESTAMP="none"
TREND_FILES_DELTA_10=0
TREND_SIZE_DELTA_10=0

GATE_SYNTAX="ok"
GATE_EXECUTABLES="ok"
GATE_GROWTH="ok"
GATE_OVERALL="ok"

TIMESTAMP_UTC=""
TIMESTAMP_FILE=""
GIT_BRANCH="unknown"
GIT_COMMIT="unknown"
GIT_DIRTY="false"
PREV_SNAPSHOT_TIMESTAMP="none"

safe_number() {
    local value="$1"
    if [[ "$value" =~ ^-?[0-9]+$ ]]; then
        printf '%s' "$value"
    else
        printf '0'
    fi
}

percent_change() {
    local previous="$1"
    local current="$2"
    if [[ "$previous" -eq 0 ]]; then
        printf 'n/a'
        return
    fi
    awk -v prev="$previous" -v curr="$current" 'BEGIN { printf "%.2f", ((curr - prev) / prev) * 100 }'
}

json_escape() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//$'\n'/ }"
    printf '%s' "$value"
}

json_num_from_file() {
    local file="$1"
    local key="$2"
    awk -v key="$key" '
        index($0, "\"" key "\"") {
            line=$0
            gsub(/[^0-9-]/, "", line)
            print line
            exit
        }
    ' "$file" 2>/dev/null
}

json_str_from_file() {
    local file="$1"
    local key="$2"
    awk -v key="$key" '
        index($0, "\"" key "\"") {
            if (match($0, /"[^"]*"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
                val=substr($0, RSTART, RLENGTH)
                sub(/^"[^"]*"[[:space:]]*:[[:space:]]*"/, "", val)
                sub(/"$/, "", val)
                print val
                exit
            }
        }
    ' "$file" 2>/dev/null
}

path_index() {
    local path="$1"
    local i=0
    for i in "${!TOP_LEVEL_PATHS[@]}"; do
        if [[ "${TOP_LEVEL_PATHS[$i]}" == "$path" ]]; then
            printf '%s' "$i"
            return 0
        fi
    done
    return 1
}

detect_git_state() {
    if ! git -C "$LAB_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        return
    fi

    GIT_BRANCH="$(git -C "$LAB_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || printf 'unknown')"
    GIT_COMMIT="$(git -C "$LAB_DIR" rev-parse --short HEAD 2>/dev/null || printf 'unknown')"
    if [[ -n "$(git -C "$LAB_DIR" status --porcelain 2>/dev/null)" ]]; then
        GIT_DIRTY="true"
    fi

    COMMITS_7D="$(git -C "$LAB_DIR" log --since='7 days ago' --pretty=format:'%H' 2>/dev/null | wc -l | tr -d ' ')"
    COMMITS_30D="$(git -C "$LAB_DIR" log --since='30 days ago' --pretty=format:'%H' 2>/dev/null | wc -l | tr -d ' ')"
    COMMITS_90D="$(git -C "$LAB_DIR" log --since='90 days ago' --pretty=format:'%H' 2>/dev/null | wc -l | tr -d ' ')"

    COMMITS_7D="$(safe_number "$COMMITS_7D")"
    COMMITS_30D="$(safe_number "$COMMITS_30D")"
    COMMITS_90D="$(safe_number "$COMMITS_90D")"
}

load_previous_snapshot() {
    if [[ ! -f "$STATS_JSON_FILE" ]]; then
        return
    fi

    PREV_TOTAL_FILES="$(safe_number "$(json_num_from_file "$STATS_JSON_FILE" "total_files")")"
    PREV_TOTAL_DIRS="$(safe_number "$(json_num_from_file "$STATS_JSON_FILE" "total_dirs")")"
    PREV_TOTAL_SIZE_KB="$(safe_number "$(json_num_from_file "$STATS_JSON_FILE" "total_size_kb")")"

    local prev_time
    prev_time="$(json_str_from_file "$STATS_JSON_FILE" "generated_at")"
    if [[ -n "$prev_time" ]]; then
        PREV_SNAPSHOT_TIMESTAMP="$prev_time"
    fi
}

collect_repo_shape() {
    local top_path=""
    for top_path in "${TOP_LEVEL_PATHS[@]}"; do
        local full_path="$LAB_DIR/$top_path"
        if [[ ! -d "$full_path" ]]; then
            PATH_FILES["$top_path"]=0
            PATH_DIRS["$top_path"]=0
            PATH_SIZE_KB["$top_path"]=0
            continue
        fi

        local files
        local dirs
        local size_kb

        files="$(find "$full_path" -type f 2>/dev/null | wc -l | tr -d ' ')"
        dirs="$(find "$full_path" -type d 2>/dev/null | wc -l | tr -d ' ')"
        size_kb="$(du -sk "$full_path" 2>/dev/null | awk '{print $1}')"

        files="$(safe_number "$files")"
        dirs="$(safe_number "$dirs")"
        size_kb="$(safe_number "$size_kb")"

        if [[ "$dirs" -gt 0 ]]; then
            dirs=$((dirs - 1))
        fi

        PATH_FILES["$top_path"]="$files"
        PATH_DIRS["$top_path"]="$dirs"
        PATH_SIZE_KB["$top_path"]="$size_kb"
    done

    TOTAL_FILES="$(find "$LAB_DIR" -path "$LAB_DIR/.git" -prune -o -type f -print 2>/dev/null | wc -l | tr -d ' ')"
    TOTAL_DIRS="$(find "$LAB_DIR" -path "$LAB_DIR/.git" -prune -o -type d -print 2>/dev/null | wc -l | tr -d ' ')"
    TOTAL_SIZE_KB="$(du -sk --exclude='.git' "$LAB_DIR" 2>/dev/null | awk '{print $1}')"

    TOTAL_FILES="$(safe_number "$TOTAL_FILES")"
    TOTAL_DIRS="$(safe_number "$TOTAL_DIRS")"
    TOTAL_SIZE_KB="$(safe_number "$TOTAL_SIZE_KB")"

    if [[ "$TOTAL_DIRS" -gt 0 ]]; then
        TOTAL_DIRS=$((TOTAL_DIRS - 1))
    fi

    DELTA_FILES=$((TOTAL_FILES - PREV_TOTAL_FILES))
    DELTA_DIRS=$((TOTAL_DIRS - PREV_TOTAL_DIRS))
    DELTA_SIZE_KB=$((TOTAL_SIZE_KB - PREV_TOTAL_SIZE_KB))

    DELTA_FILES_PCT="$(percent_change "$PREV_TOTAL_FILES" "$TOTAL_FILES")"
    DELTA_DIRS_PCT="$(percent_change "$PREV_TOTAL_DIRS" "$TOTAL_DIRS")"
    DELTA_SIZE_PCT="$(percent_change "$PREV_TOTAL_SIZE_KB" "$TOTAL_SIZE_KB")"
}

collect_hygiene_metrics() {
    local syntax_candidates=()
    local file=""

    if [[ -f "$LAB_DIR/go" ]]; then
        syntax_candidates+=("$LAB_DIR/go")
    fi

    while IFS= read -r file; do
        syntax_candidates+=("$file")
    done < <(find "$LAB_DIR/bin" "$LAB_DIR/lib" "$LAB_DIR/utl/doc/generators" -type f ! -name '*.*' 2>/dev/null | sort)

    while IFS= read -r file; do
        syntax_candidates+=("$file")
    done < <(find "$LAB_DIR/val" "$LAB_DIR/utl" -type f -name '*.sh' 2>/dev/null | sort)

    local seen=""
    local unique_candidates=()
    for file in "${syntax_candidates[@]}"; do
        if [[ "$seen" == *"|$file|"* ]]; then
            continue
        fi
        seen+="|$file|"
        unique_candidates+=("$file")
    done

    SYNTAX_CHECKED=${#unique_candidates[@]}
    SYNTAX_FAILED=0
    SYNTAX_FAILED_FILES=()

    for file in "${unique_candidates[@]}"; do
        if ! bash -n "$file" >/dev/null 2>&1; then
            SYNTAX_FAILED=$((SYNTAX_FAILED + 1))
            SYNTAX_FAILED_FILES+=("${file#$LAB_DIR/}")
        fi
    done
    SYNTAX_PASSED=$((SYNTAX_CHECKED - SYNTAX_FAILED))

    local executable_candidates=()
    EXEC_MISSING_FILES=()

    if [[ -f "$LAB_DIR/go" ]]; then
        executable_candidates+=("$LAB_DIR/go")
    fi
    while IFS= read -r file; do
        executable_candidates+=("$file")
    done < <(find "$LAB_DIR/bin" "$LAB_DIR/utl/doc/generators" -type f ! -name '*.*' 2>/dev/null | sort)
    while IFS= read -r file; do
        executable_candidates+=("$file")
    done < <(find "$LAB_DIR/val" -type f -name '*.sh' 2>/dev/null | sort)

    EXEC_EXPECTED=${#executable_candidates[@]}
    EXEC_ANOMALIES=0
    for file in "${executable_candidates[@]}"; do
        if [[ ! -x "$file" ]]; then
            EXEC_ANOMALIES=$((EXEC_ANOMALIES + 1))
            EXEC_MISSING_FILES+=("${file#$LAB_DIR/}")
        fi
    done
}

collect_window_churn() {
    local days="$1"
    local line=""

    for line in "${TOP_LEVEL_PATHS[@]}"; do
        CHURN_ADD["$days:$line"]=0
        CHURN_DEL["$days:$line"]=0
    done

    if ! git -C "$LAB_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        return
    fi

    while IFS=$'\t' read -r adds dels file; do
        if [[ -z "$file" ]]; then
            continue
        fi
        if [[ ! "$adds" =~ ^[0-9]+$ ]] || [[ ! "$dels" =~ ^[0-9]+$ ]]; then
            continue
        fi

        local top="${file%%/*}"
        if ! path_index "$top" >/dev/null 2>&1; then
            continue
        fi

        local key="$days:$top"
        CHURN_ADD["$key"]=$(( CHURN_ADD["$key"] + adds ))
        CHURN_DEL["$key"]=$(( CHURN_DEL["$key"] + dels ))
    done < <(git -C "$LAB_DIR" log --since="$days days ago" --numstat --pretty=tformat:'' 2>/dev/null)
}

collect_hotspots() {
    HOTSPOT_FILES=()
    HOTSPOT_CHURN=()
    HOTSPOT_AUTHORS=()

    if ! git -C "$LAB_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        return
    fi

    local hotspot_rows
    hotspot_rows="$(git -C "$LAB_DIR" log --since='90 days ago' --numstat --pretty=tformat:'' 2>/dev/null | \
        awk -F '\t' 'NF==3 && $1 ~ /^[0-9]+$/ && $2 ~ /^[0-9]+$/ { c[$3]+=($1+$2) } END { for (f in c) printf "%d\t%s\n", c[f], f }' | \
        sort -t $'\t' -k1,1nr -k2,2 | sed -n '1,10p')"

    local row=""
    while IFS=$'\t' read -r churn file; do
        if [[ -z "${file:-}" ]]; then
            continue
        fi
        HOTSPOT_FILES+=("$file")
        HOTSPOT_CHURN+=("$(safe_number "$churn")")

        local authors
        authors="$(git -C "$LAB_DIR" log --since='90 days ago' --format='%an' -- "$file" 2>/dev/null | sort -u | wc -l | tr -d ' ')"
        HOTSPOT_AUTHORS+=("$(safe_number "$authors")")
    done <<< "$hotspot_rows"
}

collect_trend_summary() {
    TREND_POINTS=0
    TREND_OLDEST_TIMESTAMP="none"
    TREND_LATEST_TIMESTAMP="none"
    TREND_FILES_DELTA_10=0
    TREND_SIZE_DELTA_10=0

    if [[ ! -d "$STATS_HISTORY_DIR" ]]; then
        return
    fi

    local -a history_files=()
    local hist=""
    while IFS= read -r hist; do
        history_files+=("$hist")
    done < <(find "$STATS_HISTORY_DIR" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort)

    local total=${#history_files[@]}
    if [[ "$total" -eq 0 ]]; then
        return
    fi

    local start=0
    if [[ "$total" -gt "$TREND_HISTORY_LIMIT" ]]; then
        start=$((total - TREND_HISTORY_LIMIT))
    fi

    local -a selected=("${history_files[@]:$start}")
    TREND_POINTS=${#selected[@]}

    local first_file="${selected[0]}"
    local last_file="${selected[$((TREND_POINTS - 1))]}"

    TREND_OLDEST_TIMESTAMP="$(json_str_from_file "$first_file" "generated_at")"
    TREND_LATEST_TIMESTAMP="$(json_str_from_file "$last_file" "generated_at")"
    [[ -z "$TREND_OLDEST_TIMESTAMP" ]] && TREND_OLDEST_TIMESTAMP="none"
    [[ -z "$TREND_LATEST_TIMESTAMP" ]] && TREND_LATEST_TIMESTAMP="none"

    local first_files
    local last_files
    local first_size
    local last_size

    first_files="$(safe_number "$(json_num_from_file "$first_file" "total_files")")"
    last_files="$(safe_number "$(json_num_from_file "$last_file" "total_files")")"
    first_size="$(safe_number "$(json_num_from_file "$first_file" "total_size_kb")")"
    last_size="$(safe_number "$(json_num_from_file "$last_file" "total_size_kb")")"

    TREND_FILES_DELTA_10=$((last_files - first_files))
    TREND_SIZE_DELTA_10=$((last_size - first_size))
}

collect_phase_two_metrics() {
    collect_window_churn 7
    collect_window_churn 30
    collect_window_churn 90
    collect_hotspots
    collect_trend_summary
}

evaluate_quality_gates() {
    GATE_SYNTAX="ok"
    GATE_EXECUTABLES="ok"
    GATE_GROWTH="ok"

    if [[ "$SYNTAX_FAILED" -gt 0 ]]; then
        GATE_SYNTAX="fail"
    fi
    if [[ "$EXEC_ANOMALIES" -gt 0 ]]; then
        GATE_EXECUTABLES="warn"
    fi
    if [[ "$DELTA_FILES_PCT" != "n/a" ]] && awk -v p="$DELTA_FILES_PCT" 'BEGIN { exit !(p > 8.0 || p < -8.0) }'; then
        GATE_GROWTH="warn"
    fi

    if [[ "$GATE_SYNTAX" == "fail" ]]; then
        GATE_OVERALL="fail"
    elif [[ "$GATE_EXECUTABLES" == "warn" || "$GATE_GROWTH" == "warn" ]]; then
        GATE_OVERALL="warn"
    else
        GATE_OVERALL="ok"
    fi
}

collect_metrics() {
    TIMESTAMP_UTC="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    TIMESTAMP_FILE="$(date -u '+%Y%m%dT%H%M%SZ')"
    detect_git_state
    load_previous_snapshot
    collect_repo_shape
    collect_hygiene_metrics
    collect_phase_two_metrics
    evaluate_quality_gates
}

render_markdown() {
    local size_mb
    size_mb="$(awk -v kb="$TOTAL_SIZE_KB" 'BEGIN { printf "%.2f", kb / 1024 }')"

    echo "# Repository Metrics"
    echo
    echo "This file is auto-generated by \`./utl/doc/generators/stats --update\`."
    echo
    echo "> **Generated At (UTC)**: $TIMESTAMP_UTC"
    echo "> **Metric Version**: $METRIC_VERSION"
    echo "> **Git Ref**: $GIT_BRANCH@$GIT_COMMIT (dirty=$GIT_DIRTY)"
    echo
    echo "## Overview"
    echo
    echo "| Metric | Value | Delta vs Previous |"
    echo "| --- | ---: | ---: |"
    printf '| Total files | %s | %+d (%s%%) |\n' "$TOTAL_FILES" "$DELTA_FILES" "$DELTA_FILES_PCT"
    printf '| Total directories | %s | %+d (%s%%) |\n' "$TOTAL_DIRS" "$DELTA_DIRS" "$DELTA_DIRS_PCT"
    printf '| Repository size (KB) | %s | %+d (%s%%) |\n' "$TOTAL_SIZE_KB" "$DELTA_SIZE_KB" "$DELTA_SIZE_PCT"
    printf '| Repository size (MB) | %s | - |\n' "$size_mb"
    echo
    echo "| Top-level path | Files | Directories | Size (KB) |"
    echo "| --- | ---: | ---: | ---: |"
    local top_path=""
    for top_path in "${TOP_LEVEL_PATHS[@]}"; do
        printf '| `%s` | %s | %s | %s |\n' "$top_path" "${PATH_FILES[$top_path]:-0}" "${PATH_DIRS[$top_path]:-0}" "${PATH_SIZE_KB[$top_path]:-0}"
    done

    echo
    echo "## Trend Highlights"
    echo
    printf -- '- Commit velocity: 7d=%s, 30d=%s, 90d=%s.\n' "$COMMITS_7D" "$COMMITS_30D" "$COMMITS_90D"
    printf -- '- Snapshot delta: files %+d, dirs %+d, size %+d KB.\n' "$DELTA_FILES" "$DELTA_DIRS" "$DELTA_SIZE_KB"
    printf -- '- 10-snapshot trend: files %+d, size %+d KB (%s -> %s, points=%s).\n' "$TREND_FILES_DELTA_10" "$TREND_SIZE_DELTA_10" "$TREND_OLDEST_TIMESTAMP" "$TREND_LATEST_TIMESTAMP" "$TREND_POINTS"

    echo
    echo "## Change Velocity and Churn"
    echo
    echo "| Path | 7d (+/-) | 30d (+/-) | 90d (+/-) |"
    echo "| --- | ---: | ---: | ---: |"
    for top_path in "${TOP_LEVEL_PATHS[@]}"; do
        printf '| `%s` | %s/%s | %s/%s | %s/%s |\n' "$top_path" "${CHURN_ADD[7:$top_path]:-0}" "${CHURN_DEL[7:$top_path]:-0}" "${CHURN_ADD[30:$top_path]:-0}" "${CHURN_DEL[30:$top_path]:-0}" "${CHURN_ADD[90:$top_path]:-0}" "${CHURN_DEL[90:$top_path]:-0}"
    done

    echo
    echo "| Hotspot File (90d) | Churn | Authors |"
    echo "| --- | ---: | ---: |"
    local i=0
    for i in "${!HOTSPOT_FILES[@]}"; do
        printf '| `%s` | %s | %s |\n' "${HOTSPOT_FILES[$i]}" "${HOTSPOT_CHURN[$i]}" "${HOTSPOT_AUTHORS[$i]}"
    done
    if [[ "${#HOTSPOT_FILES[@]}" -eq 0 ]]; then
        echo "| `none` | 0 | 0 |"
    fi

    echo
    echo "## Top Risks"
    echo
    if [[ "$SYNTAX_FAILED" -gt 0 ]]; then
        printf -- '- Syntax regressions detected: %s files fail `bash -n`.\n' "$SYNTAX_FAILED"
    else
        echo "- No syntax regressions detected in targeted scripts."
    fi
    if [[ "$EXEC_ANOMALIES" -gt 0 ]]; then
        printf -- '- Executable-bit anomalies: %s scripts expected executable are not marked executable.\n' "$EXEC_ANOMALIES"
    else
        echo "- No executable-bit anomalies detected for expected scripts."
    fi
    if [[ "$GATE_GROWTH" == "warn" ]]; then
        printf -- '- Repository growth drift warning: file count changed by %s%% since previous snapshot.\n' "$DELTA_FILES_PCT"
    else
        echo "- Repository growth is within configured drift budget."
    fi

    echo
    echo "## Quality Gates Status"
    echo
    echo "| Gate | Status | Signal |"
    echo "| --- | --- | --- |"
    printf '| Syntax checks (`bash -n`) | `%s` | checked=%s, passed=%s, failed=%s |\n' "$GATE_SYNTAX" "$SYNTAX_CHECKED" "$SYNTAX_PASSED" "$SYNTAX_FAILED"
    printf '| Executable bit hygiene | `%s` | checked=%s, anomalies=%s |\n' "$GATE_EXECUTABLES" "$EXEC_EXPECTED" "$EXEC_ANOMALIES"
    printf '| Growth drift budget | `%s` | file delta=%+d (%s%%) |\n' "$GATE_GROWTH" "$DELTA_FILES" "$DELTA_FILES_PCT"
    printf '| Overall | `%s` | synthesized from gate statuses |\n' "$GATE_OVERALL"
}

render_json() {
    local history_snapshot_path="doc/ref/stats-history/${TIMESTAMP_FILE}.json"

    echo "{"
    printf '  "metric_version": "%s",\n' "$METRIC_VERSION"
    printf '  "generated_at": "%s",\n' "$TIMESTAMP_UTC"
    echo "  \"git\": {"
    printf '    "branch": "%s",\n' "$(json_escape "$GIT_BRANCH")"
    printf '    "commit": "%s",\n' "$(json_escape "$GIT_COMMIT")"
    printf '    "dirty": %s\n' "$GIT_DIRTY"
    echo "  },"
    echo "  \"repo_shape\": {"
    printf '    "total_files": %s,\n' "$TOTAL_FILES"
    printf '    "total_dirs": %s,\n' "$TOTAL_DIRS"
    printf '    "total_size_kb": %s,\n' "$TOTAL_SIZE_KB"
    echo "    \"delta\": {"
    printf '      "files": %s,\n' "$DELTA_FILES"
    printf '      "dirs": %s,\n' "$DELTA_DIRS"
    printf '      "size_kb": %s,\n' "$DELTA_SIZE_KB"
    printf '      "files_percent": "%s",\n' "$DELTA_FILES_PCT"
    printf '      "dirs_percent": "%s",\n' "$DELTA_DIRS_PCT"
    printf '      "size_percent": "%s"\n' "$DELTA_SIZE_PCT"
    echo "    }"
    echo "  },"
    echo "  \"velocity\": {"
    printf '    "commits_7d": %s,\n' "$COMMITS_7D"
    printf '    "commits_30d": %s,\n' "$COMMITS_30D"
    printf '    "commits_90d": %s\n' "$COMMITS_90D"
    echo "  },"
    echo "  \"churn\": {"
    echo "    \"by_path\": ["
    local idx=0
    local top_path=""
    for top_path in "${TOP_LEVEL_PATHS[@]}"; do
        idx=$((idx + 1))
        echo "      {"
        printf '        "path": "%s",\n' "$top_path"
        printf '        "adds_7d": %s,\n' "${CHURN_ADD[7:$top_path]:-0}"
        printf '        "dels_7d": %s,\n' "${CHURN_DEL[7:$top_path]:-0}"
        printf '        "adds_30d": %s,\n' "${CHURN_ADD[30:$top_path]:-0}"
        printf '        "dels_30d": %s,\n' "${CHURN_DEL[30:$top_path]:-0}"
        printf '        "adds_90d": %s,\n' "${CHURN_ADD[90:$top_path]:-0}"
        printf '        "dels_90d": %s\n' "${CHURN_DEL[90:$top_path]:-0}"
        if [[ "$idx" -lt "${#TOP_LEVEL_PATHS[@]}" ]]; then
            echo "      },"
        else
            echo "      }"
        fi
    done
    echo "    ],"
    echo "    \"hotspots_90d\": ["
    if [[ "${#HOTSPOT_FILES[@]}" -eq 0 ]]; then
        echo "      { \"file\": \"none\", \"churn\": 0, \"authors\": 0 }"
    else
        for idx in "${!HOTSPOT_FILES[@]}"; do
            echo "      {"
            printf '        "file": "%s",\n' "$(json_escape "${HOTSPOT_FILES[$idx]}")"
            printf '        "churn": %s,\n' "${HOTSPOT_CHURN[$idx]}"
            printf '        "authors": %s\n' "${HOTSPOT_AUTHORS[$idx]}"
            if [[ "$idx" -lt "$((${#HOTSPOT_FILES[@]} - 1))" ]]; then
                echo "      },"
            else
                echo "      }"
            fi
        done
    fi
    echo "    ]"
    echo "  },"
    echo "  \"hygiene\": {"
    echo "    \"syntax\": {"
    printf '      "checked": %s,\n' "$SYNTAX_CHECKED"
    printf '      "passed": %s,\n' "$SYNTAX_PASSED"
    printf '      "failed": %s\n' "$SYNTAX_FAILED"
    echo "    },"
    echo "    \"executable_bits\": {"
    printf '      "checked": %s,\n' "$EXEC_EXPECTED"
    printf '      "anomalies": %s\n' "$EXEC_ANOMALIES"
    echo "    }"
    echo "  },"
    echo "  \"trend\": {"
    printf '    "points": %s,\n' "$TREND_POINTS"
    printf '    "oldest": "%s",\n' "$(json_escape "$TREND_OLDEST_TIMESTAMP")"
    printf '    "latest": "%s",\n' "$(json_escape "$TREND_LATEST_TIMESTAMP")"
    printf '    "files_delta_10": %s,\n' "$TREND_FILES_DELTA_10"
    printf '    "size_kb_delta_10": %s\n' "$TREND_SIZE_DELTA_10"
    echo "  },"
    echo "  \"quality_gates\": {"
    printf '    "overall": "%s",\n' "$GATE_OVERALL"
    printf '    "syntax": "%s",\n' "$GATE_SYNTAX"
    printf '    "executable_bits": "%s",\n' "$GATE_EXECUTABLES"
    printf '    "growth": "%s"\n' "$GATE_GROWTH"
    echo "  },"
    echo "  \"history\": {"
    printf '    "previous_snapshot": "%s",\n' "$(json_escape "$PREV_SNAPSHOT_TIMESTAMP")"
    printf '    "history_snapshot": "%s"\n' "$history_snapshot_path"
    echo "  }"
    echo "}"
}

render_text() {
    echo "Repository Metrics"
    echo "=================="
    printf 'generated_at_utc: %s\n' "$TIMESTAMP_UTC"
    printf 'git_ref: %s@%s dirty=%s\n' "$GIT_BRANCH" "$GIT_COMMIT" "$GIT_DIRTY"
    printf 'totals: files=%s dirs=%s size_kb=%s\n' "$TOTAL_FILES" "$TOTAL_DIRS" "$TOTAL_SIZE_KB"
    printf 'delta: files=%+d dirs=%+d size_kb=%+d\n' "$DELTA_FILES" "$DELTA_DIRS" "$DELTA_SIZE_KB"
    printf 'velocity: 7d=%s 30d=%s 90d=%s\n' "$COMMITS_7D" "$COMMITS_30D" "$COMMITS_90D"
    printf 'quality_gate: %s\n' "$GATE_OVERALL"
}

render_raw() {
    printf '%s\n' "$TOTAL_FILES"
}

update_output_files() {
    mkdir -p "$(dirname "$STATS_MARKDOWN_FILE")"
    mkdir -p "$(dirname "$STATS_JSON_FILE")"
    mkdir -p "$STATS_HISTORY_DIR"

    local md_tmp
    local json_tmp
    md_tmp="$(mktemp)"
    json_tmp="$(mktemp)"

    render_markdown > "$md_tmp"
    render_json > "$json_tmp"

    mv "$md_tmp" "$STATS_MARKDOWN_FILE"
    mv "$json_tmp" "$STATS_JSON_FILE"
    cp "$STATS_JSON_FILE" "$STATS_HISTORY_DIR/${TIMESTAMP_FILE}.json"

    echo "Updated $STATS_MARKDOWN_FILE"
    echo "Updated $STATS_JSON_FILE"
}

show_help() {
    sed -n '1,12p' "$0"
    cat <<'EOF'

Options:
  --update     Write markdown + json outputs (default)
  --stdout     Print selected format to stdout
  --markdown   Print markdown summary to stdout
  --json       Print JSON metrics to stdout
  --text       Print text summary to stdout
  --raw        Print total file count only
  -h, --help   Show help
EOF
}

main() {
    local action="update"
    local format="markdown"

    for arg in "$@"; do
        case "$arg" in
            --update) action="update" ;;
            --stdout) action="stdout" ;;
            --markdown) action="stdout"; format="markdown" ;;
            --json) action="stdout"; format="json" ;;
            --text) action="stdout"; format="text" ;;
            --raw) action="stdout"; format="raw" ;;
            -h|--help) show_help; return 0 ;;
            *) echo "Unknown option: $arg" >&2; return 1 ;;
        esac
    done

    collect_metrics

    if [[ "$action" == "update" ]]; then
        update_output_files
        return 0
    fi

    case "$format" in
        markdown) render_markdown ;;
        json) render_json ;;
        text) render_text ;;
        raw) render_raw ;;
        *) echo "Unsupported format: $format" >&2; return 1 ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
