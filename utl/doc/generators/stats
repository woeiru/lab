    printf 'generated_at_utc: %s\n' "$TIMESTAMP_UTC"
    printf 'git_ref: %s@%s dirty=%s\n' "$GIT_BRANCH" "$GIT_COMMIT" "$GIT_DIRTY"
    printf 'totals: files=%s dirs=%s size_kb=%s\n' "$TOTAL_FILES" "$TOTAL_DIRS" "$TOTAL_SIZE_KB"
    printf 'delta: files=%+d dirs=%+d size_kb=%+d\n' "$DELTA_FILES" "$DELTA_DIRS" "$DELTA_SIZE_KB"
    printf 'velocity: 7d=%s 30d=%s 90d=%s\n' "$COMMITS_7D" "$COMMITS_30D" "$COMMITS_90D"
    printf 'complexity: p90=%s max=%s gt150=%s\n' "$FUNC_P90_LINES" "$FUNC_MAX_LINES" "$FUNC_GT_150"
    printf 'risk: eval=%s backticks=%s chmod777=%s secret=%s\n' "$RISK_COUNT_EVAL" "$RISK_COUNT_BACKTICKS" "$RISK_COUNT_CHMOD_777" "$RISK_COUNT_SECRET_PATTERNS"
    printf 'test_health: last=%s status=%s duration=%ss p90=%ss\n' "$TEST_LAST_RUN_SUITE" "$TEST_LAST_RUN_STATUS" "$TEST_LAST_RUN_DURATION_SECONDS" "$TEST_TREND_P90_SECONDS"
    printf 'flaky: total=%s over_budget=%s oscillation_over=%s variance_over=%s gate=%s\n' "$FLAKY_TOTAL_CANDIDATES" "$FLAKY_TOTAL_OVER_BUDGET" "$FLAKY_STATUS_OSCILLATION_OVER_BUDGET" "$FLAKY_DURATION_VARIANCE_OVER_BUDGET" "$GATE_TEST_HEALTH"
    printf 'quality_gate: %s\n' "$GATE_OVERALL"
}

render_raw() {
    printf '%s\n' "$TOTAL_FILES"
}

update_output_files() {
    mkdir -p "$(dirname "$STATS_MARKDOWN_FILE")"
    mkdir -p "$(dirname "$STATS_JSON_FILE")"
    mkdir -p "$STATS_HISTORY_DIR"

    local md_tmp
    local json_tmp
    md_tmp="$(mktemp)"
    json_tmp="$(mktemp)"

    render_markdown > "$md_tmp"
    render_json > "$json_tmp"

    mv "$md_tmp" "$STATS_MARKDOWN_FILE"
    mv "$json_tmp" "$STATS_JSON_FILE"
    cp "$STATS_JSON_FILE" "$STATS_HISTORY_DIR/${TIMESTAMP_FILE}.json"

    echo "Updated $STATS_MARKDOWN_FILE"
    echo "Updated $STATS_JSON_FILE"
}

