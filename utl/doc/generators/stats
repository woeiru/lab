collect_complexity_metrics() {
    FUNCTION_COUNT=0
    FUNC_P50_LINES=0
    FUNC_P90_LINES=0
    FUNC_MAX_LINES=0
    FUNC_GT_80=0
    FUNC_GT_120=0
    FUNC_GT_150=0
    LONGEST_FUNCTION_NAMES=()
    LONGEST_FUNCTION_FILES=()
    LONGEST_FUNCTION_LINES=()

    local raw_tmp
    local sorted_tmp
    local top_tmp
    raw_tmp="$(mktemp)"
    sorted_tmp="$(mktemp)"
    top_tmp="$(mktemp)"

    local file=""
    local rel_path=""
    for file in "${CODE_FILES[@]}"; do
        rel_path="${file#$LAB_DIR/}"
        awk -v rel="$rel_path" '
            function brace_delta(s,   tmp, opens, closes) {
                tmp=s
                opens=gsub(/\{/, "{", tmp)
                tmp=s
                closes=gsub(/\}/, "}", tmp)
                return opens-closes
            }
            BEGIN {
                in_fn=0
                depth=0
                fn_len=0
                fn_name=""
            }
            {
                line=$0
                if (!in_fn) {
                    if (line ~ /^[[:space:]]*function[[:space:]]+[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*(\(\))?[[:space:]]*\{/) {
                        fn_name=line
                        sub(/^[[:space:]]*function[[:space:]]+/, "", fn_name)
                        sub(/[[:space:]]*\(\)[[:space:]]*\{.*/, "", fn_name)
                        sub(/[[:space:]]*\{.*/, "", fn_name)
                        in_fn=1
                        fn_len=1
                        depth=brace_delta(line)
                        if (depth <= 0) {
                            printf "%d\t%s\t%s\n", fn_len, fn_name, rel
                            in_fn=0
                            depth=0
                            fn_len=0
                            fn_name=""
                        }
                        next
                    }

                    if (line ~ /^[[:space:]]*[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*\(\)[[:space:]]*\{/) {
                        fn_name=line
                        sub(/^[[:space:]]*/, "", fn_name)
                        sub(/[[:space:]]*\(\)[[:space:]]*\{.*/, "", fn_name)
                        in_fn=1
                        fn_len=1
                        depth=brace_delta(line)
                        if (depth <= 0) {
                            printf "%d\t%s\t%s\n", fn_len, fn_name, rel
                            in_fn=0
                            depth=0
                            fn_len=0
                            fn_name=""
                        }
                    }
                } else {
                    fn_len++
                    depth+=brace_delta(line)
                    if (depth <= 0) {
                        printf "%d\t%s\t%s\n", fn_len, fn_name, rel
                        in_fn=0
                        depth=0
                        fn_len=0
                        fn_name=""
                    }
                }
            }
        ' "$file" >> "$raw_tmp"
    done

    if [[ ! -s "$raw_tmp" ]]; then
        rm -f "$raw_tmp" "$sorted_tmp" "$top_tmp"
        return
    fi

    sort -t $'\t' -k1,1n -k3,3 -k2,2 "$raw_tmp" > "$sorted_tmp"

    FUNCTION_COUNT="$(wc -l < "$sorted_tmp" | tr -d ' ')"
    FUNCTION_COUNT="$(safe_number "$FUNCTION_COUNT")"

    if [[ "$FUNCTION_COUNT" -gt 0 ]]; then
        local p50_rank=$(( (50 * FUNCTION_COUNT + 99) / 100 ))
        local p90_rank=$(( (90 * FUNCTION_COUNT + 99) / 100 ))
        [[ "$p50_rank" -lt 1 ]] && p50_rank=1
        [[ "$p90_rank" -lt 1 ]] && p90_rank=1

        FUNC_P50_LINES="$(awk -v target="$p50_rank" 'NR==target { print $1; exit }' "$sorted_tmp")"
        FUNC_P90_LINES="$(awk -v target="$p90_rank" 'NR==target { print $1; exit }' "$sorted_tmp")"
        FUNC_MAX_LINES="$(awk 'END { print $1 }' "$sorted_tmp")"
        FUNC_GT_80="$(awk '$1>80 { c++ } END { print c+0 }' "$sorted_tmp")"
        FUNC_GT_120="$(awk '$1>120 { c++ } END { print c+0 }' "$sorted_tmp")"
        FUNC_GT_150="$(awk '$1>150 { c++ } END { print c+0 }' "$sorted_tmp")"
    fi

    FUNC_P50_LINES="$(safe_number "$FUNC_P50_LINES")"
    FUNC_P90_LINES="$(safe_number "$FUNC_P90_LINES")"
    FUNC_MAX_LINES="$(safe_number "$FUNC_MAX_LINES")"
    FUNC_GT_80="$(safe_number "$FUNC_GT_80")"
    FUNC_GT_120="$(safe_number "$FUNC_GT_120")"
    FUNC_GT_150="$(safe_number "$FUNC_GT_150")"

    sort -t $'\t' -k1,1nr -k3,3 -k2,2 "$raw_tmp" | sed -n '1,10p' > "$top_tmp"
    local lines=""
    local fn=""
    while IFS=$'\t' read -r lines fn rel_path; do
        [[ -z "${fn:-}" ]] && continue
        LONGEST_FUNCTION_LINES+=("$(safe_number "$lines")")
        LONGEST_FUNCTION_NAMES+=("$fn")
        LONGEST_FUNCTION_FILES+=("$rel_path")
    done < "$top_tmp"

    rm -f "$raw_tmp" "$sorted_tmp" "$top_tmp"
}

collect_risk_signals() {
    RISK_COUNT_EVAL=0
    RISK_COUNT_BACKTICKS=0
    RISK_COUNT_CHMOD_777=0
    RISK_COUNT_SECRET_PATTERNS=0
    RISK_DELTA_EVAL=0
    RISK_DELTA_BACKTICKS=0
    RISK_DELTA_CHMOD_777=0
    RISK_DELTA_SECRET_PATTERNS=0
    RISK_NEW_FINDINGS=0
    RISK_RESOLVED_FINDINGS=0

    local file=""
    local eval_count
    local backtick_count
    local chmod_count
    local secret_count
    local result

    for file in "${CODE_FILES[@]}"; do
        result="$(awk '
            BEGIN {
                eval_count=0
                backtick_count=0
                chmod_count=0
                secret_count=0
            }
            {
                line=$0
                code=line
                sub(/[[:space:]]+#.*/, "", code)

                temp=code
                while (match(temp, /(^|[^[:alnum:]_])eval[[:space:]]+/)) {
                    eval_count++
                    temp=substr(temp, RSTART+RLENGTH)
                }

                temp=code
                backtick_count+=gsub(/`[^`]+`/, "&", temp)

                if (code ~ /(^|[[:space:];|&])chmod[[:space:]]+[^#]*[[:space:]]0?777([[:space:]]|$)/) {
                    chmod_count++
                }

                lower=tolower(code)
                if (
                    code ~ /BEGIN[[:space:]]+([A-Z]+[[:space:]]+)?PRIVATE[[:space:]]+KEY/ ||
                    code ~ /AKIA[0-9A-Z]{16}/
                ) {
                    secret_count++
                    next
                }

                eq=index(code, "=")
                if (eq > 0) {
                    lhs=tolower(substr(code, 1, eq - 1))
                    rhs=substr(code, eq + 1)
                    gsub(/^[[:space:]]+|[[:space:]]+$/, "", lhs)
                    gsub(/^[[:space:]]+|[[:space:]]+$/, "", rhs)

                    if (lhs ~ /(password|passwd|token|secret|api[_-]?key)/) {
                        if (rhs ~ /^\$/ || rhs ~ /\$\{/ || rhs ~ /^\$\(/ || rhs ~ /^`/) {
                            next
                        }

                        value=rhs
                        sub(/[[:space:]].*$/, "", value)
                        if (value ~ /^".*"$/) {
                            sub(/^"/, "", value)
                            sub(/"$/, "", value)
                        }

                        lower_value=tolower(value)
                        if (length(value) < 12) {
                            next
                        }
                        if (lower_value ~ /(changeme|change_me|example|dummy|sample|test|placeholder|your_|xxxxx|null|none)/) {
                            next
                        }
                        if (value ~ /^(<[^>]*>|\*+)$/) {
                            next
                        }

                        secret_count++
                    }
                }
            }
            END {
                printf "%d\t%d\t%d\t%d\n", eval_count, backtick_count, chmod_count, secret_count
            }
        ' "$file" 2>/dev/null || true)"

        eval_count="$(safe_number "$(awk -F '\t' '{print $1}' <<< "$result")")"
        backtick_count="$(safe_number "$(awk -F '\t' '{print $2}' <<< "$result")")"
        chmod_count="$(safe_number "$(awk -F '\t' '{print $3}' <<< "$result")")"
        secret_count="$(safe_number "$(awk -F '\t' '{print $4}' <<< "$result")")"

        RISK_COUNT_EVAL=$((RISK_COUNT_EVAL + eval_count))
        RISK_COUNT_BACKTICKS=$((RISK_COUNT_BACKTICKS + backtick_count))
        RISK_COUNT_CHMOD_777=$((RISK_COUNT_CHMOD_777 + chmod_count))
        RISK_COUNT_SECRET_PATTERNS=$((RISK_COUNT_SECRET_PATTERNS + secret_count))
    done

    RISK_DELTA_EVAL=$((RISK_COUNT_EVAL - PREV_RISK_COUNT_EVAL))
    RISK_DELTA_BACKTICKS=$((RISK_COUNT_BACKTICKS - PREV_RISK_COUNT_BACKTICKS))
    RISK_DELTA_CHMOD_777=$((RISK_COUNT_CHMOD_777 - PREV_RISK_COUNT_CHMOD_777))
    RISK_DELTA_SECRET_PATTERNS=$((RISK_COUNT_SECRET_PATTERNS - PREV_RISK_COUNT_SECRET_PATTERNS))

    update_delta_counters "$RISK_DELTA_EVAL"
    update_delta_counters "$RISK_DELTA_BACKTICKS"
    update_delta_counters "$RISK_DELTA_CHMOD_777"
    update_delta_counters "$RISK_DELTA_SECRET_PATTERNS"
}

collect_phase_three_metrics() {
    collect_code_file_list
    collect_complexity_metrics
    collect_risk_signals
}

evaluate_quality_gates() {
    GATE_SYNTAX="ok"
    GATE_EXECUTABLES="ok"
    GATE_GROWTH="ok"
    GATE_COMPLEXITY="ok"
    GATE_RISK_SIGNALS="ok"

    if [[ "$SYNTAX_FAILED" -gt 0 ]]; then
        GATE_SYNTAX="fail"
    fi
    if [[ "$EXEC_ANOMALIES" -gt 0 ]]; then
        GATE_EXECUTABLES="warn"
    fi
    if [[ "$DELTA_FILES_PCT" != "n/a" ]] && awk -v p="$DELTA_FILES_PCT" 'BEGIN { exit !(p > 8.0 || p < -8.0) }'; then
        GATE_GROWTH="warn"
    fi
    if [[ "$FUNC_GT_150" -gt 3 ]]; then
        GATE_COMPLEXITY="fail"
    elif [[ "$FUNC_GT_150" -gt 0 ]]; then
        GATE_COMPLEXITY="warn"
    fi
    if [[ "$RISK_DELTA_SECRET_PATTERNS" -gt 0 ]]; then
        GATE_RISK_SIGNALS="fail"
    elif [[ "$RISK_DELTA_EVAL" -gt 0 || "$RISK_DELTA_BACKTICKS" -gt 0 || "$RISK_DELTA_CHMOD_777" -gt 0 ]]; then
        GATE_RISK_SIGNALS="warn"
    fi

    if [[ "$GATE_SYNTAX" == "fail" || "$GATE_COMPLEXITY" == "fail" || "$GATE_RISK_SIGNALS" == "fail" ]]; then
        GATE_OVERALL="fail"
    elif [[ "$GATE_EXECUTABLES" == "warn" || "$GATE_GROWTH" == "warn" || "$GATE_COMPLEXITY" == "warn" || "$GATE_RISK_SIGNALS" == "warn" ]]; then
        GATE_OVERALL="warn"
    else
        GATE_OVERALL="ok"
    fi
}

collect_metrics() {
    TIMESTAMP_UTC="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    TIMESTAMP_FILE="$(date -u '+%Y%m%dT%H%M%SZ')"
    detect_git_state
    load_previous_snapshot
    collect_repo_shape
    collect_hygiene_metrics
    collect_phase_two_metrics
    collect_phase_three_metrics
    evaluate_quality_gates
}

enforce_ci_gate() {
    if [[ "$CI_GATE_ENABLED" != "true" ]]; then
        return 0
    fi

    local -a failures=()
    if [[ "$GATE_SYNTAX" == "fail" ]]; then
        failures+=("syntax checks failing")
    fi
    if [[ "$GATE_RISK_SIGNALS" == "fail" ]]; then
        failures+=("new secret-pattern findings detected")
    fi

    if [[ "${#failures[@]}" -eq 0 ]]; then
        return 0
    fi

    echo "CI gate failed: ${failures[*]}" >&2
    return 2
}

