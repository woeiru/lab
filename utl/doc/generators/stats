    echo "| --- | ---: | ---: | ---: |"
    local top_path=""
    for top_path in "${TOP_LEVEL_PATHS[@]}"; do
        printf '| `%s` | %s | %s | %s |\n' "$top_path" "${PATH_FILES[$top_path]:-0}" "${PATH_DIRS[$top_path]:-0}" "${PATH_SIZE_KB[$top_path]:-0}"
    done

    echo
    echo "## Trend Highlights"
    echo
    printf -- '- Commit velocity: 7d=%s, 30d=%s, 90d=%s.\n' "$COMMITS_7D" "$COMMITS_30D" "$COMMITS_90D"
    printf -- '- Snapshot delta: files %+d, dirs %+d, size %+d KB.\n' "$DELTA_FILES" "$DELTA_DIRS" "$DELTA_SIZE_KB"
    printf -- '- 10-snapshot trend: files %+d, size %+d KB (%s -> %s, points=%s).\n' "$TREND_FILES_DELTA_10" "$TREND_SIZE_DELTA_10" "$TREND_OLDEST_TIMESTAMP" "$TREND_LATEST_TIMESTAMP" "$TREND_POINTS"

    echo
    echo "## Change Velocity and Churn"
    echo
    echo "| Path | 7d (+/-) | 30d (+/-) | 90d (+/-) |"
    echo "| --- | ---: | ---: | ---: |"
    for top_path in "${TOP_LEVEL_PATHS[@]}"; do
        printf '| `%s` | %s/%s | %s/%s | %s/%s |\n' "$top_path" "${CHURN_ADD[7:$top_path]:-0}" "${CHURN_DEL[7:$top_path]:-0}" "${CHURN_ADD[30:$top_path]:-0}" "${CHURN_DEL[30:$top_path]:-0}" "${CHURN_ADD[90:$top_path]:-0}" "${CHURN_DEL[90:$top_path]:-0}"
    done

    echo
    echo "| Hotspot File (90d) | Churn | Authors |"
    echo "| --- | ---: | ---: |"
