update_delta_counters() {
    local value="$1"
    if [[ "$value" -gt 0 ]]; then
        RISK_NEW_FINDINGS=$((RISK_NEW_FINDINGS + value))
    elif [[ "$value" -lt 0 ]]; then
        RISK_RESOLVED_FINDINGS=$((RISK_RESOLVED_FINDINGS + (-value)))
    fi
}

safe_number() {
    local value="$1"
    if [[ "$value" =~ ^-?[0-9]+$ ]]; then
        printf '%s' "$value"
    else
        printf '0'
    fi
}

percent_change() {
    local previous="$1"
    local current="$2"
    if [[ "$previous" -eq 0 ]]; then
        printf 'n/a'
        return
    fi
    awk -v prev="$previous" -v curr="$current" 'BEGIN { printf "%.2f", ((curr - prev) / prev) * 100 }'
}

json_escape() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//$'\n'/ }"
    printf '%s' "$value"
}

json_num_from_file() {
    local file="$1"
    local key="$2"
    awk -v key="$key" '
        index($0, "\"" key "\"") {
            line=$0
            gsub(/[^0-9-]/, "", line)
            print line
            exit
        }
    ' "$file" 2>/dev/null
}

json_str_from_file() {
    local file="$1"
    local key="$2"
    awk -v key="$key" '
        index($0, "\"" key "\"") {
            if (match($0, /"[^"]*"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
                val=substr($0, RSTART, RLENGTH)
                sub(/^"[^"]*"[[:space:]]*:[[:space:]]*"/, "", val)
                sub(/"$/, "", val)
                print val
                exit
            }
        }
    ' "$file" 2>/dev/null
}

parse_positive_int() {
    local value="$1"
    if [[ "$value" =~ ^[0-9]+$ ]] && [[ "$value" -gt 0 ]]; then
        printf '%s' "$value"
    else
        printf '0'
    fi
}

parse_non_negative_int() {
    local value="$1"
    if [[ "$value" =~ ^[0-9]+$ ]]; then
        printf '%s' "$value"
    else
        printf '0'
    fi
}

register_flaky_suite_budget() {
    local suite="$1"
    local oscillation_budget="$2"
    local variance_budget="$3"

    [[ -z "$suite" ]] && return 1

    oscillation_budget="$(parse_non_negative_int "$oscillation_budget")"
    variance_budget="$(parse_non_negative_int "$variance_budget")"

    if [[ -z "${FLAKY_SUITE_OSC_BUDGET[$suite]+x}" ]]; then
        FLAKY_BUDGET_SUITES+=("$suite")
    fi

    FLAKY_SUITE_OSC_BUDGET["$suite"]="$oscillation_budget"
    FLAKY_SUITE_VAR_BUDGET["$suite"]="$variance_budget"
    return 0
}

register_flaky_suite_budget_default() {
    local suite="$1"
    local oscillation_budget="$2"
    local variance_budget="$3"

    [[ -z "$suite" ]] && return 1
    if [[ -n "${FLAKY_SUITE_OSC_BUDGET[$suite]+x}" ]]; then
        return 0
    fi

    register_flaky_suite_budget "$suite" "$oscillation_budget" "$variance_budget"
}

apply_flaky_budget_profile() {
    local profile="$1"

    case "$profile" in
        none|strict)
            ;;
        balanced)
            register_flaky_suite_budget_default "val/core/agents_md_test.sh" 1 1
            register_flaky_suite_budget_default "val/core/stats_generator_test.sh" 1 1
            ;;
        relaxed)
            register_flaky_suite_budget_default "val/core/agents_md_test.sh" 2 2
            register_flaky_suite_budget_default "val/core/stats_generator_test.sh" 2 2
            ;;
        *)
            return 1
            ;;
    esac

    FLAKY_BUDGET_PROFILE="$profile"
    return 0
}

parse_flaky_suite_budget_entry() {
    local entry="$1"
    local suite=""
    local oscillation_budget=""
    local variance_budget=""
    local extra=""

    IFS=':' read -r suite oscillation_budget variance_budget extra <<< "$entry"
    if [[ -z "$suite" || -z "$oscillation_budget" || -z "$variance_budget" || -n "$extra" ]]; then
        return 1
    fi
    if [[ ! "$oscillation_budget" =~ ^[0-9]+$ || ! "$variance_budget" =~ ^[0-9]+$ ]]; then
        return 1
    fi

    register_flaky_suite_budget "$suite" "$oscillation_budget" "$variance_budget"
}

load_flaky_suite_budgets_from_env() {
    local budgets_csv="${STATS_FLAKY_SUITE_BUDGETS:-}"
    [[ -z "$budgets_csv" ]] && return 0

    local old_ifs="$IFS"
    local entry=""
    IFS=','
    for entry in $budgets_csv; do
        if ! parse_flaky_suite_budget_entry "$entry"; then
            echo "Invalid STATS_FLAKY_SUITE_BUDGETS entry: $entry" >&2
            IFS="$old_ifs"
            return 1
        fi
    done
    IFS="$old_ifs"
}

load_flaky_budget_profile_from_env() {
    local profile="${STATS_FLAKY_BUDGET_PROFILE:-}"
    [[ -z "$profile" ]] && return 0

    if ! apply_flaky_budget_profile "$profile"; then
        echo "Invalid STATS_FLAKY_BUDGET_PROFILE: $profile" >&2
        return 1
    fi
}

append_test_record() {
    local records_file="$1"
    local timestamp="$2"
    local suite="$3"
    local status="$4"
    local duration="$5"

    if [[ -z "$timestamp" || "$timestamp" == "none" ]]; then
        return
    fi
    if [[ -z "$suite" ]]; then
        suite="unknown"
    fi
    if [[ "$status" != "pass" && "$status" != "fail" ]]; then
        return
    fi

    duration="$(parse_positive_int "$duration")"
    if [[ "$duration" -eq 0 ]]; then
        return
    fi

    printf '%s\t%s\t%s\t%s\n' "$timestamp" "$suite" "$status" "$duration" >> "$records_file"
}

collect_test_health_from_stats_history() {
    local records_file="$1"
    if [[ ! -d "$STATS_HISTORY_DIR" ]]; then
        return
    fi

    local hist_file=""
    local status=""
    local duration=""
    local timestamp=""
    local suite=""
    while IFS= read -r hist_file; do
        status="$(json_str_from_file "$hist_file" "status")"
        duration="$(safe_number "$(json_num_from_file "$hist_file" "duration_seconds")")"
        timestamp="$(json_str_from_file "$hist_file" "timestamp")"
        suite="$(json_str_from_file "$hist_file" "suite")"

        if [[ -z "$timestamp" ]]; then
            timestamp="$(json_str_from_file "$hist_file" "generated_at")"
        fi
        if [[ -z "$suite" ]]; then
            suite="snapshot"
        fi
        append_test_record "$records_file" "$timestamp" "$suite" "$status" "$duration"
    done < <(find "$STATS_HISTORY_DIR" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort)
}

sample_test_health_records() {
    local records_file="$1"
    if [[ "$TEST_HEALTH_SAMPLE_ENABLED" != "true" ]]; then
        return
    fi

    local suites_csv="${STATS_TEST_SAMPLE_SUITES:-val/core/agents_md_test.sh}"
    local IFS=','
    local suites=($suites_csv)
    local suite=""
    local run_index=0
    local start_secs=0
    local end_secs=0
    local duration=0
    local run_status=""
    local run_timestamp=""

    for suite in "${suites[@]}"; do
        suite="${suite#./}"
        if [[ ! -f "$LAB_DIR/$suite" ]]; then
            continue
        fi

        for ((run_index=1; run_index<=TEST_HEALTH_SAMPLE_RUNS; run_index++)); do
            start_secs="$(date +%s)"
            if bash "$LAB_DIR/$suite" >/dev/null 2>&1; then
                run_status="pass"
            else
                run_status="fail"
            fi
            end_secs="$(date +%s)"
            duration=$((end_secs - start_secs))
            if [[ "$duration" -lt 1 ]]; then
                duration=1
            fi
            run_timestamp="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
            append_test_record "$records_file" "$run_timestamp" "$suite" "$run_status" "$duration"
        done
    done
}

collect_test_health_metrics() {
    TEST_LAST_RUN_STATUS="unknown"
    TEST_LAST_RUN_DURATION_SECONDS=0
    TEST_LAST_RUN_TIMESTAMP="none"
    TEST_LAST_RUN_SUITE="none"
    TEST_HISTORY_POINTS=0
    TEST_TREND_P50_SECONDS=0
    TEST_TREND_P90_SECONDS=0
    FLAKY_TOTAL_CANDIDATES=0
    FLAKY_STATUS_OSCILLATION_COUNT=0
    FLAKY_DURATION_VARIANCE_COUNT=0
    FLAKY_TOTAL_OVER_BUDGET=0
    FLAKY_STATUS_OSCILLATION_OVER_BUDGET=0
    FLAKY_DURATION_VARIANCE_OVER_BUDGET=0
    FLAKY_CANDIDATE_SUITES=()
    FLAKY_CANDIDATE_REASONS=()
    FLAKY_CANDIDATE_COUNTS=()
    FLAKY_CANDIDATE_MIN_SECONDS=()
    FLAKY_CANDIDATE_MAX_SECONDS=()

    local records_tmp
    local sorted_tmp
    local trend_tmp
    local candidates_tmp
    records_tmp="$(mktemp)"
    sorted_tmp="$(mktemp)"
    trend_tmp="$(mktemp)"
    candidates_tmp="$(mktemp)"

    collect_test_health_from_stats_history "$records_tmp"
    sample_test_health_records "$records_tmp"

    if [[ ! -s "$records_tmp" ]]; then
        rm -f "$records_tmp" "$sorted_tmp" "$trend_tmp" "$candidates_tmp"
        return
    fi

    sort -u -t $'\t' -k1,1 -k2,2 -k3,3 -k4,4n "$records_tmp" > "$sorted_tmp"

    local last_line
    last_line="$(tail -n 1 "$sorted_tmp")"
    if [[ -n "$last_line" ]]; then
        TEST_LAST_RUN_TIMESTAMP="$(awk -F '\t' '{print $1}' <<< "$last_line")"
        TEST_LAST_RUN_SUITE="$(awk -F '\t' '{print $2}' <<< "$last_line")"
        TEST_LAST_RUN_STATUS="$(awk -F '\t' '{print $3}' <<< "$last_line")"
        TEST_LAST_RUN_DURATION_SECONDS="$(safe_number "$(awk -F '\t' '{print $4}' <<< "$last_line")")"
    fi

    TEST_HISTORY_POINTS="$(wc -l < "$sorted_tmp" | tr -d ' ')"
    TEST_HISTORY_POINTS="$(safe_number "$TEST_HISTORY_POINTS")"

    if [[ "$TEST_HISTORY_POINTS" -gt "$TEST_HEALTH_TREND_LIMIT" ]]; then
        local start_line=$((TEST_HISTORY_POINTS - TEST_HEALTH_TREND_LIMIT + 1))
        awk -F '\t' -v start="$start_line" 'NR>=start { print $0 }' "$sorted_tmp" > "$trend_tmp"
    else
        cp "$sorted_tmp" "$trend_tmp"
    fi

    local trend_count
    trend_count="$(wc -l < "$trend_tmp" | tr -d ' ')"
    trend_count="$(safe_number "$trend_count")"
    if [[ "$trend_count" -gt 0 ]]; then
        local durations_tmp
        durations_tmp="$(mktemp)"
        awk -F '\t' '{print $4}' "$trend_tmp" | sort -n > "$durations_tmp"
        local p50_rank=$(( (50 * trend_count + 99) / 100 ))
        local p90_rank=$(( (90 * trend_count + 99) / 100 ))
        [[ "$p50_rank" -lt 1 ]] && p50_rank=1
        [[ "$p90_rank" -lt 1 ]] && p90_rank=1
        TEST_TREND_P50_SECONDS="$(safe_number "$(awk -v target="$p50_rank" 'NR==target { print $1; exit }' "$durations_tmp")")"
        TEST_TREND_P90_SECONDS="$(safe_number "$(awk -v target="$p90_rank" 'NR==target { print $1; exit }' "$durations_tmp")")"
        rm -f "$durations_tmp"
    fi

    awk -F '\t' -v min_samples="$FLAKY_MIN_SAMPLES" -v min_delta="$FLAKY_MIN_DELTA_SECONDS" -v min_ratio="$FLAKY_MIN_RATIO_PERCENT" '
        {
            suite=$2
            status=$3
            duration=$4 + 0
            count[suite]++
            if (!(suite in min_dur) || duration < min_dur[suite]) min_dur[suite]=duration
            if (!(suite in max_dur) || duration > max_dur[suite]) max_dur[suite]=duration
            if (status == "pass") seen_pass[suite]=1
            if (status == "fail") seen_fail[suite]=1
        }
        END {
            for (suite in count) {
                reason=""
                if (seen_pass[suite] && seen_fail[suite]) {
                    reason="status_oscillation"
                }
                if (count[suite] >= min_samples && (max_dur[suite] - min_dur[suite]) >= min_delta && ((max_dur[suite] * 100) >= (min_dur[suite] * min_ratio))) {
                    if (reason == "") {
                        reason="duration_variance"
                    } else {
                        reason=reason "+duration_variance"
                    }
                }
                if (reason != "") {
                    printf "%s\t%s\t%d\t%d\t%d\n", suite, reason, count[suite], min_dur[suite], max_dur[suite]
                }
            }
        }
    ' "$sorted_tmp" | sort -t $'\t' -k1,1 > "$candidates_tmp"

    local row=""
    local suite=""
    local reason=""
    local count=""
    local min_dur=""
    local max_dur=""
    local over_budget="false"
    local oscillation_budget=0
    local variance_budget=0
    while IFS=$'\t' read -r suite reason count min_dur max_dur; do
        [[ -z "$suite" ]] && continue
        FLAKY_CANDIDATE_SUITES+=("$suite")
        FLAKY_CANDIDATE_REASONS+=("$reason")
        FLAKY_CANDIDATE_COUNTS+=("$(safe_number "$count")")
        FLAKY_CANDIDATE_MIN_SECONDS+=("$(safe_number "$min_dur")")
        FLAKY_CANDIDATE_MAX_SECONDS+=("$(safe_number "$max_dur")")
        FLAKY_TOTAL_CANDIDATES=$((FLAKY_TOTAL_CANDIDATES + 1))

        oscillation_budget="$(safe_number "${FLAKY_SUITE_OSC_BUDGET[$suite]:-0}")"
        variance_budget="$(safe_number "${FLAKY_SUITE_VAR_BUDGET[$suite]:-0}")"
        over_budget="false"

        if [[ "$reason" == *"status_oscillation"* ]]; then
            FLAKY_STATUS_OSCILLATION_COUNT=$((FLAKY_STATUS_OSCILLATION_COUNT + 1))
            if [[ "$oscillation_budget" -lt 1 ]]; then
                FLAKY_STATUS_OSCILLATION_OVER_BUDGET=$((FLAKY_STATUS_OSCILLATION_OVER_BUDGET + 1))
                over_budget="true"
            fi
        fi
        if [[ "$reason" == *"duration_variance"* ]]; then
            FLAKY_DURATION_VARIANCE_COUNT=$((FLAKY_DURATION_VARIANCE_COUNT + 1))
            if [[ "$variance_budget" -lt 1 ]]; then
                FLAKY_DURATION_VARIANCE_OVER_BUDGET=$((FLAKY_DURATION_VARIANCE_OVER_BUDGET + 1))
                over_budget="true"
            fi
        fi
        if [[ "$over_budget" == "true" ]]; then
            FLAKY_TOTAL_OVER_BUDGET=$((FLAKY_TOTAL_OVER_BUDGET + 1))
        fi
    done < "$candidates_tmp"

    rm -f "$records_tmp" "$sorted_tmp" "$trend_tmp" "$candidates_tmp"
}

path_index() {
    local path="$1"
    local i=0
    for i in "${!TOP_LEVEL_PATHS[@]}"; do
        if [[ "${TOP_LEVEL_PATHS[$i]}" == "$path" ]]; then
            printf '%s' "$i"
            return 0
        fi
    done
    return 1
}

detect_git_state() {
    if ! git -C "$LAB_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        return
    fi

    GIT_BRANCH="$(git -C "$LAB_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || printf 'unknown')"
    GIT_COMMIT="$(git -C "$LAB_DIR" rev-parse --short HEAD 2>/dev/null || printf 'unknown')"
    if [[ -n "$(git -C "$LAB_DIR" status --porcelain 2>/dev/null)" ]]; then
        GIT_DIRTY="true"
    fi

    COMMITS_7D="$(git -C "$LAB_DIR" log --since='7 days ago' --pretty=format:'%H' 2>/dev/null | wc -l | tr -d ' ')"
    COMMITS_30D="$(git -C "$LAB_DIR" log --since='30 days ago' --pretty=format:'%H' 2>/dev/null | wc -l | tr -d ' ')"
    COMMITS_90D="$(git -C "$LAB_DIR" log --since='90 days ago' --pretty=format:'%H' 2>/dev/null | wc -l | tr -d ' ')"

    COMMITS_7D="$(safe_number "$COMMITS_7D")"
    COMMITS_30D="$(safe_number "$COMMITS_30D")"
    COMMITS_90D="$(safe_number "$COMMITS_90D")"
}

load_previous_snapshot() {
    if [[ ! -f "$STATS_JSON_FILE" ]]; then
        return
    fi

    PREV_TOTAL_FILES="$(safe_number "$(json_num_from_file "$STATS_JSON_FILE" "total_files")")"
    PREV_TOTAL_DIRS="$(safe_number "$(json_num_from_file "$STATS_JSON_FILE" "total_dirs")")"
    PREV_TOTAL_SIZE_KB="$(safe_number "$(json_num_from_file "$STATS_JSON_FILE" "total_size_kb")")"
    PREV_RISK_COUNT_EVAL="$(safe_number "$(json_num_from_file "$STATS_JSON_FILE" "eval")")"
    PREV_RISK_COUNT_BACKTICKS="$(safe_number "$(json_num_from_file "$STATS_JSON_FILE" "backticks")")"
    PREV_RISK_COUNT_CHMOD_777="$(safe_number "$(json_num_from_file "$STATS_JSON_FILE" "chmod_777")")"
    PREV_RISK_COUNT_SECRET_PATTERNS="$(safe_number "$(json_num_from_file "$STATS_JSON_FILE" "secret_patterns")")"

    local prev_time
    prev_time="$(json_str_from_file "$STATS_JSON_FILE" "generated_at")"
    if [[ -n "$prev_time" ]]; then
        PREV_SNAPSHOT_TIMESTAMP="$prev_time"
    fi
}

collect_repo_shape() {
    local top_path=""
    for top_path in "${TOP_LEVEL_PATHS[@]}"; do
        local full_path="$LAB_DIR/$top_path"
        if [[ ! -d "$full_path" ]]; then
            PATH_FILES["$top_path"]=0
            PATH_DIRS["$top_path"]=0
            PATH_SIZE_KB["$top_path"]=0
            continue
        fi

        local files
        local dirs
        local size_kb

        files="$(find "$full_path" -type f 2>/dev/null | wc -l | tr -d ' ')"
        dirs="$(find "$full_path" -type d 2>/dev/null | wc -l | tr -d ' ')"
        size_kb="$(du -sk "$full_path" 2>/dev/null | awk '{print $1}')"

        files="$(safe_number "$files")"
        dirs="$(safe_number "$dirs")"
        size_kb="$(safe_number "$size_kb")"

        if [[ "$dirs" -gt 0 ]]; then
            dirs=$((dirs - 1))
        fi

        PATH_FILES["$top_path"]="$files"
        PATH_DIRS["$top_path"]="$dirs"
        PATH_SIZE_KB["$top_path"]="$size_kb"
    done

    TOTAL_FILES="$(find "$LAB_DIR" -path "$LAB_DIR/.git" -prune -o -type f -print 2>/dev/null | wc -l | tr -d ' ')"
    TOTAL_DIRS="$(find "$LAB_DIR" -path "$LAB_DIR/.git" -prune -o -type d -print 2>/dev/null | wc -l | tr -d ' ')"
    TOTAL_SIZE_KB="$(du -sk --exclude='.git' "$LAB_DIR" 2>/dev/null | awk '{print $1}')"

    TOTAL_FILES="$(safe_number "$TOTAL_FILES")"
    TOTAL_DIRS="$(safe_number "$TOTAL_DIRS")"
    TOTAL_SIZE_KB="$(safe_number "$TOTAL_SIZE_KB")"

    if [[ "$TOTAL_DIRS" -gt 0 ]]; then
        TOTAL_DIRS=$((TOTAL_DIRS - 1))
    fi

    DELTA_FILES=$((TOTAL_FILES - PREV_TOTAL_FILES))
    DELTA_DIRS=$((TOTAL_DIRS - PREV_TOTAL_DIRS))
    DELTA_SIZE_KB=$((TOTAL_SIZE_KB - PREV_TOTAL_SIZE_KB))

    DELTA_FILES_PCT="$(percent_change "$PREV_TOTAL_FILES" "$TOTAL_FILES")"
    DELTA_DIRS_PCT="$(percent_change "$PREV_TOTAL_DIRS" "$TOTAL_DIRS")"
    DELTA_SIZE_PCT="$(percent_change "$PREV_TOTAL_SIZE_KB" "$TOTAL_SIZE_KB")"
}

collect_hygiene_metrics() {
    local syntax_candidates=()
    local file=""

    if [[ -f "$LAB_DIR/go" ]]; then
        syntax_candidates+=("$LAB_DIR/go")
    fi

    while IFS= read -r file; do
        syntax_candidates+=("$file")
    done < <(find "$LAB_DIR/bin" "$LAB_DIR/lib" "$LAB_DIR/utl/doc/generators" -type f ! -name '*.*' 2>/dev/null | sort)

    while IFS= read -r file; do
        syntax_candidates+=("$file")
    done < <(find "$LAB_DIR/val" "$LAB_DIR/utl" -type f -name '*.sh' 2>/dev/null | sort)

    local seen=""
    local unique_candidates=()
    for file in "${syntax_candidates[@]}"; do
        if [[ "$seen" == *"|$file|"* ]]; then
            continue
        fi
        seen+="|$file|"
        unique_candidates+=("$file")
    done

    SYNTAX_CHECKED=${#unique_candidates[@]}
    SYNTAX_FAILED=0
    SYNTAX_FAILED_FILES=()

    for file in "${unique_candidates[@]}"; do
        if ! bash -n "$file" >/dev/null 2>&1; then
            SYNTAX_FAILED=$((SYNTAX_FAILED + 1))
            SYNTAX_FAILED_FILES+=("${file#$LAB_DIR/}")
        fi
    done
    SYNTAX_PASSED=$((SYNTAX_CHECKED - SYNTAX_FAILED))

    local executable_candidates=()
    EXEC_MISSING_FILES=()

    if [[ -f "$LAB_DIR/go" ]]; then
        executable_candidates+=("$LAB_DIR/go")
    fi
    while IFS= read -r file; do
        executable_candidates+=("$file")
    done < <(find "$LAB_DIR/bin" "$LAB_DIR/utl/doc/generators" -type f ! -name '*.*' 2>/dev/null | sort)
    while IFS= read -r file; do
        executable_candidates+=("$file")
    done < <(find "$LAB_DIR/val" -type f -name '*.sh' 2>/dev/null | sort)

    EXEC_EXPECTED=${#executable_candidates[@]}
    EXEC_ANOMALIES=0
    for file in "${executable_candidates[@]}"; do
        if [[ ! -x "$file" ]]; then
            EXEC_ANOMALIES=$((EXEC_ANOMALIES + 1))
            EXEC_MISSING_FILES+=("${file#$LAB_DIR/}")
        fi
    done
}

collect_window_churn() {
    local days="$1"
    local line=""

    for line in "${TOP_LEVEL_PATHS[@]}"; do
        CHURN_ADD["$days:$line"]=0
        CHURN_DEL["$days:$line"]=0
    done

    if ! git -C "$LAB_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        return
    fi

    while IFS=$'\t' read -r adds dels file; do
        if [[ -z "$file" ]]; then
            continue
        fi
        if [[ ! "$adds" =~ ^[0-9]+$ ]] || [[ ! "$dels" =~ ^[0-9]+$ ]]; then
            continue
        fi

        local top="${file%%/*}"
        if ! path_index "$top" >/dev/null 2>&1; then
            continue
        fi

        local key="$days:$top"
        CHURN_ADD["$key"]=$(( CHURN_ADD["$key"] + adds ))
        CHURN_DEL["$key"]=$(( CHURN_DEL["$key"] + dels ))
    done < <(git -C "$LAB_DIR" log --since="$days days ago" --numstat --pretty=tformat:'' 2>/dev/null)
}

collect_hotspots() {
    HOTSPOT_FILES=()
    HOTSPOT_CHURN=()
    HOTSPOT_AUTHORS=()

    if ! git -C "$LAB_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        return
    fi

    local hotspot_rows
    hotspot_rows="$(git -C "$LAB_DIR" log --since='90 days ago' --numstat --pretty=tformat:'' 2>/dev/null | \
        awk -F '\t' 'NF==3 && $1 ~ /^[0-9]+$/ && $2 ~ /^[0-9]+$/ { c[$3]+=($1+$2) } END { for (f in c) printf "%d\t%s\n", c[f], f }' | \
        sort -t $'\t' -k1,1nr -k2,2 | sed -n '1,10p')"

    local row=""
    while IFS=$'\t' read -r churn file; do
        if [[ -z "${file:-}" ]]; then
            continue
        fi
        HOTSPOT_FILES+=("$file")
        HOTSPOT_CHURN+=("$(safe_number "$churn")")

        local authors
        authors="$(git -C "$LAB_DIR" log --since='90 days ago' --format='%an' -- "$file" 2>/dev/null | sort -u | wc -l | tr -d ' ')"
        HOTSPOT_AUTHORS+=("$(safe_number "$authors")")
    done <<< "$hotspot_rows"
}

collect_trend_summary() {
    TREND_POINTS=0
    TREND_OLDEST_TIMESTAMP="none"
    TREND_LATEST_TIMESTAMP="none"
    TREND_FILES_DELTA_10=0
    TREND_SIZE_DELTA_10=0

    if [[ ! -d "$STATS_HISTORY_DIR" ]]; then
        return
    fi

    local -a history_files=()
    local hist=""
    while IFS= read -r hist; do
        history_files+=("$hist")
    done < <(find "$STATS_HISTORY_DIR" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort)

    local total=${#history_files[@]}
    if [[ "$total" -eq 0 ]]; then
        return
    fi

    local start=0
    if [[ "$total" -gt "$TREND_HISTORY_LIMIT" ]]; then
        start=$((total - TREND_HISTORY_LIMIT))
    fi

    local -a selected=("${history_files[@]:$start}")
    TREND_POINTS=${#selected[@]}

    local first_file="${selected[0]}"
    local last_file="${selected[$((TREND_POINTS - 1))]}"

    TREND_OLDEST_TIMESTAMP="$(json_str_from_file "$first_file" "generated_at")"
    TREND_LATEST_TIMESTAMP="$(json_str_from_file "$last_file" "generated_at")"
    [[ -z "$TREND_OLDEST_TIMESTAMP" ]] && TREND_OLDEST_TIMESTAMP="none"
    [[ -z "$TREND_LATEST_TIMESTAMP" ]] && TREND_LATEST_TIMESTAMP="none"

    local first_files
    local last_files
    local first_size
    local last_size

    first_files="$(safe_number "$(json_num_from_file "$first_file" "total_files")")"
    last_files="$(safe_number "$(json_num_from_file "$last_file" "total_files")")"
    first_size="$(safe_number "$(json_num_from_file "$first_file" "total_size_kb")")"
    last_size="$(safe_number "$(json_num_from_file "$last_file" "total_size_kb")")"

    TREND_FILES_DELTA_10=$((last_files - first_files))
    TREND_SIZE_DELTA_10=$((last_size - first_size))
}

