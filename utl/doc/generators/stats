  --flaky-budget-profile=PROFILE
                  Apply default per-suite flaky budgets by profile
                  Profiles: none, strict, balanced, relaxed
  --flaky-suite-budget=SUITE:OSC:VAR
                   Per-suite flaky budget allowances (repeatable)
                   OSC and VAR are non-negative integers
  -h, --help   Show help
EOF
}

main() {
    local action="update"
    local format="markdown"

    load_flaky_budget_profile_from_env || return 1
    load_flaky_suite_budgets_from_env || return 1

    for arg in "$@"; do
        case "$arg" in
            --update) action="update" ;;
            --stdout) action="stdout" ;;
            --markdown) action="stdout"; format="markdown" ;;
            --json) action="stdout"; format="json" ;;
            --text) action="stdout"; format="text" ;;
            --raw) action="stdout"; format="raw" ;;
            --ci-gate) CI_GATE_ENABLED="true" ;;
            --ci-gate-flaky) CI_GATE_ENABLED="true"; CI_GATE_FLAKY_ENABLED="true" ;;
            --sample-tests) TEST_HEALTH_SAMPLE_ENABLED="true" ;;
            --sample-runs=*)
                TEST_HEALTH_SAMPLE_RUNS="$(parse_positive_int "${arg#*=}")"
                if [[ "$TEST_HEALTH_SAMPLE_RUNS" -eq 0 ]]; then
                    echo "Invalid sample run count: ${arg#*=}" >&2
                    return 1
                fi
                ;;
            --flaky-budget-profile=*)
                if ! apply_flaky_budget_profile "${arg#*=}"; then
                    echo "Invalid flaky budget profile: ${arg#*=}" >&2
                    return 1
                fi
                ;;
            --flaky-suite-budget=*)
                if ! parse_flaky_suite_budget_entry "${arg#*=}"; then
                    echo "Invalid flaky suite budget: ${arg#*=}" >&2
                    return 1
                fi
                ;;
            -h|--help) show_help; return 0 ;;
            *) echo "Unknown option: $arg" >&2; return 1 ;;
        esac
    done

    collect_metrics

    if [[ "$action" == "update" ]]; then
        update_output_files
        enforce_ci_gate
        return $?
    fi

    case "$format" in
        markdown) render_markdown ;;
        json) render_json ;;
        text) render_text ;;
        raw) render_raw ;;
        *) echo "Unsupported format: $format" >&2; return 1 ;;
    esac

    enforce_ci_gate
    return $?
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
