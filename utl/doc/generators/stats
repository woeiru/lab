enforce_ci_gate() {
    if [[ "$CI_GATE_ENABLED" != "true" ]]; then
        return 0
    fi

    local -a failures=()
    if [[ "$GATE_SYNTAX" == "fail" ]]; then
        failures+=("syntax checks failing")
    fi
    if [[ "$GATE_RISK_SIGNALS" == "fail" ]]; then
        failures+=("new secret-pattern findings detected")
    fi
    if [[ "$CI_GATE_FLAKY_ENABLED" == "true" && "$GATE_TEST_HEALTH" == "fail" ]]; then
        failures+=("flaky-test severity exceeded policy")
    fi

    if [[ "${#failures[@]}" -eq 0 ]]; then
        return 0
    fi

    echo "CI gate failed: ${failures[*]}" >&2
    return 2
}

