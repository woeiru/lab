evaluate_quality_gates() {
    GATE_SYNTAX="ok"
    GATE_EXECUTABLES="ok"
    GATE_GROWTH="ok"
    GATE_COMPLEXITY="ok"
    GATE_RISK_SIGNALS="ok"
    GATE_TEST_HEALTH="ok"

    if [[ "$SYNTAX_FAILED" -gt 0 ]]; then
        GATE_SYNTAX="fail"
    fi
    if [[ "$EXEC_ANOMALIES" -gt 0 ]]; then
        GATE_EXECUTABLES="warn"
    fi
    if [[ "$DELTA_FILES_PCT" != "n/a" ]] && awk -v p="$DELTA_FILES_PCT" 'BEGIN { exit !(p > 8.0 || p < -8.0) }'; then
        GATE_GROWTH="warn"
    fi
    if [[ "$FUNC_GT_150" -gt 3 ]]; then
        GATE_COMPLEXITY="fail"
    elif [[ "$FUNC_GT_150" -gt 0 ]]; then
        GATE_COMPLEXITY="warn"
    fi
    if [[ "$RISK_DELTA_SECRET_PATTERNS" -gt 0 ]]; then
        GATE_RISK_SIGNALS="fail"
    elif [[ "$RISK_DELTA_EVAL" -gt 0 || "$RISK_DELTA_BACKTICKS" -gt 0 || "$RISK_DELTA_CHMOD_777" -gt 0 ]]; then
        GATE_RISK_SIGNALS="warn"
    fi
    if [[ "$FLAKY_STATUS_OSCILLATION_OVER_BUDGET" -ge "$FLAKY_FAIL_OSCILLATION_COUNT" || "$FLAKY_TOTAL_OVER_BUDGET" -ge "$FLAKY_FAIL_TOTAL_CANDIDATES" ]]; then
        GATE_TEST_HEALTH="fail"
    elif [[ "$FLAKY_DURATION_VARIANCE_OVER_BUDGET" -ge "$FLAKY_WARN_VARIANCE_COUNT" ]]; then
        GATE_TEST_HEALTH="warn"
    fi

    if [[ "$GATE_SYNTAX" == "fail" || "$GATE_COMPLEXITY" == "fail" || "$GATE_RISK_SIGNALS" == "fail" || "$GATE_TEST_HEALTH" == "fail" ]]; then
        GATE_OVERALL="fail"
    elif [[ "$GATE_EXECUTABLES" == "warn" || "$GATE_GROWTH" == "warn" || "$GATE_COMPLEXITY" == "warn" || "$GATE_RISK_SIGNALS" == "warn" || "$GATE_TEST_HEALTH" == "warn" ]]; then
        GATE_OVERALL="warn"
    else
        GATE_OVERALL="ok"
    fi
}

