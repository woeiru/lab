    done
    if [[ "${#HOTSPOT_FILES[@]}" -eq 0 ]]; then
        echo "| `none` | 0 | 0 |"
    fi

    echo
    echo "## Complexity and Risk Signals"
    echo
    echo "| Complexity Metric | Value |"
    echo "| --- | ---: |"
    printf '| Functions detected | %s |\n' "$FUNCTION_COUNT"
    printf '| Function length p50 (lines) | %s |\n' "$FUNC_P50_LINES"
    printf '| Function length p90 (lines) | %s |\n' "$FUNC_P90_LINES"
    printf '| Function length max (lines) | %s |\n' "$FUNC_MAX_LINES"
    printf '| Functions >80 lines | %s |\n' "$FUNC_GT_80"
    printf '| Functions >120 lines | %s |\n' "$FUNC_GT_120"
    printf '| Functions >150 lines | %s |\n' "$FUNC_GT_150"

    echo
    echo "| Longest Function | File | Lines |"
    echo "| --- | --- | ---: |"
    local i=0
    for i in "${!LONGEST_FUNCTION_NAMES[@]}"; do
        printf '| `%s` | `%s` | %s |\n' "${LONGEST_FUNCTION_NAMES[$i]}" "${LONGEST_FUNCTION_FILES[$i]}" "${LONGEST_FUNCTION_LINES[$i]}"
    done
    if [[ "${#LONGEST_FUNCTION_NAMES[@]}" -eq 0 ]]; then
        echo "| `none` | `none` | 0 |"
    fi

    echo
    echo "| Risk Signal | Current | Delta vs Previous |"
    echo "| --- | ---: | ---: |"
    printf '| `eval` usage | %s | %+d |\n' "$RISK_COUNT_EVAL" "$RISK_DELTA_EVAL"
    printf '| Backtick substitutions | %s | %+d |\n' "$RISK_COUNT_BACKTICKS" "$RISK_DELTA_BACKTICKS"
    printf '| `chmod 777` patterns | %s | %+d |\n' "$RISK_COUNT_CHMOD_777" "$RISK_DELTA_CHMOD_777"
    printf '| Secret-pattern hits | %s | %+d |\n' "$RISK_COUNT_SECRET_PATTERNS" "$RISK_DELTA_SECRET_PATTERNS"
    printf '| New findings (aggregate) | %s | - |\n' "$RISK_NEW_FINDINGS"
    printf '| Resolved findings (aggregate) | %s | - |\n' "$RISK_RESOLVED_FINDINGS"

    echo
    echo "## Top Risks"
    echo
    if [[ "$SYNTAX_FAILED" -gt 0 ]]; then
        printf -- '- Syntax regressions detected: %s files fail `bash -n`.\n' "$SYNTAX_FAILED"
    else
        echo "- No syntax regressions detected in targeted scripts."
    fi
    if [[ "$EXEC_ANOMALIES" -gt 0 ]]; then
        printf -- '- Executable-bit anomalies: %s scripts expected executable are not marked executable.\n' "$EXEC_ANOMALIES"
    else
        echo "- No executable-bit anomalies detected for expected scripts."
    fi
    if [[ "$GATE_GROWTH" == "warn" ]]; then
        printf -- '- Repository growth drift warning: file count changed by %s%% since previous snapshot.\n' "$DELTA_FILES_PCT"
    else
        echo "- Repository growth is within configured drift budget."
    fi
    if [[ "$FUNC_GT_150" -gt 0 ]]; then
        printf -- '- Long-function outliers detected: %s functions exceed 150 lines.\n' "$FUNC_GT_150"
    else
        echo "- No long-function outliers above 150 lines."
    fi
    if [[ "$RISK_DELTA_SECRET_PATTERNS" -gt 0 ]]; then
        printf -- '- New secret-pattern findings detected: %+d (immediate triage recommended).\n' "$RISK_DELTA_SECRET_PATTERNS"
    elif [[ "$GATE_RISK_SIGNALS" == "warn" ]]; then
        printf -- '- Risk-pattern drift warning: eval/backticks/chmod deltas are %+d/%+d/%+d.\n' "$RISK_DELTA_EVAL" "$RISK_DELTA_BACKTICKS" "$RISK_DELTA_CHMOD_777"
    else
        echo "- Risk-pattern deltas are stable or improving against previous snapshot."
    fi

    echo
    echo "## Quality Gates Status"
    echo
    echo "| Gate | Status | Signal |"
    echo "| --- | --- | --- |"
    printf '| Syntax checks (`bash -n`) | `%s` | checked=%s, passed=%s, failed=%s |\n' "$GATE_SYNTAX" "$SYNTAX_CHECKED" "$SYNTAX_PASSED" "$SYNTAX_FAILED"
    printf '| Executable bit hygiene | `%s` | checked=%s, anomalies=%s |\n' "$GATE_EXECUTABLES" "$EXEC_EXPECTED" "$EXEC_ANOMALIES"
    printf '| Growth drift budget | `%s` | file delta=%+d (%s%%) |\n' "$GATE_GROWTH" "$DELTA_FILES" "$DELTA_FILES_PCT"
    printf '| Complexity outlier budget | `%s` | gt_150=%s, p90=%s lines |\n' "$GATE_COMPLEXITY" "$FUNC_GT_150" "$FUNC_P90_LINES"
    printf '| Risk signal drift | `%s` | eval=%+d, backticks=%+d, chmod777=%+d, secret=%+d |\n' "$GATE_RISK_SIGNALS" "$RISK_DELTA_EVAL" "$RISK_DELTA_BACKTICKS" "$RISK_DELTA_CHMOD_777" "$RISK_DELTA_SECRET_PATTERNS"
    printf '| Overall | `%s` | synthesized from gate statuses |\n' "$GATE_OVERALL"
}

render_json() {
    local history_snapshot_path="doc/ref/stats-history/${TIMESTAMP_FILE}.json"

    echo "{"
    printf '  "metric_version": "%s",\n' "$METRIC_VERSION"
    printf '  "generated_at": "%s",\n' "$TIMESTAMP_UTC"
    echo "  \"git\": {"
    printf '    "branch": "%s",\n' "$(json_escape "$GIT_BRANCH")"
    printf '    "commit": "%s",\n' "$(json_escape "$GIT_COMMIT")"
    printf '    "dirty": %s\n' "$GIT_DIRTY"
    echo "  },"
    echo "  \"repo_shape\": {"
    printf '    "total_files": %s,\n' "$TOTAL_FILES"
    printf '    "total_dirs": %s,\n' "$TOTAL_DIRS"
    printf '    "total_size_kb": %s,\n' "$TOTAL_SIZE_KB"
    echo "    \"delta\": {"
    printf '      "files": %s,\n' "$DELTA_FILES"
    printf '      "dirs": %s,\n' "$DELTA_DIRS"
    printf '      "size_kb": %s,\n' "$DELTA_SIZE_KB"
    printf '      "files_percent": "%s",\n' "$DELTA_FILES_PCT"
    printf '      "dirs_percent": "%s",\n' "$DELTA_DIRS_PCT"
    printf '      "size_percent": "%s"\n' "$DELTA_SIZE_PCT"
    echo "    }"
    echo "  },"
    echo "  \"velocity\": {"
    printf '    "commits_7d": %s,\n' "$COMMITS_7D"
    printf '    "commits_30d": %s,\n' "$COMMITS_30D"
    printf '    "commits_90d": %s\n' "$COMMITS_90D"
    echo "  },"
    echo "  \"churn\": {"
    echo "    \"by_path\": ["
    local idx=0
    local top_path=""
    for top_path in "${TOP_LEVEL_PATHS[@]}"; do
        idx=$((idx + 1))
        echo "      {"
        printf '        "path": "%s",\n' "$top_path"
        printf '        "adds_7d": %s,\n' "${CHURN_ADD[7:$top_path]:-0}"
