#!/bin/bash
#######################################################################
# Lab Environment Variable Usage Documentation Generator
#######################################################################

set -e

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -z "${LAB_DIR:-}" ]]; then
    readonly LAB_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
fi

source "$LAB_DIR/lib/gen/aux"
source "$LAB_DIR/lib/gen/ana"

TARGETS_FILE="$(dirname "$SCRIPT_DIR")/config/targets"
if [[ -f "$TARGETS_FILE" ]]; then
    source "$TARGETS_FILE"
fi

if [[ -n "${GENERATOR_OUTPUT_FILES[var]:-}" ]]; then
    DOC_FILE="$LAB_DIR/${GENERATOR_OUTPUT_FILES[var]}"
else
    DOC_FILE="$LAB_DIR/doc/dev/generated-doc-injections.md"
fi

SECTION_NAME="${GENERATOR_SECTIONS[var]:-Variable Usage Table}"

CONFIG_SOURCE="${CONFIG_ana:-${SITE_CONFIG_FILE:-$LAB_DIR/cfg/env/site1}}"
VAR_TARGETS=("$LAB_DIR/cfg/env" "$LAB_DIR/lib/ops" "$LAB_DIR/src/set")

generate_variables_section() {
    echo "*Auto-updated variable usage analysis*"
    echo ""
    echo "> **Last Updated**: $(date '+%Y-%m-%d %H:%M:%S')"
    echo "> **Generated By**: \`utl/doc/generators/var\`"
    echo "> **Config Source**: \`$CONFIG_SOURCE\`"
    echo ""
    echo "
\`\`\`text"
    ana_acu -a "$CONFIG_SOURCE" "${VAR_TARGETS[@]}" || true
    echo "\`\`\`"
}

update_documentation() {
    local temp_file
    temp_file=$(mktemp)
    local in_auto_section=false

    echo "Updating variable usage section '$SECTION_NAME' in $DOC_FILE..."

    while IFS= read -r line; do
        if [[ "$line" == *"<!-- AUTO-GENERATED SECTION: $SECTION_NAME -->"* ]]; then
            echo "$line" >> "$temp_file"
            echo "" >> "$temp_file"
            generate_variables_section >> "$temp_file"
            echo "" >> "$temp_file"
            in_auto_section=true
            continue
        fi
        if [[ "$line" == *"<!-- END AUTO-GENERATED SECTION -->"* && "$in_auto_section" == true ]]; then
            echo "$line" >> "$temp_file"
            in_auto_section=false
            continue
        fi
        if [[ "$in_auto_section" == false ]]; then
            echo "$line" >> "$temp_file"
        fi
    done < "$DOC_FILE"

    mv "$temp_file" "$DOC_FILE"
    echo "Variable usage section updated successfully."
}

main() {
    for p in "${VAR_TARGETS[@]}"; do
        if [[ ! -d "$p" ]]; then
            echo "Warning: variable analysis target missing: $p"
        fi
    done

    if [[ ! -f "$DOC_FILE" ]]; then
        echo "Error: Documentation file $DOC_FILE not found"
        exit 1
    fi

    update_documentation
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
