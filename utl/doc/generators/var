#!/bin/bash
#######################################################################
# Lab Environment Variable Usage Documentation Generator
#######################################################################
# File: var
# Description: Automatic variable usage documentation generator using ana_acu -j
#######################################################################

set +e

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -z "${LAB_DIR:-}" ]]; then
    readonly LAB_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
fi

source "$LAB_DIR/lib/gen/aux" >/dev/null 2>&1
source "$LAB_DIR/lib/gen/ana" >/dev/null 2>&1

TARGETS_FILE="$(dirname "$SCRIPT_DIR")/config/targets"
if [[ -f "$TARGETS_FILE" ]]; then
    source "$TARGETS_FILE"
fi

DOC_FILE="$LAB_DIR/${GENERATOR_OUTPUT_FILES[var]:-doc/ref/variables.md}"
TMP_DIR="$LAB_DIR/.tmp/doc"
mkdir -p "$TMP_DIR"

# Targets as defined in ffl-acu_cycle
CONFIG_DIRS=("cfg/core" "cfg/env")
TARGET_DIRECTORIES=("lib" "src" "utl")

generate_var_table() {
    cat << HEADER_EOF
*Auto-updated variable metadata table with real-time analysis*

> **Last Updated**: $(date '+%Y-%m-%d %H:%M:%S')  
> **Generated By**: utl/doc/generators/var  

This table provides a comprehensive overview of variable usages.

### **📖 Variable Usage Table**

| Variable | Value | Total Occurrences | Usage Breakdown | Config Source |
|----------|-------|-------------------|-----------------|---------------|
HEADER_EOF

    for config_dir in "${CONFIG_DIRS[@]}"; do
        local config_full="$LAB_DIR/$config_dir"
        
        while IFS= read -r -d '' conf_file; do
            local target_paths=()
            for t in "${TARGET_DIRECTORIES[@]}"; do target_paths+=("$LAB_DIR/$t"); done
            
            ana_acu -j "$conf_file" "${target_paths[@]}" >/dev/null 2>&1 || true
            
            local rel_conf="${conf_file#$LAB_DIR/}"
            local json_filename="${rel_conf//\//_}.json"
            local json_file="$TMP_DIR/$json_filename"
            
            if [[ -f "$json_file" ]]; then
                # parse via jq
                jq -r --arg conf "$rel_conf" '
                    .variables[]? | 
                    select(.total_occurrences > 0) |
                    [
                        "`\(.name)`", 
                        "`\(.value | gsub("`";"\\`") | gsub("\\|"; "\\|"))`",
                        (.total_occurrences | tostring),
                        ([.usage_by_folder[]? | select(.total_occurrences > 0) | "\(.path): \(.total_occurrences)"] | join(", ")),
                        $conf
                    ] | 
                    "| " + join(" | ") + " |"
                ' "$json_file" 2>/dev/null
            fi
        done < <(find "$config_full" -type f ! -path '*/.*' ! -name '*.*' -print0)
    done
}

update_documentation() {
    local temp_file=$(mktemp)
    local in_auto_section=false

    echo "Updating variable metadata table in $DOC_FILE..."

    while IFS= read -r line; do
        if [[ "$line" == *"<!-- AUTO-GENERATED SECTION: "* ]]; then
            echo "$line" >> "$temp_file"
            generate_var_table >> "$temp_file"
            in_auto_section=true
            continue
        fi
        if [[ "$line" == *"<!-- END AUTO-GENERATED SECTION "* ]]; then
            echo "$line" >> "$temp_file"
            in_auto_section=false
            continue
        fi
        if [[ "$in_auto_section" == false ]]; then
            echo "$line" >> "$temp_file"
        fi
    done < "$DOC_FILE"

    mv "$temp_file" "$DOC_FILE"
    echo "Variable metadata table updated successfully."
}

echo "Generating variable metadata table..."
update_documentation
echo "Variable metadata table generation complete."
