#!/bin/bash
#######################################################################
# Lab Environment Error Handling Generator
#######################################################################
# File: err
# Description: Automatic error-handling generator using ana_err -j
#######################################################################

set +e

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -z "${LAB_DIR:-}" ]]; then
    readonly LAB_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
fi

source "$LAB_DIR/lib/gen/aux" >/dev/null 2>&1
source "$LAB_DIR/lib/gen/ana" >/dev/null 2>&1

TARGETS_FILE="$(dirname "$SCRIPT_DIR")/config/targets"
if [[ -f "$TARGETS_FILE" ]]; then
    source "$TARGETS_FILE"
fi

DOC_FILE="$LAB_DIR/${GENERATOR_OUTPUT_FILES[err]:-doc/ref/error-handling.md}"
TMP_BASE_DIR="$LAB_DIR/.tmp/doc"
TMP_DIR="$TMP_BASE_DIR/err"
mkdir -p "$TMP_DIR"

# Target scopes according to ffl-err_cycle
TARGET_DIRECTORIES=("bin" "lib/core" "lib/gen" "lib/ops" "src" "utl")

_err_collect_rows() {
    local target_file="$1"
    local raw_rows_file="$2"

    ana_err -j --json-dir "$TMP_DIR" "$target_file" >/dev/null 2>&1 || true

    local rel_file="${target_file#$LAB_DIR/}"
    rel_file="${rel_file#/}"
    local json_file="$TMP_DIR/${rel_file//\//_}.err.json"

    if [[ -f "$json_file" ]]; then
        jq -r --arg target "$rel_file" '
            if ((.errors // []) | length) == 0 then
                [$target, "-", "-", "-", "No findings"] | @tsv
            else
                (.errors[] | [$target, .function, .type, (.location|tostring), (.message // "-")] | @tsv)
            end
        ' "$json_file" 2>/dev/null >> "$raw_rows_file"
    fi
}

generate_err_table() {
    cat << HEADER_EOF
*Auto-updated error handling table with real-time analysis*

> **Last Updated**: $(date '+%Y-%m-%d %H:%M:%S')  
> **Generated By**: utl/doc/generators/err  

This table tracks analyzer-detected return/exit paths and aux error logging calls.

### Error Handling Table

| Target Module | Function | Type | Line | Message/Code |
|---------------|----------|------|------|--------------|
HEADER_EOF

    local raw_rows
    raw_rows=$(mktemp)

    local go_file="$LAB_DIR/go"
    if [[ -f "$go_file" ]]; then
        _err_collect_rows "$go_file" "$raw_rows"
    fi

    for target_dir in "${TARGET_DIRECTORIES[@]}"; do
        local full_path="$LAB_DIR/$target_dir"
        if [[ ! -d "$full_path" ]]; then
            continue
        fi

        while IFS= read -r -d '' file; do
            _err_collect_rows "$file" "$raw_rows"
        done < <(find "$full_path" -type f -print0 | LC_ALL=C sort -z)
    done

    if [[ -s "$raw_rows" ]]; then
        LC_ALL=C sort -t $'\t' -k1,1 -k2,2 -k3,3 -k4,4n "$raw_rows" | while IFS=$'\t' read -r target func_name err_type line message; do
            local target_cell="\`$target\`"
            local func_cell="-"
            local msg_cell="-"
            local safe_type="$err_type"

            if [[ "$func_name" != "-" ]]; then
                func_cell="\`$func_name\`"
            fi
            if [[ "$message" != "-" ]]; then
                msg_cell="\`$message\`"
            fi

            safe_type="${safe_type//|/\\|}"
            echo "| $target_cell | $func_cell | $safe_type | $line | $msg_cell |"
        done
    fi

    rm -f "$raw_rows"
}

update_documentation() {
    if [[ ! -f "$DOC_FILE" ]]; then
        mkdir -p "$(dirname "$DOC_FILE")"
        cat << 'EOF' > "$DOC_FILE"
# Error Handling

This page tracks analyzer-derived error and exit handling patterns across project modules.

<!-- AUTO-GENERATED SECTION: Error Handling Table -->
<!-- END AUTO-GENERATED SECTION -->

## How to Use This Table

This page is generated from `ana_err` (error handling analysis) and highlights return paths, explicit exits, and structured `aux_*` log emissions.

### Terminal Analyzer (ERR)

```bash
# direct analyzer usage
ana_err lib/gen/ana
ana_err -j --json-dir .tmp/doc/err lib/gen/ana

# cycle profile from aliases (cfg/ali/sta)
ffl-err_cycle
```

### Second-Layer API Flow

- Layer 1 (core analyzer): `lib/gen/ana` -> `ana_err`
- Layer 2 (terminal API): wrappers in `cfg/ali/sta` (for example `_ffl_err_core`, `_ffl_err_ops`, `_ffl_err_cycle`)
- Traversal helper: `lib/gen/aux` -> `aux_ffl` (used to apply ERR over folder scopes)
- Documentation layer: `utl/doc/generators/err` runs `ana_err -j --json-dir .tmp/doc/err` and renders this table

### JSON Fork for Docs

For documentation, `ana_err` writes intermediate JSON into `.tmp/doc/err/`. The generator reads those files to build Markdown while terminal output remains independent. This keeps CLI behavior stable and doc generation reproducible.

See `utl/doc/README.md` for orchestration and generator namespace details: [`../../utl/doc/README.md`](../../utl/doc/README.md)
EOF
    fi

    local temp_file
    temp_file=$(mktemp)
    local in_auto_section=false

    echo "Updating error handling table in $DOC_FILE..."

    while IFS= read -r line; do
        if [[ "$line" == *"<!-- AUTO-GENERATED SECTION: "* ]]; then
            echo "$line" >> "$temp_file"
            generate_err_table >> "$temp_file"
            in_auto_section=true
            continue
        fi
        if [[ "$line" == *"<!-- END AUTO-GENERATED SECTION "* ]]; then
            echo "$line" >> "$temp_file"
            in_auto_section=false
            continue
        fi
        if [[ "$in_auto_section" == false ]]; then
            echo "$line" >> "$temp_file"
        fi
    done < "$DOC_FILE"

    mv "$temp_file" "$DOC_FILE"
    echo "Error handling table updated successfully."
}

echo "Generating error handling table..."
update_documentation
echo "Error handling table generation complete."
