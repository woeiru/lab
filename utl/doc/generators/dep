#!/bin/bash
#######################################################################
# Lab Environment Module Dependency Generator
#######################################################################
# File: dep
# Description: Automatic module dependency generator using ana_dep -j
#######################################################################

set +e

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -z "${LAB_DIR:-}" ]]; then
    readonly LAB_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
fi

source "$LAB_DIR/lib/gen/aux" >/dev/null 2>&1
source "$LAB_DIR/lib/gen/ana" >/dev/null 2>&1

TARGETS_FILE="$(dirname "$SCRIPT_DIR")/config/targets"
if [[ -f "$TARGETS_FILE" ]]; then
    source "$TARGETS_FILE"
fi

DOC_FILE="$LAB_DIR/${GENERATOR_OUTPUT_FILES[dep]:-doc/ref/module-dependencies.md}"
TMP_BASE_DIR="$LAB_DIR/.tmp/doc"
TMP_DIR="$TMP_BASE_DIR/dep"
mkdir -p "$TMP_DIR"

# Target scopes according to ffl-dep_cycle
TARGET_DIRECTORIES=("bin" "lib/core" "lib/gen" "lib/ops" "src" "utl")

generate_dep_table() {
    cat << HEADER_EOF
*Auto-updated module dependency table with real-time analysis*

> **Last Updated**: $(date '+%Y-%m-%d %H:%M:%S')  
> **Generated By**: utl/doc/generators/dep  

This table provides direct per-module dependencies (sourced scripts and required host commands).

### **📖 Module Dependency Table**

| Module File | Script Imports | Host Commands |
|-------------|----------------|---------------|
HEADER_EOF

    local go_file="$LAB_DIR/go"
    if [[ -f "$go_file" ]]; then
        ana_dep -j --json-dir "$TMP_DIR" "$go_file" >/dev/null 2>&1 || true
        local go_json="${go_file#$LAB_DIR/}"
        go_json="${go_json#/}"
        go_json="${go_json//\//_}.json"
        if [[ -f "$TMP_DIR/$go_json" ]]; then
            jq -r --arg root "$LAB_DIR/" '
                .target_file as $target |
                [
                    ($target | sub("^" + $root; "")),
                    ((.dependencies.scripts // []) | if length == 0 then "-" else (map("`" + . + "`") | join(", ")) end),
                    ((.dependencies.commands // []) | if length == 0 then "-" else (map("`" + . + "`") | join(", ")) end)
                ] |
                "| " + join(" | ") + " |"
            ' "$TMP_DIR/$go_json" 2>/dev/null
        fi
    fi

    for target_dir in "${TARGET_DIRECTORIES[@]}"; do
        local full_path="$LAB_DIR/$target_dir"
        if [[ ! -d "$full_path" ]]; then
            continue
        fi

        while IFS= read -r -d '' file; do
            ana_dep -j --json-dir "$TMP_DIR" "$file" >/dev/null 2>&1 || true

            local rel_file="${file#$LAB_DIR/}"
            rel_file="${rel_file#/}"
            local json_filename="${rel_file//\//_}.json"
            local json_file="$TMP_DIR/$json_filename"

            if [[ -f "$json_file" ]]; then
                jq -r --arg root "$LAB_DIR/" '
                    .target_file as $target |
                    [
                        ($target | sub("^" + $root; "")),
                        ((.dependencies.scripts // []) | if length == 0 then "-" else (map("`" + . + "`") | join(", ")) end),
                        ((.dependencies.commands // []) | if length == 0 then "-" else (map("`" + . + "`") | join(", ")) end)
                    ] |
                    "| " + join(" | ") + " |"
                ' "$json_file" 2>/dev/null
            fi
        done < <(find "$full_path" -type f ! -name "*.md" -print0)
    done
}

update_documentation() {
    if [[ ! -f "$DOC_FILE" ]]; then
        mkdir -p "$(dirname "$DOC_FILE")"
        cat << 'EOF' > "$DOC_FILE"
# Module Dependencies

<!-- AUTO-GENERATED SECTION: Module Dependency Table -->
<!-- END AUTO-GENERATED SECTION -->
EOF
    fi

    local temp_file
    temp_file=$(mktemp)
    local in_auto_section=false

    echo "Updating module dependency table in $DOC_FILE..."

    while IFS= read -r line; do
        if [[ "$line" == *"<!-- AUTO-GENERATED SECTION: "* ]]; then
            echo "$line" >> "$temp_file"
            generate_dep_table >> "$temp_file"
            in_auto_section=true
            continue
        fi
        if [[ "$line" == *"<!-- END AUTO-GENERATED SECTION "* ]]; then
            echo "$line" >> "$temp_file"
            in_auto_section=false
            continue
        fi
        if [[ "$in_auto_section" == false ]]; then
            echo "$line" >> "$temp_file"
        fi
    done < "$DOC_FILE"

    mv "$temp_file" "$DOC_FILE"
    echo "Module dependency table updated successfully."
}

echo "Generating module dependency table..."
update_documentation
echo "Module dependency table generation complete."
