#!/bin/bash
#######################################################################
# Lab Environment Test Coverage Generator
#######################################################################
# File: tst
# Description: Automatic test traceability generator using ana_tst -j
#######################################################################

set +e

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -z "${LAB_DIR:-}" ]]; then
    readonly LAB_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
fi

source "$LAB_DIR/lib/gen/aux" >/dev/null 2>&1
source "$LAB_DIR/lib/gen/ana" >/dev/null 2>&1

TARGETS_FILE="$(dirname "$SCRIPT_DIR")/config/targets"
if [[ -f "$TARGETS_FILE" ]]; then
    source "$TARGETS_FILE"
fi

DOC_FILE="$LAB_DIR/${GENERATOR_OUTPUT_FILES[tst]:-doc/ref/test-coverage.md}"
TMP_BASE_DIR="$LAB_DIR/.tmp/doc"
TMP_DIR="$TMP_BASE_DIR/tst"
mkdir -p "$TMP_DIR"

# Target scopes according to ffl-tst_cycle
TARGET_DIRECTORIES=("bin" "lib/core" "lib/gen" "lib/ops" "src" "utl")

generate_tst_table() {
    cat << HEADER_EOF
*Auto-updated test traceability table with real-time analysis*

> **Last Updated**: $(date '+%Y-%m-%d %H:%M:%S')  
> **Generated By**: utl/doc/generators/tst  

This table maps source modules to matching validation tests and reported counters.

### **📖 Test Coverage Table**

| Target Module | Test File | Count | Type | Status |
|---------------|-----------|-------|------|--------|
HEADER_EOF

    local raw_rows
    raw_rows=$(mktemp)

    local go_file="$LAB_DIR/go"
    if [[ -f "$go_file" ]]; then
        ana_tst -j --json-dir "$TMP_DIR" "$go_file" >/dev/null 2>&1 || true
        local go_rel="${go_file#$LAB_DIR/}"
        go_rel="${go_rel#/}"
        local go_json="$TMP_DIR/${go_rel//\//_}.json"
        if [[ -f "$go_json" ]]; then
            jq -r '
                .target as $target |
                if ((.test_suites // []) | length) == 0 then
                    [$target, "-", "0", "-", "No tests"] | @tsv
                else
                    (.test_suites[] | [$target, .file, (.count|tostring), .type, .status] | @tsv)
                end
            ' "$go_json" 2>/dev/null >> "$raw_rows"
        fi
    fi

    for target_dir in "${TARGET_DIRECTORIES[@]}"; do
        local full_path="$LAB_DIR/$target_dir"
        if [[ ! -d "$full_path" ]]; then
            continue
        fi

        while IFS= read -r -d '' file; do
            ana_tst -j --json-dir "$TMP_DIR" "$file" >/dev/null 2>&1 || true

            local rel_file="${file#$LAB_DIR/}"
            rel_file="${rel_file#/}"
            local json_file="$TMP_DIR/${rel_file//\//_}.json"

            if [[ -f "$json_file" ]]; then
                jq -r '
                    .target as $target |
                    if ((.test_suites // []) | length) == 0 then
                        [$target, "-", "0", "-", "No tests"] | @tsv
                    else
                        (.test_suites[] | [$target, .file, (.count|tostring), .type, .status] | @tsv)
                    end
                ' "$json_file" 2>/dev/null >> "$raw_rows"
            fi
        done < <(find "$full_path" -type f -print0 | LC_ALL=C sort -z)
    done

    if [[ -s "$raw_rows" ]]; then
        LC_ALL=C sort -t $'\t' -k1,1 -k2,2 "$raw_rows" | while IFS=$'\t' read -r target test_file count test_type status; do
            local target_cell="\`$target\`"
            local test_cell="-"
            if [[ "$test_file" != "-" ]]; then
                test_cell="\`$test_file\`"
            fi
            echo "| $target_cell | $test_cell | $count | $test_type | $status |"
        done
    fi

    rm -f "$raw_rows"
}

update_documentation() {
    if [[ ! -f "$DOC_FILE" ]]; then
        mkdir -p "$(dirname "$DOC_FILE")"
        cat << 'EOF' > "$DOC_FILE"
# Test Coverage

<!-- AUTO-GENERATED SECTION: Test Coverage Table -->
<!-- END AUTO-GENERATED SECTION -->
EOF
    fi

    local temp_file
    temp_file=$(mktemp)
    local in_auto_section=false

    echo "Updating test coverage table in $DOC_FILE..."

    while IFS= read -r line; do
        if [[ "$line" == *"<!-- AUTO-GENERATED SECTION: "* ]]; then
            echo "$line" >> "$temp_file"
            generate_tst_table >> "$temp_file"
            in_auto_section=true
            continue
        fi
        if [[ "$line" == *"<!-- END AUTO-GENERATED SECTION "* ]]; then
            echo "$line" >> "$temp_file"
            in_auto_section=false
            continue
        fi
        if [[ "$in_auto_section" == false ]]; then
            echo "$line" >> "$temp_file"
        fi
    done < "$DOC_FILE"

    mv "$temp_file" "$DOC_FILE"
    echo "Test coverage table updated successfully."
}

echo "Generating test coverage table..."
update_documentation
echo "Test coverage table generation complete."
