#!/bin/bash
#######################################################################
# Lab Environment Reverse Dependencies Generator
#######################################################################
# File: rdp
# Description: Automatic function reverse dependency generator using ana_rdp -j
#######################################################################

set +e

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -z "${LAB_DIR:-}" ]]; then
    readonly LAB_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
fi

source "$LAB_DIR/lib/gen/aux" >/dev/null 2>&1
source "$LAB_DIR/lib/gen/ana" >/dev/null 2>&1

TARGETS_FILE="$(dirname "$SCRIPT_DIR")/config/targets"
if [[ -f "$TARGETS_FILE" ]]; then
    source "$TARGETS_FILE"
fi

DOC_FILE="$LAB_DIR/${GENERATOR_OUTPUT_FILES[rdp]:-doc/ref/dependencies.md}"
TMP_BASE_DIR="$LAB_DIR/.tmp/doc"
TMP_DIR="$TMP_BASE_DIR/rdp"
mkdir -p "$TMP_DIR"

generate_rdp_table() {
    cat << HEADER_EOF
*Auto-updated reverse dependencies table with real-time analysis*

> **Last Updated**: $(date '+%Y-%m-%d %H:%M:%S')  
> **Generated By**: utl/doc/generators/rdp  

This table provides an overview of reverse dependencies across modules.

### **📖 Reverse Dependencies Table**

| Target Module | Dependent Function | Total Calls | Dependent Files |
|---------------|--------------------|-------------|-----------------|
HEADER_EOF

    # Target modules defined in ffl-rdp_cycle
    local source_modules=("$LAB_DIR/lib/core" "$LAB_DIR/lib/gen" "$LAB_DIR/lib/ops")

    for dir in "${source_modules[@]}"; do
        if [[ ! -d "$dir" ]]; then continue; fi
        while IFS= read -r -d '' file; do
            local rel_file="${file#$LAB_DIR/}"
            
            # Determine callsite dirs based on the block
            local callsites=()
            if [[ "$dir" == *"lib/core"* ]]; then
                callsites=("$LAB_DIR/bin" "$LAB_DIR/lib" "$LAB_DIR/utl")
            elif [[ "$dir" == *"lib/gen"* ]]; then
                callsites=("$LAB_DIR/bin" "$LAB_DIR/lib" "$LAB_DIR/src" "$LAB_DIR/utl")
            elif [[ "$dir" == *"lib/ops"* ]]; then
                callsites=("$LAB_DIR/lib" "$LAB_DIR/src" "$LAB_DIR/utl")
            fi
            
            ana_rdp -j --json-dir "$TMP_DIR" "$file" "${callsites[@]}" >/dev/null 2>&1 || true
            
            local rel_target="${file#$LAB_DIR/}"
            rel_target="${rel_target#/}"
            local json_filename="${rel_target//\//_}.json"
            local json_file="$TMP_DIR/$json_filename"
            if [[ -f "$json_file" ]]; then
                jq -r --arg file "$rel_file" '
                    .dependencies[]? |
                    [
                        $file,
                        "`\(.function)`",
                        (.total_calls | tostring),
                        ([.used_by[]? | select(.calls > 0) | "\(.file): \(.calls)"] | join(", "))
                    ] |
                    "| " + join(" | ") + " |"
                ' "$json_file" 2>/dev/null
            fi
        done < <(find "$dir" -type f ! -path '*/.*' ! -name '*.*' -print0)
    done
}

update_documentation() {
    # If the doc file does not exist, initialize it
    if [[ ! -f "$DOC_FILE" ]]; then
        mkdir -p "$(dirname "$DOC_FILE")"
        cat << 'EOF' > "$DOC_FILE"
# Reverse Dependencies

<!-- AUTO-GENERATED SECTION: Reverse Dependencies Table -->
<!-- END AUTO-GENERATED SECTION -->
EOF
    fi

    local temp_file=$(mktemp)
    local in_auto_section=false

    echo "Updating reverse dependencies table in $DOC_FILE..."

    while IFS= read -r line; do
        if [[ "$line" == *"<!-- AUTO-GENERATED SECTION: "* ]]; then
            echo "$line" >> "$temp_file"
            generate_rdp_table >> "$temp_file"
            in_auto_section=true
            continue
        fi
        if [[ "$line" == *"<!-- END AUTO-GENERATED SECTION "* ]]; then
            echo "$line" >> "$temp_file"
            in_auto_section=false
            continue
        fi
        if [[ "$in_auto_section" == false ]]; then
            echo "$line" >> "$temp_file"
        fi
    done < "$DOC_FILE"

    mv "$temp_file" "$DOC_FILE"
    echo "Reverse dependencies table updated successfully."
}

echo "Generating reverse dependencies table..."
update_documentation
echo "Reverse dependencies table generation complete."
