#!/bin/bash
#######################################################################
# Lab Environment Scope Integrity Generator
#######################################################################
# File: scp
# Description: Automatic scope integrity generator using ana_scp -j
#######################################################################

set +e

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -z "${LAB_DIR:-}" ]]; then
    readonly LAB_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
fi

source "$LAB_DIR/lib/gen/aux" >/dev/null 2>&1
source "$LAB_DIR/lib/gen/ana" >/dev/null 2>&1

TARGETS_FILE="$(dirname "$SCRIPT_DIR")/config/targets"
if [[ -f "$TARGETS_FILE" ]]; then
    source "$TARGETS_FILE"
fi

DOC_FILE="$LAB_DIR/${GENERATOR_OUTPUT_FILES[scp]:-doc/ref/scope-integrity.md}"
TMP_BASE_DIR="$LAB_DIR/.tmp/doc"
TMP_DIR="$TMP_BASE_DIR/scp"
mkdir -p "$TMP_DIR"

# Target scopes according to ffl-scp_cycle
TARGET_DIRECTORIES=("bin" "lib/core" "lib/gen" "lib/ops" "src" "utl")

_scp_collect_rows() {
    local target_file="$1"
    local raw_rows_file="$2"

    ana_scp -j --json-dir "$TMP_DIR" "$target_file" >/dev/null 2>&1 || true

    local rel_file="${target_file#$LAB_DIR/}"
    rel_file="${rel_file#/}"
    local json_file="$TMP_DIR/${rel_file//\//_}_scp.json"

    if [[ -f "$json_file" ]]; then
        jq -r --arg target "$rel_file" '
            if ((.scope_analysis // []) | length) == 0 then
                [$target, "-", "-", "-", "No findings"] | @tsv
            else
                (.scope_analysis[] | [$target, .type, .variable, (.line|tostring), .context] | @tsv)
            end
        ' "$json_file" 2>/dev/null >> "$raw_rows_file"
    fi
}

generate_scp_table() {
    cat << HEADER_EOF
*Auto-updated scope integrity table with real-time analysis*

> **Last Updated**: $(date '+%Y-%m-%d %H:%M:%S')  
> **Generated By**: utl/doc/generators/scp  

This table tracks readonly declarations, global mutation patterns, and local leak findings.

### Scope Integrity Table

| Target Module | Type | Variable | Line | Context |
|---------------|------|----------|------|---------|
HEADER_EOF

    local raw_rows
    raw_rows=$(mktemp)

    local go_file="$LAB_DIR/go"
    if [[ -f "$go_file" ]]; then
        _scp_collect_rows "$go_file" "$raw_rows"
    fi

    for target_dir in "${TARGET_DIRECTORIES[@]}"; do
        local full_path="$LAB_DIR/$target_dir"
        if [[ ! -d "$full_path" ]]; then
            continue
        fi

        while IFS= read -r -d '' file; do
            _scp_collect_rows "$file" "$raw_rows"
        done < <(find "$full_path" -type f -print0 | LC_ALL=C sort -z)
    done

    if [[ -s "$raw_rows" ]]; then
        LC_ALL=C sort -t $'\t' -k1,1 -k2,2 -k3,3 -k4,4n "$raw_rows" | while IFS=$'\t' read -r target scope_type variable line context; do
            local target_cell="\`$target\`"
            local variable_cell="-"
            local context_cell="-"

            if [[ "$variable" != "-" ]]; then
                variable_cell="\`$variable\`"
            fi
            if [[ "$context" != "-" ]]; then
                context_cell="\`$context\`"
            fi

            echo "| $target_cell | $scope_type | $variable_cell | $line | $context_cell |"
        done
    fi

    rm -f "$raw_rows"
}

update_documentation() {
    if [[ ! -f "$DOC_FILE" ]]; then
        mkdir -p "$(dirname "$DOC_FILE")"
        cat << 'EOF' > "$DOC_FILE"
# Scope Integrity

This page tracks analyzer-derived scope integrity findings across project modules.

<!-- AUTO-GENERATED SECTION: Scope Integrity Table -->
<!-- END AUTO-GENERATED SECTION -->
EOF
    fi

    local temp_file
    temp_file=$(mktemp)
    local in_auto_section=false

    echo "Updating scope integrity table in $DOC_FILE..."

    while IFS= read -r line; do
        if [[ "$line" == *"<!-- AUTO-GENERATED SECTION: "* ]]; then
            echo "$line" >> "$temp_file"
            generate_scp_table >> "$temp_file"
            in_auto_section=true
            continue
        fi
        if [[ "$line" == *"<!-- END AUTO-GENERATED SECTION "* ]]; then
            echo "$line" >> "$temp_file"
            in_auto_section=false
            continue
        fi
        if [[ "$in_auto_section" == false ]]; then
            echo "$line" >> "$temp_file"
        fi
    done < "$DOC_FILE"

    mv "$temp_file" "$DOC_FILE"
    echo "Scope integrity table updated successfully."
}

echo "Generating scope integrity table..."
update_documentation
echo "Scope integrity table generation complete."
