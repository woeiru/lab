#!/bin/bash

set -euo pipefail

run_gate_usage() {
    cat <<'EOF'
Usage: src/run/gate-evidence <target> [options]

Produce a gate-evidence-v0 artifact for strict run dispatch.

Options:
  --plan <artifact>      Validate approvals against plan policy gates
  --allow-gate <gate>    Approve gate token (repeatable)
  --output <path>        Write artifact to path (default: stdout)
  --help                 Show this help

Environment defaults:
  LAB_RUN_ALLOWED_POLICY_GATES="gate_network gate_storage"

Examples:
  src/run/gate-evidence h1 --allow-gate gate_network --allow-gate gate_storage
  src/run/gate-evidence h1 --plan .tmp/rec/site1.plan --allow-gate gate_network --allow-gate gate_storage --output .tmp/rec/h1.gates
EOF
}

run_gate_parse_word_list() {
    local raw_value="$1"
    local -n out_ref=$2
    local -a tokens=()
    local token

    read -r -a tokens <<< "$raw_value"
    for token in "${tokens[@]}"; do
        if [[ -n "$token" ]]; then
            out_ref+=("$token")
        fi
    done

    return 0
}

run_gate_list_contains() {
    local needle="$1"
    shift

    local value
    for value in "$@"; do
        if [[ "$value" == "$needle" ]]; then
            return 0
        fi
    done

    return 1
}

run_gate_add_unique_token() {
    local -n list_ref=$1
    local token="$2"

    if run_gate_list_contains "$token" "${list_ref[@]}"; then
        return 0
    fi

    list_ref+=("$token")
    return 0
}

run_gate_validate_token() {
    local gate_token="$1"

    if [[ "$gate_token" =~ ^[a-zA-Z0-9._:-]+$ ]]; then
        return 0
    fi

    return 1
}

run_gate_plan_target_index() {
    local plan_path="$1"
    local target="$2"
    local line

    while IFS= read -r line; do
        if [[ "$line" =~ ^target_([0-9]+)=(.*)$ ]]; then
            if [[ "${BASH_REMATCH[2]}" == "$target" ]]; then
                printf '%s\n' "${BASH_REMATCH[1]}"
                return 0
            fi
        fi
    done < "$plan_path"

    return 1
}

run_gate_plan_target_field() {
    local plan_path="$1"
    local target="$2"
    local field_name="$3"
    local target_index

    if ! target_index="$(run_gate_plan_target_index "$plan_path" "$target")"; then
        return 1
    fi

    local lookup_prefix="target_${target_index}_${field_name}="
    local line
    while IFS= read -r line; do
        if [[ "$line" == "${lookup_prefix}"* ]]; then
            printf '%s\n' "${line#*=}"
            return 0
        fi
    done < "$plan_path"

    return 1
}

run_gate_plan_validate() {
    local plan_path="$1"
    local target="$2"
    local -a approved_gates=("${@:3}")

    if [[ ! -f "$plan_path" ]]; then
        printf 'src/run/gate-evidence: plan not found: %s\n' "$plan_path" >&2
        return 1
    fi

    local has_format=0
    local line
    while IFS= read -r line; do
        if [[ "$line" == "format=rec-plan-v0" ]]; then
            has_format=1
            break
        fi
    done < "$plan_path"

    if [[ "$has_format" -ne 1 ]]; then
        printf 'src/run/gate-evidence: invalid plan format in %s\n' "$plan_path" >&2
        return 1
    fi

    if ! run_gate_plan_target_index "$plan_path" "$target" >/dev/null; then
        printf 'src/run/gate-evidence: target "%s" not present in plan %s\n' "$target" "$plan_path" >&2
        return 1
    fi

    local policy_gates_value=""
    if ! policy_gates_value="$(run_gate_plan_target_field "$plan_path" "$target" "policy_gates")"; then
        printf 'src/run/gate-evidence: missing policy gate metadata for target "%s" in plan %s\n' "$target" "$plan_path" >&2
        return 1
    fi

    if [[ -z "$policy_gates_value" ]]; then
        return 0
    fi

    local -a required_gates=()
    run_gate_parse_word_list "$policy_gates_value" required_gates

    local required_gate
    for required_gate in "${required_gates[@]}"; do
        if ! run_gate_list_contains "$required_gate" "${approved_gates[@]}"; then
            printf 'src/run/gate-evidence: missing required gate "%s" for target "%s"\n' "$required_gate" "$target" >&2
            return 1
        fi
    done

    return 0
}

run_gate_main() {
    local target="${1:-}"

    if [[ -z "$target" || "$target" == "--help" || "$target" == "-h" ]]; then
        run_gate_usage
        return 0
    fi

    shift

    local plan_path=""
    local output_path=""
    local -a approved_gates=()

    if [[ -n "${LAB_RUN_ALLOWED_POLICY_GATES:-}" ]]; then
        run_gate_parse_word_list "$LAB_RUN_ALLOWED_POLICY_GATES" approved_gates
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --plan)
                if [[ $# -lt 2 ]]; then
                    printf 'src/run/gate-evidence: missing value for --plan\n' >&2
                    return 1
                fi
                plan_path="$2"
                shift 2
                ;;
            --allow-gate)
                if [[ $# -lt 2 ]]; then
                    printf 'src/run/gate-evidence: missing value for --allow-gate\n' >&2
                    return 1
                fi
                approved_gates+=("$2")
                shift 2
                ;;
            --output)
                if [[ $# -lt 2 ]]; then
                    printf 'src/run/gate-evidence: missing value for --output\n' >&2
                    return 1
                fi
                output_path="$2"
                shift 2
                ;;
            --help|-h)
                run_gate_usage
                return 0
                ;;
            *)
                printf 'src/run/gate-evidence: unknown option "%s"\n' "$1" >&2
                return 1
                ;;
        esac
    done

    local -a normalized_gates=()
    local gate_token
    for gate_token in "${approved_gates[@]}"; do
        if ! run_gate_validate_token "$gate_token"; then
            printf 'src/run/gate-evidence: invalid gate token "%s"\n' "$gate_token" >&2
            return 1
        fi
        run_gate_add_unique_token normalized_gates "$gate_token"
    done

    if [[ "${#normalized_gates[@]}" -eq 0 ]]; then
        printf 'src/run/gate-evidence: at least one approved gate is required\n' >&2
        return 1
    fi

    if [[ -n "$plan_path" ]]; then
        if ! run_gate_plan_validate "$plan_path" "$target" "${normalized_gates[@]}"; then
            return 1
        fi
    fi

    local generated_at
    generated_at="$(date '+%Y-%m-%dT%H:%M:%S%z')"

    local joined_gates="${normalized_gates[0]}"
    local i
    for ((i = 1; i < ${#normalized_gates[@]}; i++)); do
        joined_gates+=" ${normalized_gates[$i]}"
    done

    local artifact=""
    artifact+="# producer=src/run/gate-evidence"$'\n'
    artifact+="# generated_at=${generated_at}"$'\n'
    if [[ -n "$plan_path" ]]; then
        artifact+="# plan=${plan_path}"$'\n'
    fi
    artifact+="format=gate-evidence-v0"$'\n'
    artifact+="target=${target}"$'\n'
    artifact+="approved_gates=${joined_gates}"$'\n'

    if [[ -n "$output_path" ]]; then
        mkdir -p "$(dirname "$output_path")"
        printf '%s' "$artifact" > "$output_path"
        printf 'src/run/gate-evidence: wrote artifact to %s\n' "$output_path"
        return 0
    fi

    printf '%s' "$artifact"
    return 0
}

run_gate_main "$@"
