#!/bin/bash
# ----------------------------------------------------------------------
# Functions:
#   a_xall: Installs NFS server packages, enables the NFS service, and 
#           creates a user account for NFS management.
#   b_xall: Configures NFS exports by setting up a shared folder with 
#           specified access permissions.
# ----------------------------------------------------------------------

# Define script location
DIR_SH="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
FILE_SH="$(basename "${BASH_SOURCE[0]}")"
BASE_SH="${FILE_SH%.*}"
export LAB_REC_TARGET="${BASE_SH}"

# Temporary compatibility delegation to src/run during migration
if [[ "${LAB_RUN_DISPATCH_BYPASS:-0}" != "1" ]]; then
    if [[ "${LAB_USE_DIC_RUN_BRIDGE:-0}" == "1" ]]; then
        DIC_RUN_FILE="${DIR_SH}/../dic/run"
        if [[ -x "$DIC_RUN_FILE" ]]; then
            exec "$DIC_RUN_FILE" "$BASE_SH" "$@"
        fi
    fi

    RUN_DISPATCH_FILE="${DIR_SH}/../run/dispatch"
    if [[ -x "$RUN_DISPATCH_FILE" ]]; then
        exec "$RUN_DISPATCH_FILE" "$BASE_SH" "$@"
    fi
fi

# Source menu framework
MENU_FILE="$(realpath "$DIR_SH/.menu")"
if ! source "$MENU_FILE"; then
    printf 'Failed to source menu framework: %s\n' "$MENU_FILE" >&2
    exit 2
fi

# Source DIC operations for intelligent parameter resolution
if ! source "$DIR_SH/../dic/ops"; then
    printf 'Failed to source DIC operations: %s\n' "$DIR_SH/../dic/ops" >&2
    exit 2
fi

menu_runtime_setup "${BASE_SH}_bootstrap" || exit 2

# Declare MENU_OPTIONS
declare -A MENU_OPTIONS
MENU_OPTIONS[a]="a_xall"
MENU_OPTIONS[b]="b_xall"

# Installs NFS server packages, enables the NFS service, and creates a user account for NFS management
a_xall() {
    ops sys ipa -j
    ops sys sdc -j
    ops sys ust -j
}

# Configures NFS exports by setting up a shared folder with specified access permissions
b_xall() {
    ops nfs set -j
}

# Handle script execution
if [ $# -eq 0 ]; then
    print_usage
    clean_exit 0       # Exit cleanly with status 0
else
    setup_main "$@"
    clean_exit $?
fi
