#!/bin/bash
#######################################################################
# System Initialization Controller
#######################################################################
# Purpose:
#   Core system initialization script that manages the bootstrapping and
#   configuration of the entire environment through a modular, dependency-
#   aware approach.
#
# Architecture:
#   - Core Components:
#     * Verification Module (ver): Validates system state and dependencies
#     * Runtime Constants (ric): System-wide configuration constants
#     * Runtime Dependencies (rdc): Runtime environment requirements
#     * Shared Loader Registry (lab): Canonical module source tracking
#     * Component Orchestrator (orc): Manages setup of additional system components
#
# Initialization Flow:
#   1. Module System Initialization:
#      - Validates core dependencies
#      - Sets up required directories
#      - Loads and verifies essential modules (err, lo1, tme)
#
#   2. Core System Configuration & Runtime Initialization:
#      - Sources the Component Orchestrator (bin/orc)
#      - Prepares bootstrap runtime state and component loading defaults
#
#   3. Additional Component Setup:
#      - Utilizes the Component Orchestrator to set up further system components
#
# Error Handling:
#   - Comprehensive error logging via ini_log
#   - Fallback to minimal environment on failure
#   - Verification at each critical step
#
# Dependencies:
#   Required files in cfg/core/:
#   - ric (Runtime initialization constants - provides directory paths)
#   - rdc (Runtime dependency constants)
#   Required modules in lib/core/:
#   - col (Centralized color management)
#   - err (Error handling functions)
#   - lo1 (Logging functions)
#   - tme (Timing functions)
#   - lab (Shared module sourcing registry)
#   - ver (Verification functions)
#   Required scripts in bin/:
#   - orc (Component orchestrator)
#   Required directory variables from ric:
#   - BASE_DIR (Base lab directory path)
#   - LOG_DIR (Logging directory path)
#   - TMP_DIR (Temporary files directory path)
#   - LIB_CORE_DIR (Core library directory path)
#   - ERROR_LOG, INI_LOG_FILE, LOG_FILE (Log file paths)
#   - TME_LOG_FILE, TME_STATE_FILE (Timing system files)
#
#######################################################################

#######################################################################
# Constants and Configuration
#######################################################################

# Prevent readonly errors when re-sourced (e.g. calling lab twice)
[[ -n "${_INI_LOADED:-}" ]] && return 0 2>/dev/null || :
_INI_LOADED=1

# Capture wall-clock start time before anything else runs
ini_now_ns() {
    local out_var="$1"
    local epoch
    local seconds
    local micros="000000"

    if [[ -n "${EPOCHREALTIME:-}" ]]; then
        epoch="${EPOCHREALTIME/,/.}"
        seconds="${epoch%%.*}"
        micros="${epoch#*.}"
        micros="${micros//[^0-9]/}"
        micros="${micros:0:6}"
        while ((${#micros} < 6)); do
            micros+="0"
        done
    else
        printf -v seconds '%(%s)T' -1
    fi

    printf -v "$out_var" '%s%s000' "$seconds" "$micros"
}

ini_format_time() {
    local out_var="$1"
    local format="$2"
    printf -v "$out_var" "%(${format})T" -1
}

restore_boot_log_debug_state() {
    if [[ "${_INI_LOG_DEBUG_WAS_SET:-0}" -eq 1 ]]; then
        export LOG_DEBUG_ENABLED="${_INI_LOG_DEBUG_ORIG_VALUE:-1}"
    else
        export LOG_DEBUG_ENABLED=1
    fi
    unset _INI_LOG_DEBUG_WAS_SET _INI_LOG_DEBUG_ORIG_VALUE
}

ini_now_ns _INI_START_NS

# Suppress verbose debug stack traces during bootstrap sourcing chain
declare -g _INI_LOG_DEBUG_WAS_SET=0
declare -g _INI_LOG_DEBUG_ORIG_VALUE="1"
if [[ -v LOG_DEBUG_ENABLED ]]; then
    _INI_LOG_DEBUG_WAS_SET=1
    _INI_LOG_DEBUG_ORIG_VALUE="$LOG_DEBUG_ENABLED"
fi
export LOG_DEBUG_ENABLED=0
export LAB_BOOTSTRAP_MODE=1
: "${LAB_BOOTSTRAP_CACHE_ENABLED:=1}"
export LAB_BOOTSTRAP_CACHE_ENABLED

readonly LOG_PRIORITY_NORMAL=1
readonly LOG_PRIORITY_DETAILED=2
readonly TIMER_MAIN_OPERATIONS="MAIN_OPERATIONS"
readonly TIMER_SOURCE_COMP="SOURCE_COMP_ORCHESTRATOR"
readonly TIMER_FINALIZE="FINALIZE_MAIN_INIT"
readonly INI_BOOTSTRAP_PROFILE_INTERACTIVE="interactive"
readonly INI_BOOTSTRAP_PROFILE_DEPLOYMENT="deployment"
readonly INI_BOOTSTRAP_OUTPUT_LEGACY="legacy"
readonly INI_BOOTSTRAP_OUTPUT_COMPACT="compact"
readonly INI_BOOTSTRAP_VERBOSITY_COMPACT="compact"
readonly INI_BOOTSTRAP_VERBOSITY_VERBOSE="verbose"
readonly INI_BOOTSTRAP_VERBOSITY_SILENT="silent"

declare -g INI_BOOTSTRAP_OUTPUT_MODE="$INI_BOOTSTRAP_OUTPUT_COMPACT"
declare -g INI_BOOTSTRAP_VERBOSITY_MODE="$INI_BOOTSTRAP_VERBOSITY_COMPACT"
declare -g INI_BOOTSTRAP_OUTPUT_REQUESTED_RAW="${LAB_BOOTSTRAP_OUTPUT:-}"
declare -g INI_BOOTSTRAP_VERBOSITY_REQUESTED_RAW="${LAB_BOOTSTRAP_VERBOSITY:-}"
declare -g INI_BOOTSTRAP_OUTPUT_INVALID_VALUE=0
declare -g INI_BOOTSTRAP_VERBOSITY_INVALID_VALUE=0
declare -ga INI_COMPACT_SPINNER_FRAMES=("|" "/" "-" "\\")
declare -g INI_COMPACT_SPINNER_INDEX=0
declare -g INI_COMPACT_HEADER_PRINTED=0
declare -g INI_COMPACT_PROGRESS_ACTIVE=0
declare -g INI_COMPACT_LAST_RENDER_LENGTH=0
declare -g INI_COMPACT_PROFILE_LABEL="${LAB_BOOTSTRAP_PROFILE:-$INI_BOOTSTRAP_PROFILE_INTERACTIVE}"

_INI_OUTPUT_REQUESTED="${LAB_BOOTSTRAP_OUTPUT:-$INI_BOOTSTRAP_OUTPUT_COMPACT}"
_INI_OUTPUT_REQUESTED="${_INI_OUTPUT_REQUESTED,,}"
case "$_INI_OUTPUT_REQUESTED" in
    "$INI_BOOTSTRAP_OUTPUT_COMPACT"|"$INI_BOOTSTRAP_OUTPUT_LEGACY")
        INI_BOOTSTRAP_OUTPUT_MODE="$_INI_OUTPUT_REQUESTED"
        ;;
    *)
        INI_BOOTSTRAP_OUTPUT_MODE="$INI_BOOTSTRAP_OUTPUT_COMPACT"
        INI_BOOTSTRAP_OUTPUT_INVALID_VALUE=1
        ;;
esac

_INI_VERBOSITY_REQUESTED="${LAB_BOOTSTRAP_VERBOSITY:-}"
_INI_VERBOSITY_REQUESTED="${_INI_VERBOSITY_REQUESTED,,}"
if [[ -z "$_INI_VERBOSITY_REQUESTED" ]]; then
    if [[ "$INI_BOOTSTRAP_OUTPUT_MODE" == "$INI_BOOTSTRAP_OUTPUT_LEGACY" ]]; then
        INI_BOOTSTRAP_VERBOSITY_MODE="$INI_BOOTSTRAP_VERBOSITY_VERBOSE"
    else
        INI_BOOTSTRAP_VERBOSITY_MODE="$INI_BOOTSTRAP_VERBOSITY_COMPACT"
    fi
else
    case "$_INI_VERBOSITY_REQUESTED" in
        "$INI_BOOTSTRAP_VERBOSITY_COMPACT"|"$INI_BOOTSTRAP_VERBOSITY_VERBOSE"|"$INI_BOOTSTRAP_VERBOSITY_SILENT")
            INI_BOOTSTRAP_VERBOSITY_MODE="$_INI_VERBOSITY_REQUESTED"
            ;;
        *)
            INI_BOOTSTRAP_VERBOSITY_MODE="$INI_BOOTSTRAP_VERBOSITY_COMPACT"
            INI_BOOTSTRAP_VERBOSITY_INVALID_VALUE=1
            ;;
    esac
fi

case "$INI_BOOTSTRAP_VERBOSITY_MODE" in
    "$INI_BOOTSTRAP_VERBOSITY_VERBOSE")
        INI_BOOTSTRAP_OUTPUT_MODE="$INI_BOOTSTRAP_OUTPUT_LEGACY"
        ;;
    "$INI_BOOTSTRAP_VERBOSITY_COMPACT"|"$INI_BOOTSTRAP_VERBOSITY_SILENT")
        INI_BOOTSTRAP_OUTPUT_MODE="$INI_BOOTSTRAP_OUTPUT_COMPACT"
        ;;
esac

export LAB_BOOTSTRAP_OUTPUT="$INI_BOOTSTRAP_OUTPUT_MODE"
export LAB_BOOTSTRAP_VERBOSITY="$INI_BOOTSTRAP_VERBOSITY_MODE"
unset _INI_OUTPUT_REQUESTED
unset _INI_VERBOSITY_REQUESTED

# Output a startup message, respecting verbosity settings
if [[ "${MASTER_TERMINAL_VERBOSITY:-on}" == "on" && "${INI_LOG_TERMINAL_VERBOSITY:-on}" == "on" && "$INI_BOOTSTRAP_OUTPUT_MODE" == "$INI_BOOTSTRAP_OUTPUT_LEGACY" ]]; then
    echo " ─────────────── " >&2
fi

# Set the base directory path
readonly DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
readonly BASE_DIR="$( cd "$DIR/.." &> /dev/null && pwd )"
readonly INI_BOOTSTRAP_CACHE_VERSION="1"
readonly INI_BOOTSTRAP_CACHE_DIR="${LAB_BOOTSTRAP_CACHE_DIR:-${BASE_DIR}/.tmp/bootstrap}"
readonly INI_BOOTSTRAP_CACHE_FILE="${LAB_BOOTSTRAP_CACHE_FILE:-${INI_BOOTSTRAP_CACHE_DIR}/ini_core.cache}"
readonly INI_BOOTSTRAP_CACHE_META="${LAB_BOOTSTRAP_CACHE_META:-${INI_BOOTSTRAP_CACHE_DIR}/ini_core.meta}"

declare -g INI_COMPILED_BOOTSTRAP_CACHE_USED=0

# Cache for file existence checks and directory creation
declare -A file_existence_cache
declare -A dir_creation_cache

#######################################################################
# Helper Functions
#######################################################################

# Cached file existence check
check_file_cached() {
    local file="$1"
    local type="${2:-file}" # file or dir
    
    if [[ -n "${file_existence_cache[$file]:-}" ]]; then
        [[ "${file_existence_cache[$file]}" == "true" ]]
        return $?
    fi
    
    local exists=false
    if [[ "$type" == "dir" ]]; then
        [[ -d "$file" ]] && exists=true
    else
        [[ -f "$file" ]] && exists=true
    fi
    
    file_existence_cache[$file]="$exists"
    [[ "$exists" == "true" ]]
}

# Optimized directory creation with caching
ensure_dir_cached() {
    local dir="$1"
    
    if [[ -n "${dir_creation_cache[$dir]:-}" ]]; then
        return 0
    fi
    
    if [[ ! -d "$dir" ]]; then
        mkdir -p "$dir" 2>/dev/null || return 1
    fi
    dir_creation_cache[$dir]="created"
    return 0
}

apply_bootstrap_verbosity_overrides() {
    case "${INI_BOOTSTRAP_VERBOSITY_MODE:-$INI_BOOTSTRAP_VERBOSITY_COMPACT}" in
        "$INI_BOOTSTRAP_VERBOSITY_SILENT")
            export INI_LOG_TERMINAL_VERBOSITY="off"
            export LO1_LOG_TERMINAL_VERBOSITY="off"
            export ERR_TERMINAL_VERBOSITY="off"
            export TME_TERMINAL_VERBOSITY="off"
            export TME_REPORT_TERMINAL_OUTPUT="off"
            ;;
        "$INI_BOOTSTRAP_VERBOSITY_VERBOSE")
            export INI_LOG_TERMINAL_VERBOSITY="on"
            export LO1_LOG_TERMINAL_VERBOSITY="on"
            export ERR_TERMINAL_VERBOSITY="on"
            export TME_TERMINAL_VERBOSITY="on"
            export TME_REPORT_TERMINAL_OUTPUT="on"
            ;;
        *)
            export INI_LOG_TERMINAL_VERBOSITY="on"
            export LO1_LOG_TERMINAL_VERBOSITY="on"
            export ERR_TERMINAL_VERBOSITY="on"
            export TME_TERMINAL_VERBOSITY="on"
            export TME_REPORT_TERMINAL_OUTPUT="on"
            ;;
    esac
}

ini_terminal_output_enabled() {
    [[ "${MASTER_TERMINAL_VERBOSITY:-on}" == "on" && "${INI_LOG_TERMINAL_VERBOSITY:-on}" == "on" ]]
}

ini_is_compact_output() {
    [[ "${INI_BOOTSTRAP_OUTPUT_MODE:-$INI_BOOTSTRAP_OUTPUT_LEGACY}" == "$INI_BOOTSTRAP_OUTPUT_COMPACT" ]]
}

ini_compact_truncate() {
    local out_var="$1"
    local text="$2"
    local max_width="$3"

    if ((max_width <= 0)); then
        printf -v "$out_var" ''
        return 0
    fi

    if ((${#text} <= max_width)); then
        printf -v "$out_var" '%s' "$text"
        return 0
    fi

    if ((max_width <= 3)); then
        printf -v "$out_var" '%.*s' "$max_width" "$text"
        return 0
    fi

    printf -v "$out_var" '%s...' "${text:0:$((max_width - 3))}"
}

ini_compact_print_header() {
    ini_is_compact_output || return 0
    ini_terminal_output_enabled || return 0
    [[ "$INI_COMPACT_HEADER_PRINTED" -eq 1 ]] && return 0

    printf 'lab · %s · bootstrap\n' "${INI_COMPACT_PROFILE_LABEL:-$INI_BOOTSTRAP_PROFILE_INTERACTIVE}" >&2
    INI_COMPACT_HEADER_PRINTED=1
}

ini_compact_next_spinner() {
    local out_var="$1"
    local frame_count="${#INI_COMPACT_SPINNER_FRAMES[@]}"
    local frame="${INI_COMPACT_SPINNER_FRAMES[$INI_COMPACT_SPINNER_INDEX]}"

    printf -v "$out_var" '%s' "$frame"
    INI_COMPACT_SPINNER_INDEX=$(((INI_COMPACT_SPINNER_INDEX + 1) % frame_count))
}

ini_compact_render_progress() {
    local message="$1"
    local spinner
    local compact_message
    local line
    local line_length
    local pad_width
    local pad

    ini_compact_print_header
    [[ -t 2 ]] || return 0

    ini_compact_next_spinner spinner
    ini_compact_truncate compact_message "$message" 72
    line="$spinner $compact_message"
    line_length=${#line}

    if ((INI_COMPACT_LAST_RENDER_LENGTH > line_length)); then
        pad_width=$((INI_COMPACT_LAST_RENDER_LENGTH - line_length))
        printf -v pad '%*s' "$pad_width" ''
        line+="$pad"
    fi

    printf '\r%s' "$line" >&2
    INI_COMPACT_LAST_RENDER_LENGTH=$line_length
    INI_COMPACT_PROGRESS_ACTIVE=1
}

ini_compact_finish_progress_line() {
    if [[ "$INI_COMPACT_PROGRESS_ACTIVE" -eq 1 ]]; then
        printf '\n' >&2
    fi
    INI_COMPACT_PROGRESS_ACTIVE=0
    INI_COMPACT_LAST_RENDER_LENGTH=0
}

ini_compact_print_success_summary() {
    local elapsed_display="$1"

    ini_compact_print_header
    ini_compact_finish_progress_line
    printf '✓ initialization complete · %s · clean\n' "$elapsed_display" >&2
}

ini_compact_print_failure_summary() {
    local status_code="$1"

    ini_compact_print_header
    ini_compact_finish_progress_line
    printf '✗ initialization failed · status %s\n' "$status_code" >&2
    printf '  logs: %s %s %s\n' "$INI_LOG_FILE" "$ERROR_LOG" "${BASE_DIR}/.log/tme.log" >&2
}

ini_file_signature() {
    local file_path="$1"
    local mtime
    local size

    [[ -f "$file_path" ]] || return 1

    mtime=$(stat -c '%Y' "$file_path" 2>/dev/null) || return 1
    size=$(stat -c '%s' "$file_path" 2>/dev/null) || return 1

    printf '%s:%s\n' "$mtime" "$size"
}

ini_compiled_cache_is_fresh() {
    local line
    local version=""
    local entry_type
    local entry_payload
    local entry_path
    local expected_signature
    local current_signature
    local cache_entries=0
    local source_entries=0

    [[ -r "$INI_BOOTSTRAP_CACHE_FILE" && -r "$INI_BOOTSTRAP_CACHE_META" ]] || return 1

    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" ]] && continue

        case "$line" in
            version=*)
                version="${line#version=}"
                ;;
            cache\|*|source\|*)
                entry_type="${line%%|*}"
                entry_payload="${line#*|}"
                entry_path="${entry_payload%%|*}"
                expected_signature="${entry_payload#*|}"

                current_signature=$(ini_file_signature "$entry_path") || return 1
                [[ "$current_signature" == "$expected_signature" ]] || return 1

                if [[ "$entry_type" == "cache" ]]; then
                    ((cache_entries++))
                else
                    ((source_entries++))
                fi
                ;;
            *)
                ;;
        esac
    done < "$INI_BOOTSTRAP_CACHE_META"

    [[ "$version" == "$INI_BOOTSTRAP_CACHE_VERSION" ]] || return 1
    [[ "$cache_entries" -eq 1 ]] || return 1
    [[ "$source_entries" -gt 0 ]] || return 1
    return 0
}

load_modules_from_compiled_cache() {
    INI_COMPILED_BOOTSTRAP_CACHE_USED=0

    if [[ "${LAB_BOOTSTRAP_CACHE_ENABLED:-1}" != "1" ]]; then
        ini_log "Compiled bootstrap cache disabled via LAB_BOOTSTRAP_CACHE_ENABLED"
        return 1
    fi

    if ! ini_compiled_cache_is_fresh; then
        ini_log "Compiled bootstrap cache unavailable or stale; using module source files" "load_modules" "$LOG_PRIORITY_DETAILED"
        return 1
    fi

    if ! source "$INI_BOOTSTRAP_CACHE_FILE"; then
        ini_log "WARNING: Failed to source compiled bootstrap cache (${INI_BOOTSTRAP_CACHE_FILE})"
        return 1
    fi

    if type err_process &>/dev/null && type lo1_log &>/dev/null && type tme_start_timer &>/dev/null && type lab_source_module &>/dev/null; then
        INI_COMPILED_BOOTSTRAP_CACHE_USED=1
        ini_log "Loaded core modules from compiled bootstrap cache"
        return 0
    fi

    ini_log "WARNING: Compiled bootstrap cache missing expected core symbols; using module source files"
    return 1
}

# Centralized sourcing with timer and error handling
source_with_timer() {
    local file="$1"
    local timer_name="$2"
    local parent_timer="${3:-}"
    local error_msg="${4:-Failed to source $file}"
    
    if [[ -n "$parent_timer" ]]; then
        type tme_start_timer &>/dev/null && tme_start_timer "$timer_name" "$parent_timer"
    else
        type tme_start_timer &>/dev/null && tme_start_timer "$timer_name"
    fi
    
    if ! source "$file" 2>/dev/null; then
        type tme_end_timer &>/dev/null && tme_end_timer "$timer_name" "error"
        ini_log "ERROR: $error_msg"
        return 1
    fi
    
    type tme_end_timer &>/dev/null && tme_end_timer "$timer_name" "success"
    return 0
}

# Initialization logging function to use before we load the full system
# Now with optimized I/O for performance-critical sections
ini_log() {
    local timestamp
    ini_format_time timestamp '%H:%M:%S'
    local message="$1"
    local source="${2:-${FUNCNAME[1]:-main}}"
    local priority="${3:-$LOG_PRIORITY_NORMAL}"
    local INI_LOG_FILE="${BASE_DIR}/.log/ini.log"
    
    # Skip detailed logs during performance-critical operations if desired
    if [[ "$priority" == "$LOG_PRIORITY_DETAILED" && "${PERFORMANCE_MODE:-0}" == "1" ]]; then
        return 0
    fi
    
    # Always log to file (but batch for performance)
    ensure_dir_cached "$(dirname "$INI_LOG_FILE")"
    echo "[INI] $timestamp - [$source] $message" >> "$INI_LOG_FILE"
    
    # Conditionally output to stderr based on both system and specific ini log verbosity
    if ini_terminal_output_enabled; then
        if ini_is_compact_output; then
            ini_compact_render_progress "$message"
        else
            echo "└─ $message [$timestamp]" >&2
        fi
    fi
}

# Initialization System
# Dependencies: Relies on verification module (ver) and runtime dependency constants (rdc)
# Purpose: Manages system initialization in two phases:
#   1. Module dependency initialization
#   2. Component orchestration setup

# Source core configuration files with proper error messages
source "${BASE_DIR}/cfg/core/ric" || {
    echo "Failed to source runtime initialization constants (ric)" >&2
    exit 1
}

source "${BASE_DIR}/cfg/core/rdc" || {
    echo "Failed to source runtime dependency constants (rdc)" >&2
    exit 1
}

source "${BASE_DIR}/lib/core/ver" || {
    echo "Failed to source verification module (ver)" >&2
    exit 1
}

###############################################
# Core initialization orchestrator
# Dependencies:
#   - ver (lib/core/ver) for all verification functions
###############################################
resolve_bootstrap_profile() {
    local requested_profile="${1:-${LAB_BOOTSTRAP_PROFILE:-$INI_BOOTSTRAP_PROFILE_INTERACTIVE}}"
    requested_profile="${requested_profile#--}"
    requested_profile="${requested_profile,,}"

    case "$requested_profile" in
        interactive|shell)
            printf '%s\n' "$INI_BOOTSTRAP_PROFILE_INTERACTIVE"
            return 0
            ;;
        deployment|deploy)
            printf '%s\n' "$INI_BOOTSTRAP_PROFILE_DEPLOYMENT"
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

main_ini() {
    local requested_profile="${1:-}"
    local main_op_timer_started=0
    local bootstrap_profile

    # Performance optimization: Enable performance mode for critical sections
    export PERFORMANCE_MODE=1
    apply_bootstrap_verbosity_overrides

    # Initialize logging system
    if ! init_logging_system; then
        ini_compact_finish_progress_line
        restore_boot_log_debug_state
        unset LAB_BOOTSTRAP_MODE
        echo "Critical Error: Failed to initialize logging system" >&2
        return 1
    fi

    if [[ "${INI_BOOTSTRAP_OUTPUT_INVALID_VALUE:-0}" -eq 1 ]]; then
        local invalid_output_value="${INI_BOOTSTRAP_OUTPUT_REQUESTED_RAW:-unset}"
        local invalid_timestamp
        ini_format_time invalid_timestamp '%H:%M:%S'
        echo "[INI] $invalid_timestamp - [bootstrap_output] WARNING: Invalid LAB_BOOTSTRAP_OUTPUT='$invalid_output_value'; using compact output" >> "$INI_LOG_FILE"
    fi

    if [[ "${INI_BOOTSTRAP_VERBOSITY_INVALID_VALUE:-0}" -eq 1 ]]; then
        local invalid_verbosity_value="${INI_BOOTSTRAP_VERBOSITY_REQUESTED_RAW:-unset}"
        local invalid_verbosity_timestamp
        ini_format_time invalid_verbosity_timestamp '%H:%M:%S'
        echo "[INI] $invalid_verbosity_timestamp - [bootstrap_verbosity] WARNING: Invalid LAB_BOOTSTRAP_VERBOSITY='$invalid_verbosity_value'; using compact" >> "$INI_LOG_FILE"
    fi

    ini_log "Starting main initialization with performance optimizations"

    # Verify that verification module is loaded
    if ! verify_core_modules_loaded; then
        ini_compact_finish_progress_line
        restore_boot_log_debug_state
        unset LAB_BOOTSTRAP_MODE
        echo "ERROR: Core verification modules not properly loaded" >&2
        return 1
    fi

    # Part 1: Module dependency initialization
    if ! init_module_system; then
        restore_boot_log_debug_state
        unset LAB_BOOTSTRAP_MODE
        ini_log "Critical error: Module system initialization failed. Exiting." "main_ini"
        return 1
    fi

    # Initialize timer system and start main operations timer
    if ! init_timer_system; then
        ini_log "WARNING: Timer system initialization failed"
    else
        main_op_timer_started=1
    fi

    # Part 2: Source component orchestrator
    if ! source_component_orchestrator "$main_op_timer_started"; then
        restore_boot_log_debug_state
        unset LAB_BOOTSTRAP_MODE
        return 1
    fi

    # Disable performance mode before component setup
    export PERFORMANCE_MODE=0

    # Phase 3 prototype: lazy-load selected ops modules during bootstrap.
    : "${LAB_OPS_LAZY_LOAD:=1}"
    : "${LAB_OPS_LAZY_MODULES:=all}"
    : "${LAB_GEN_LAZY_LOAD:=1}"
    : "${LAB_GEN_LAZY_MODULES:=all}"
    export LAB_OPS_LAZY_LOAD LAB_OPS_LAZY_MODULES LAB_GEN_LAZY_LOAD LAB_GEN_LAZY_MODULES

    if ! bootstrap_profile="$(resolve_bootstrap_profile "$requested_profile")"; then
        restore_boot_log_debug_state
        unset LAB_BOOTSTRAP_MODE
        ini_log "ERROR: Unsupported bootstrap profile '${requested_profile:-${LAB_BOOTSTRAP_PROFILE:-unset}}'"
        return 1
    fi

    INI_COMPACT_PROFILE_LABEL="$bootstrap_profile"
    ini_log "Bootstrap profile selected: ${bootstrap_profile}"

    # Part 3: Setup profile-specific components
    if ! setup_components_with_finalization "$main_op_timer_started" "$bootstrap_profile"; then
        restore_boot_log_debug_state
        unset LAB_BOOTSTRAP_MODE
        return 1
    fi

    restore_boot_log_debug_state
    unset LAB_BOOTSTRAP_MODE
    ini_log "Main initialization completed successfully"
    return 0
}

# Initialize logging system with proper error handling
init_logging_system() {
    if [[ -z "$LOG_DIR" ]] || [[ -z "$INI_LOG_FILE" ]] || [[ -z "$ERROR_LOG" ]]; then
        return 1
    fi
    
    ensure_dir_cached "$LOG_DIR"
    > "$INI_LOG_FILE" # Clear/create ini log
    > "$ERROR_LOG"    # Clear/create error log
    return 0
}

# Verify core modules are loaded
verify_core_modules_loaded() {
    type ver_verify_module &>/dev/null && type ver_verify_path &>/dev/null
}

# Initialize timer system
init_timer_system() {
    if type tme_init_timer &>/dev/null; then
        tme_init_timer "${BASE_DIR}/.log"
        ini_log "Timer system initialized and log cleared (${BASE_DIR}/.log/tme.log)."
        
        if type tme_start_timer &>/dev/null; then
            tme_start_timer "$TIMER_MAIN_OPERATIONS"
            return 0
        else
            ini_log "WARNING: tme_start_timer function not found."
            return 1
        fi
    else
        ini_log "WARNING: tme_init_timer function not found after module loading."
        return 1
    fi
}

# Source component orchestrator with proper error handling
source_component_orchestrator() {
    local main_op_timer_started="$1"
    local comp_orchestrator_path="${BASE_DIR}/bin/orc"
    
    if ! check_file_cached "$comp_orchestrator_path"; then
        restore_boot_log_debug_state
        ini_log "ERROR: Component orchestrator script not found at $comp_orchestrator_path"
        ((main_op_timer_started)) && type tme_end_timer &>/dev/null && tme_end_timer "$TIMER_MAIN_OPERATIONS" "1"
        return 1
    fi
    
    if ! source_with_timer "$comp_orchestrator_path" "$TIMER_SOURCE_COMP" "$TIMER_MAIN_OPERATIONS" "Failed to source component orchestrator"; then
        restore_boot_log_debug_state
        ((main_op_timer_started)) && type tme_end_timer &>/dev/null && tme_end_timer "$TIMER_MAIN_OPERATIONS" "1"
        return 1
    fi

    ini_log "Component orchestrator sourced successfully"
    return 0
}

# Setup components with finalization
setup_components_with_finalization() {
    local main_op_timer_started="$1"
    local bootstrap_profile="${2:-$INI_BOOTSTRAP_PROFILE_INTERACTIVE}"
    local component_setup_function="setup_components"

    case "$bootstrap_profile" in
        "$INI_BOOTSTRAP_PROFILE_INTERACTIVE")
            component_setup_function="setup_components"
            ;;
        "$INI_BOOTSTRAP_PROFILE_DEPLOYMENT")
            component_setup_function="setup_deployment_components"
            ;;
        *)
            ini_log "ERROR: Invalid bootstrap profile '$bootstrap_profile'"
            ((main_op_timer_started)) && type tme_end_timer &>/dev/null && tme_end_timer "$TIMER_MAIN_OPERATIONS" "1"
            return 1
            ;;
    esac

    ini_log "Setting RC_SOURCED=0 before calling ${component_setup_function} (${bootstrap_profile})"
    if ! type "$component_setup_function" &>/dev/null; then
        ini_log "ERROR: Expected component setup function '$component_setup_function' is unavailable"
        ((main_op_timer_started)) && type tme_end_timer &>/dev/null && tme_end_timer "$TIMER_MAIN_OPERATIONS" "1"
        return 1
    fi

    if ! "$component_setup_function"; then
        ini_log "ERROR: Component setup failed via orchestrator profile '${bootstrap_profile}'."
        ((main_op_timer_started)) && type tme_end_timer &>/dev/null && tme_end_timer "$TIMER_MAIN_OPERATIONS" "1"
        return 1
    fi

    type tme_start_timer &>/dev/null && tme_start_timer "$TIMER_FINALIZE" "$TIMER_MAIN_OPERATIONS"
    ini_log "RC_SOURCED value after setup_components: ${RC_SOURCED}"
    
    # Set RC_SOURCED=1 if setup_components succeeded
    if [[ -z "${RC_SOURCED:-}" ]] || [[ "${RC_SOURCED:-0}" -ne 1 ]]; then
        ini_log "Note: RC_SOURCED was not set to 1 by setup_components, setting it now"
        export RC_SOURCED=1
    fi

    type tme_end_timer &>/dev/null && tme_end_timer "$TIMER_FINALIZE" "success"
    ((main_op_timer_started)) && type tme_end_timer &>/dev/null && tme_end_timer "$TIMER_MAIN_OPERATIONS" "0"
    return 0
}

main_ini_interactive() {
    main_ini "$INI_BOOTSTRAP_PROFILE_INTERACTIVE"
}

main_ini_deployment() {
    main_ini "$INI_BOOTSTRAP_PROFILE_DEPLOYMENT"
}

###########################################
# PART 1: Module Dependency Management
# Uses verification functions:
#   - ver_verify_module() from ver
#   - ver_verify_path() from ver
#   - ver_validate_module() from ver
###########################################

init_module_system() {
    ini_log "Starting module system initialization"

    # Essential verification check from ver module
    if ! ver_essential_check; then
        ini_log "ERROR: Essential system check failed"
        return 1
    fi

    # Initialize directories using ver's ver_verify_path
    if ! init_dirs; then
        ini_log "ERROR: Directory initialization failed"
        return 1
    fi

    # Load and verify modules using ver's validation functions
    if ! load_modules; then
        ini_log "ERROR: Module loading failed"
        return 1
    fi

    ini_log "Module system initialization completed"
    return 0
}

# Initialize directories using ver's ver_verify_path
init_dirs() {
    ini_log "Starting directory initialization"

    # Updated directory paths to use BASE_DIR
    # Removed .log and .tmp as they are handled by ver_essential_check
    local required_dirs=(
        "${BASE_DIR}/lib"
        "${BASE_DIR}/cfg"
    )

    # Using ver_verify_path from ver module
    for dir in "${required_dirs[@]}"; do
        if ! ver_verify_path "$dir" "dir" "true"; then
            ini_log "ERROR: Failed to verify/create directory: $dir"
            return 1
        fi
        chmod 700 "$dir" 2>/dev/null || ini_log "WARNING: Unable to set permissions for $dir"
    done

    return 0
}

# Load modules using ver's validation functions
load_modules() {
    ini_log "Starting optimized module loading"

    if load_modules_from_compiled_cache; then
        return 0
    fi

    local module_loaded=0
    local -a modules=(
        "${BASE_DIR}/lib/core/col"
        "${BASE_DIR}/lib/core/err"
        "${BASE_DIR}/lib/core/lo1"
        "${BASE_DIR}/lib/core/tme"
        "${BASE_DIR}/lib/core/lab"
    )

    declare -A loaded_modules
    
    # Performance optimization: Batch validate all modules first using cache
    ini_log "Batch validating modules for performance" "load_modules" $LOG_PRIORITY_DETAILED
    for module in "${modules[@]}"; do
        local module_name="$(basename "$module")"
        
        # Use cached file existence check
        if ! check_file_cached "$module" "file"; then
            ini_log "ERROR: Module file not accessible: $module_name"
            continue
        fi
        
        ini_log "Module file verified: $module_name" "load_modules" $LOG_PRIORITY_DETAILED
    done

    # Load each module with optimized checks
    for module in "${modules[@]}"; do
        local module_name="$(basename "$module")"

        ini_log "Loading module: $module_name" "load_modules" $LOG_PRIORITY_DETAILED
        
        # Use cached existence check and simplified loading
        if check_file_cached "$module" "file" && [[ -r "$module" ]]; then
            if source "$module"; then
                loaded_modules["$module_name"]=1
                ((module_loaded++))
                ini_log "Successfully loaded module: $module_name"
            else
                ini_log "ERROR: Failed to source module: $module_name"
            fi
        else
            ini_log "ERROR: Module file not accessible: $module_name"
        fi
    done
    
    # Log completion with flow tracking
    ensure_dir_cached "${BASE_DIR}/.log"
    local flow_timestamp
    ini_format_time flow_timestamp '%T'
    echo "INIT_SCRIPT_FLOW: Finished module loading loop in init - ${flow_timestamp}" >> "${BASE_DIR}/.log/init_flow.log"

    ini_log "Loaded $module_loaded modules using optimized batch processing"
    return $((module_loaded > 0 ? 0 : 1))
}

# Setup minimal environment in case of failure
setup_minimal_environment() {
    local base_path="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$HOME/bin"
    export PATH="$PATH:$base_path"
    PS1="(minimal)[\u@\h \W]\$ "

    # Create essential directories using cached creation
    local log_dir="${BASE_DIR}/.log"
    local tmp_dir="${BASE_DIR}/.tmp"
    for dir in "$log_dir" "$tmp_dir"; do
        ensure_dir_cached "$dir"
    done
    
    ini_log "Minimal environment setup completed" "setup_minimal_environment"
}

# Execute initialization
main_ini
RC_STATUS=$?

if [ $RC_STATUS -ne 0 ]; then
    if ini_is_compact_output && ini_terminal_output_enabled; then
        ini_compact_print_failure_summary "$RC_STATUS"
    else
        echo "Initialization failed with status $RC_STATUS. Check logs for details" >&2
    fi
    setup_minimal_environment
    exit 1
fi

# Export only the main initialization function
export -f main_ini
export -f main_ini_interactive
export -f main_ini_deployment

# --- Force timer output and print timing report at the end ---
if type tme_settme &>/dev/null; then
    if ini_is_compact_output; then
        TME_STATUS_TERMINAL_OUTPUT=off tme_settme report on
    else
        tme_settme report on
    fi
fi
if type tme_print_timing_report &>/dev/null; then
    tme_print_timing_report
fi

# --- Total initialization duration ---
if [[ -n "${_INI_START_NS:-}" ]]; then
    ini_now_ns _INI_END_NS
    _INI_ELAPSED_MS=$(( (_INI_END_NS - _INI_START_NS) / 1000000 ))
    if [[ "$_INI_ELAPSED_MS" -ge 1000 ]]; then
        _INI_ELAPSED_S=$(printf '%d.%03d' $((_INI_ELAPSED_MS / 1000)) $((_INI_ELAPSED_MS % 1000)))
        _INI_ELAPSED_DISPLAY="${_INI_ELAPSED_S}s"
    else
        _INI_ELAPSED_DISPLAY="${_INI_ELAPSED_MS}ms"
    fi
    if ini_terminal_output_enabled; then
        if ini_is_compact_output; then
            ini_compact_print_success_summary "${_INI_ELAPSED_DISPLAY}"
        else
            echo " ━ Initialization completed in ${_INI_ELAPSED_DISPLAY}" >&2
            echo >&2
        fi
    fi
    unset _INI_START_NS _INI_END_NS _INI_ELAPSED_MS _INI_ELAPSED_S _INI_ELAPSED_DISPLAY
fi
