#!/bin/bash
#
# -----------------------------------------------------------------------------
# Module: Shared module loader registry
# -----------------------------------------------------------------------------
# Purpose:     Provide a canonical module sourcing entrypoint with process-local
#              loaded-state tracking for bootstrap, DIC, and menu paths.
# File:        lib/core/lab
#
# Description: This module centralizes module sourcing through
#              `lab_source_module`, ensuring a module is sourced once per
#              process and all callers share the same loaded-state map.
# -----------------------------------------------------------------------------

declare -gA LAB_MODULE_SOURCE_STATE

lab_source_module() {
    local module_id="$1"
    local module_path="$2"
    local third_arg="${3:-}"
    local fourth_arg="${4:-}"
    local module_desc="${module_path##*/}"
    local context="lab"

    if [[ -n "$fourth_arg" ]]; then
        module_desc="$third_arg"
        context="$fourth_arg"
    elif [[ -n "$third_arg" ]]; then
        context="$third_arg"
    fi

    if [[ -z "$module_id" || -z "$module_path" ]]; then
        if type lo1_log &>/dev/null; then
            lo1_log "lvl" "Error: Invalid lab_source_module arguments (module_id/module_path required)"
        fi
        return 1
    fi

    declare -gA LAB_MODULE_SOURCE_STATE

    if [[ "${LAB_MODULE_SOURCE_STATE[$module_id]:-0}" == "1" ]]; then
        if type lo1_log &>/dev/null; then
            lo1_log "lvl" "Module already loaded (context=${context}, module_id=${module_id})"
        fi
        return 0
    fi

    if [[ ! -f "$module_path" || ! -r "$module_path" ]]; then
        if type lo1_log &>/dev/null; then
            lo1_log "lvl" "Error: Module file not accessible (context=${context}, module_id=${module_id}, path=${module_path})"
        fi
        return 127
    fi

    if type source_helper &>/dev/null; then
        if ! source_helper "$module_path" "$module_desc"; then
            if type lo1_log &>/dev/null; then
                lo1_log "lvl" "Error: Module source failed (context=${context}, module_id=${module_id}, path=${module_path})"
            fi
            return 2
        fi
    else
        if ! source "$module_path"; then
            return 2
        fi
    fi

    LAB_MODULE_SOURCE_STATE["$module_id"]=1
    if type lo1_log &>/dev/null; then
        lo1_log "lvl" "Module loaded (context=${context}, module_id=${module_id})"
    fi
    return 0
}
