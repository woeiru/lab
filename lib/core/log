#!/bin/bash
# Shared logging primitives for core/bootstrap modules.

declare -gA _LOG_ROTATE_COUNTER

_log_normalize_level() {
    local raw_level="${1:-normal}"
    raw_level="${raw_level,,}"

    case "$raw_level" in
        off|silent|none|0)
            printf '%s\n' "silent"
            ;;
        error|err|fatal|critical|1)
            printf '%s\n' "error"
            ;;
        warn|warning|info|notice|normal|2)
            printf '%s\n' "normal"
            ;;
        verbose|detail|detailed|progress|3)
            printf '%s\n' "verbose"
            ;;
        debug|trace|4)
            printf '%s\n' "debug"
            ;;
        *)
            printf '%s\n' "normal"
            ;;
    esac
}

_log_level_rank() {
    local normalized
    normalized="$(_log_normalize_level "$1")"

    case "$normalized" in
        silent) printf '%s\n' 0 ;;
        error) printf '%s\n' 1 ;;
        normal) printf '%s\n' 2 ;;
        verbose) printf '%s\n' 3 ;;
        debug) printf '%s\n' 4 ;;
        *) printf '%s\n' 2 ;;
    esac
}

_log_effective_level() {
    local subsystem="${1:-}"
    local level="${LAB_LOG_LEVEL:-normal}"
    local override_var=""
    local legacy_toggle_var=""

    if [[ "${MASTER_TERMINAL_VERBOSITY:-on}" != "on" ]]; then
        printf '%s\n' "silent"
        return 0
    fi

    if [[ "${LAB_BOOTSTRAP_MODE:-0}" == "1" ]]; then
        case "${LAB_BOOTSTRAP_VERBOSITY:-compact}" in
            silent)
                printf '%s\n' "silent"
                return 0
                ;;
            verbose)
                printf '%s\n' "verbose"
                return 0
                ;;
            compact|*)
                printf '%s\n' "normal"
                return 0
                ;;
        esac
    fi

    case "${subsystem,,}" in
        ini)
            override_var="LAB_LOG_LEVEL_INI"
            legacy_toggle_var="INI_LOG_TERMINAL_VERBOSITY"
            ;;
        ver)
            override_var="LAB_LOG_LEVEL_VER"
            legacy_toggle_var="VER_LOG_TERMINAL_VERBOSITY"
            ;;
        lo1)
            override_var="LAB_LOG_LEVEL_LO1"
            legacy_toggle_var="LO1_LOG_TERMINAL_VERBOSITY"
            ;;
        err)
            override_var="LAB_LOG_LEVEL_ERR"
            legacy_toggle_var="ERR_TERMINAL_VERBOSITY"
            ;;
        tme)
            override_var="LAB_LOG_LEVEL_TME"
            legacy_toggle_var="TME_TERMINAL_VERBOSITY"
            ;;
        aux)
            override_var="LAB_LOG_LEVEL_AUX"
            ;;
    esac

    if [[ -n "$legacy_toggle_var" && "${!legacy_toggle_var:-on}" != "on" ]]; then
        printf '%s\n' "silent"
        return 0
    fi

    if [[ -n "$override_var" && -n "${!override_var:-}" ]]; then
        level="${!override_var}"
    fi

    _log_normalize_level "$level"
}

_log_level_permits() {
    local required_level="${1:-normal}"
    local subsystem="${2:-}"
    local required_rank
    local effective_level
    local effective_rank

    required_rank="$(_log_level_rank "$required_level")"
    effective_level="$(_log_effective_level "$subsystem")"
    effective_rank="$(_log_level_rank "$effective_level")"

    ((effective_rank >= required_rank))
}

_log_level_semantic() {
    local level="${1:-info}"
    local out_var="${2:-}"
    local resolved_semantic="info"

    case "${level,,}" in
        debug|trace)
            resolved_semantic="dim"
            ;;
        success|ok|done)
            resolved_semantic="success"
            ;;
        warn|warning)
            resolved_semantic="warn"
            ;;
        error|err|fail|failed)
            resolved_semantic="error"
            ;;
        critical|fatal|panic|security)
            resolved_semantic="critical"
            ;;
        business)
            resolved_semantic="business"
            ;;
        audit)
            resolved_semantic="audit"
            ;;
        performance|perf|metric)
            resolved_semantic="perf"
            ;;
        info|notice|normal|verbose|progress)
            resolved_semantic="info"
            ;;
        *)
            resolved_semantic="info"
            ;;
    esac

    if [[ -n "$out_var" ]]; then
        printf -v "$out_var" '%s' "$resolved_semantic"
    else
        printf '%s\n' "$resolved_semantic"
    fi
}

_log_level_glyph() {
    local level="${1:-info}"
    local out_var="${2:-}"
    local resolved_glyph="›"

    case "${level,,}" in
        debug|trace)
            resolved_glyph="·"
            ;;
        success|ok|done)
            resolved_glyph="✓"
            ;;
        warn|warning)
            resolved_glyph="!"
            ;;
        error|err|fail|failed|critical|fatal|panic|security)
            resolved_glyph="✗"
            ;;
        *)
            resolved_glyph="›"
            ;;
    esac

    if [[ -n "$out_var" ]]; then
        printf -v "$out_var" '%s' "$resolved_glyph"
    else
        printf '%s\n' "$resolved_glyph"
    fi
}

_log_color_for_semantic() {
    local semantic="${1:-info}"
    local out_var="${2:-}"
    local color=""

    if type col_get_semantic >/dev/null 2>&1; then
        color="$(col_get_semantic "$semantic")"
    else
        case "${semantic,,}" in
            dim|metadata)
                color="${COL_METADATA:-${AUX_LOG_GREY:-${COL_DIM:-}}}"
                ;;
            info)
                color="${COL_INFO:-${AUX_LOG_INFO:-}}"
                ;;
            success)
                color="${COL_SUCCESS:-}"
                ;;
            warn)
                color="${COL_WARN:-${AUX_LOG_WARN:-}}"
                ;;
            error)
                color="${COL_ERROR:-${AUX_LOG_ERROR:-}}"
                ;;
            critical|security)
                color="${COL_CRITICAL:-${AUX_LOG_SECURITY:-}}"
                ;;
            business)
                color="${COL_BUSINESS:-${AUX_LOG_BUSINESS:-}}"
                ;;
            audit)
                color="${COL_AUDIT:-${AUX_LOG_AUDIT:-}}"
                ;;
            perf|performance)
                color="${COL_PERFORMANCE:-${AUX_LOG_PERFORMANCE:-}}"
                ;;
            *)
                color=""
                ;;
        esac
    fi

    if [[ -n "$out_var" ]]; then
        printf -v "$out_var" '%s' "$color"
    else
        printf '%s\n' "$color"
    fi
}

_log_depth_prefix() {
    local depth="${1:-0}"
    local out_var="${2:-}"
    local indent=""
    local i

    [[ "$depth" =~ ^[0-9]+$ ]] || depth=0

    case "$depth" in
        0)
            indent="    "
            ;;
        1)
            indent="      "
            ;;
        *)
            indent="      "
            for ((i=2; i<=depth; i++)); do
                indent="  $indent"
            done
            ;;
    esac

    indent="${indent}└─"

    if [[ -n "$out_var" ]]; then
        printf -v "$out_var" '%s' "$indent"
    else
        printf '%s\n' "$indent"
    fi
}

_log_report_header() {
    local report_type="$1"
    local title="$2"
    local section="${3:-}"
    local out_var="${4:-}"
    local semantic="metadata"
    local color=""
    local reset="${COL_RESET:-${AUX_LOG_NC:-}}"
    local rendered

    if [[ -z "$report_type" || -z "$title" ]]; then
        return 1
    fi

    case "${report_type,,}" in
        err|error)
            semantic="error"
            ;;
        tme|timing)
            semantic="info"
            ;;
        *)
            semantic="metadata"
            ;;
    esac

    if [[ -n "$section" ]]; then
        rendered="-- ${section} --"
    else
        rendered="== ${title} =="
    fi

    _log_color_for_semantic "$semantic" color
    if [[ -n "$color" && -n "$reset" ]]; then
        rendered="${color}${rendered}${reset}"
    fi

    if [[ -n "$out_var" ]]; then
        printf -v "$out_var" '%s' "$rendered"
    else
        printf '%s\n' "$rendered"
    fi
}

_log_format_terminal() {
    local subsystem="$1"
    local level="$2"
    local message="$3"
    local component="${4:-}"
    local depth="${5:-0}"
    local out_var="${6:-}"
    local format="${LAB_LOG_FORMAT:-verbose}"
    local semantic
    local glyph
    local normalized_level
    local glyph_color=""
    local message_color=""
    local timestamp_color=""
    local component_color=""
    local depth_color=""
    local reset=""
    local timestamp=""
    local timestamp_segment=""
    local glyph_segment=""
    local component_segment=""
    local depth_segment=""
    local message_segment=""
    local depth_prefix=""
    local rendered=""

    if [[ -z "$subsystem" || -z "$level" || -z "$message" ]]; then
        return 1
    fi

    format="${format,,}"
    case "$format" in
        compact|verbose)
            ;;
        *)
            format="verbose"
            ;;
    esac

    _log_level_semantic "$level" semantic
    _log_level_glyph "$level" glyph
    normalized_level="$(_log_normalize_level "$level")"

    if type col_get_semantic >/dev/null 2>&1 || [[ -n "${COL_RESET:-}" || -n "${AUX_LOG_NC:-}" ]]; then
        _log_color_for_semantic "$semantic" glyph_color
        _log_color_for_semantic "dim" timestamp_color
        _log_color_for_semantic "dim" component_color
        reset="${COL_RESET:-${AUX_LOG_NC:-}}"
    fi

    if [[ "$semantic" == "warn" || "$semantic" == "error" || "$semantic" == "critical" ]]; then
        _log_color_for_semantic "$semantic" message_color
    fi

    if [[ -n "$message_color" && -n "$reset" ]]; then
        message_segment="${message_color}${message}${reset}"
    else
        message_segment="$message"
    fi

    if [[ -n "$glyph_color" && -n "$reset" ]]; then
        glyph_segment="${glyph_color}${glyph}${reset}"
    else
        glyph_segment="$glyph"
    fi

    if [[ "$normalized_level" == "debug" && -n "$component" ]]; then
        if [[ -n "$component_color" && -n "$reset" ]]; then
            component_segment="${component_color}[${component}]${reset}"
        else
            component_segment="[${component}]"
        fi
    fi

    if [[ "$format" == "compact" ]]; then
        rendered="$glyph_segment"
        [[ -n "$component_segment" ]] && rendered+=" $component_segment"
        rendered+=" $message_segment"
    else
        printf -v timestamp '%(%H:%M:%S)T' -1
        if [[ -n "$timestamp_color" && -n "$reset" ]]; then
            timestamp_segment="${timestamp_color}[${timestamp}]${reset}"
        else
            timestamp_segment="[${timestamp}]"
        fi

        if [[ "${subsystem,,}" == "lo1" ]]; then
            _log_depth_prefix "$depth" depth_prefix
            if type col_get_depth_color >/dev/null 2>&1; then
                depth_color="$(col_get_depth_color "$depth")"
            fi

            if [[ -n "$depth_color" && -n "$reset" ]]; then
                depth_segment="${depth_color}${depth_prefix}${reset}"
            else
                depth_segment="$depth_prefix"
            fi
        fi

        rendered="$timestamp_segment $glyph_segment"
        [[ -n "$component_segment" ]] && rendered+=" $component_segment"
        [[ -n "$depth_segment" ]] && rendered+=" $depth_segment"
        rendered+=" $message_segment"
    fi

    if [[ -n "$out_var" ]]; then
        printf -v "$out_var" '%s' "$rendered"
    else
        printf '%s\n' "$rendered"
    fi

    return 0
}

_log_strip_ansi() {
    local input="${1:-}"
    local out_var="${2:-}"
    local clean="$input"
    local ansi_regex=$'\033\\[[0-9;]*[[:alpha:]]'

    while [[ "$clean" =~ $ansi_regex ]]; do
        clean="${clean/${BASH_REMATCH[0]}/}"
    done

    if [[ -n "$out_var" ]]; then
        printf -v "$out_var" '%s' "$clean"
    else
        printf '%s\n' "$clean"
    fi
}

_log_rotate_if_needed() {
    local target_file="$1"
    local max_size="${LAB_LOG_MAX_SIZE:-10485760}"
    local check_every="${LAB_LOG_ROTATE_CHECK_EVERY:-100}"
    local counter
    local file_size
    local rotate_decl

    [[ -z "$target_file" ]] && return 1
    [[ -f "$target_file" ]] || return 0
    [[ "$max_size" =~ ^[0-9]+$ ]] || max_size=10485760
    [[ "$check_every" =~ ^[0-9]+$ ]] || check_every=100
    ((check_every > 0)) || check_every=100

    rotate_decl="$(declare -p _LOG_ROTATE_COUNTER 2>/dev/null || true)"
    if [[ "$rotate_decl" != declare\ -A* ]]; then
        unset _LOG_ROTATE_COUNTER
        declare -gA _LOG_ROTATE_COUNTER
    fi

    counter="${_LOG_ROTATE_COUNTER[$target_file]:-0}"
    ((counter++))
    _LOG_ROTATE_COUNTER[$target_file]="$counter"

    if ((counter % check_every != 0)); then
        return 0
    fi

    if ! command -v stat >/dev/null 2>&1; then
        return 0
    fi

    file_size="$(stat -c '%s' "$target_file" 2>/dev/null)" || return 2
    [[ "$file_size" =~ ^[0-9]+$ ]] || return 2

    if ((file_size < max_size)); then
        return 0
    fi

    rm -f "${target_file}.1" 2>/dev/null
    mv "$target_file" "${target_file}.1" 2>/dev/null || return 2
    : > "$target_file" || return 2

    return 0
}

_log_write() {
    local component="$1"
    local level="$2"
    local message="$3"
    local target_file="$4"
    local source="${5:-${FUNCNAME[1]:-main}}"
    local target_dir
    local timestamp
    local clean_message
    local normalized_level

    if [[ -z "$component" || -z "$level" || -z "$message" || -z "$target_file" ]]; then
        return 1
    fi

    target_dir="${target_file%/*}"
    [[ "$target_dir" == "$target_file" ]] && target_dir="."

    if [[ ! -d "$target_dir" ]]; then
        mkdir -p "$target_dir" 2>/dev/null || return 2
    fi

    _log_strip_ansi "$message" clean_message
    normalized_level="$(_log_normalize_level "$level")"
    printf -v timestamp '%(%Y-%m-%d %H:%M:%S)T' -1

    _log_rotate_if_needed "$target_file" || return 2
    printf '[%s] %s - [%s] [%s] %s\n' "${component^^}" "$timestamp" "$source" "$normalized_level" "$clean_message" >> "$target_file" || return 2
    return 0
}

export -f _log_normalize_level
export -f _log_level_rank
export -f _log_effective_level
export -f _log_level_permits
export -f _log_level_semantic
export -f _log_level_glyph
export -f _log_color_for_semantic
export -f _log_depth_prefix
export -f _log_report_header
export -f _log_format_terminal
export -f _log_strip_ansi
export -f _log_rotate_if_needed
export -f _log_write
