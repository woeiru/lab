        print(f"  Cache Age:  {age_color}{age_str}{RESET}")

    rate_limits = acct.get("rateLimitResetTimes", {})

    if quota:
        print(f"  {TITLE}Antigravity Quota{RESET}")
        print(f"  {'-' * QUOTA_TABLE_WIDTH}")
        header = quota_row("Family", "Remaining", "Reset", "Mdl")
