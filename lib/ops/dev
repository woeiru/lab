# Shows Gemini CLI quota dashboard with per-model remaining fractions and reset times
# opencode quota
# -x (execute) | --watch <seconds>
dev_oqu() {
    # Technical Description:
    #   Reads the antigravity-accounts.json to display per-account Gemini CLI quota status
    #   Shows filtered model list with remaining fractions and reset countdowns
    #   Supports --watch mode for periodic dashboard refresh at a given interval
    # Dependencies:
    #   - python3 with json modules for data processing
    #   - antigravity-accounts.json from the antigravity auth plugin
    # Arguments:
    #   $1: -x for one-shot execution, or --watch for periodic polling mode
    #   $2: refresh interval in seconds (required when using --watch)

    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        aux_tec
        return 0
    fi

    local watch_mode=0
    local watch_interval=0

    if [ "$1" = "--watch" ]; then
        if [ $# -ne 2 ]; then
            aux_err "Watch mode requires an interval in seconds" "component=dev,operation=opencode_quota"
            aux_use
            return 1
        fi
        if ! [[ "$2" =~ ^[0-9]+$ ]] || [ "$2" -lt 1 ]; then
            aux_err "Watch interval must be a positive integer" "component=dev,operation=opencode_quota,value=$2"
            return 1
        fi
        watch_mode=1
        watch_interval="$2"
    elif [ $# -ne 1 ] || [ "$1" != "-x" ]; then
        aux_use
        return 1
    fi

    if ! aux_chk "command" "python3"; then
        aux_err "python3 command not found" "component=dev,operation=opencode_quota"
        return 127
    fi

    local accounts_path
    accounts_path=$(_dev_get_antigravity_accounts_path)
    if [ $? -ne 0 ]; then
        aux_err "Antigravity accounts file not found" "component=dev,operation=opencode_quota,expected_path=${HOME}/.config/opencode/antigravity-accounts.json"
        return 2
    fi

    _dev_apply_account_denylist >/dev/null 2>&1

    if [ "$watch_mode" -eq 1 ]; then
        aux_info "Starting quota watch (interval: ${watch_interval}s, Ctrl+C to stop)" "component=dev,operation=opencode_quota"
        trap 'return 0' INT
        while true; do
            _dev_apply_account_denylist >/dev/null 2>&1
            clear
            _dev_oqu_render "$accounts_path"
            sleep "$watch_interval"
        done
    else
        aux_info "Rendering quota dashboard" "component=dev,operation=opencode_quota"
        _dev_oqu_render "$accounts_path"
    fi

    return 0
}

