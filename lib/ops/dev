_dev_oqu_render() {
    local accounts_path="$1"

    python3 - "$accounts_path" <<'PY'
import json
import re
import sys
from datetime import datetime, timezone

accounts_path = sys.argv[1]

with open(accounts_path, "r") as f:
    data = json.load(f)

accounts = data.get("accounts", [])

BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"

OQU_DASHBOARD_WIDTH = 64
OQU_TABLE_WIDTH = 64
OQU_COL_WIDTHS = (22, 15, 25)
ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")

def visible_len(text):
    return len(ANSI_RE.sub("", text))

def ansi_trim(text, width):
    if width <= 0:
        return ""

    out = []
    visible = 0
    i = 0
    while i < len(text) and visible < width:
        if text[i] == "\x1b":
            match = ANSI_RE.match(text, i)
            if match:
                out.append(match.group(0))
                i = match.end()
                continue
        out.append(text[i])
        visible += 1
        i += 1

    truncated = i < len(text)
    rendered = "".join(out)
    if truncated and "\x1b[" in rendered and not rendered.endswith(RESET):
        rendered += RESET
    return rendered

def ansi_ljust(text, width):
    trimmed = ansi_trim(text, width)
    pad = width - visible_len(trimmed)
    if pad > 0:
        return trimmed + (" " * pad)
    return trimmed

def oqu_row(model, remaining, reset):
    model_cell = ansi_ljust(str(model), OQU_COL_WIDTHS[0])
    remaining_cell = ansi_ljust(str(remaining), OQU_COL_WIDTHS[1])
