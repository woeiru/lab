#!/bin/bash

# Define directory and file variables
DIR_FUN="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
FILE_FUN=$(basename "$BASH_SOURCE")
BASE_FUN="${FILE_FUN%.*}"
FILEPATH_FUN="${DIR_FUN}/${FILE_FUN}"
CONFIG_FUN="${SITE_CONFIG_FILE}"

# Dynamically create variables based on the base name
eval "FILEPATH_${BASE_FUN}=\$FILEPATH_FUN"
eval "FILE_${BASE_FUN}=\$FILE_FUN"
eval "BASE_${BASE_FUN}=\$BASE_FUN"
eval "CONFIG_${BASE_FUN}=\$CONFIG_FUN"

_dev_get_opencode_db_path() {
    local db_path
    db_path=$(opencode db path 2>/dev/null) || return 1

    if ! aux_val "$db_path" "file_exists"; then
        return 1
    fi

    echo "$db_path"
}

# Shows a complete OpenCode session overview across all scopes
# opencode sessions overview
# -x (execute)
dev_osv() {
    # Technical Description:
    #   Reads the OpenCode SQLite database and prints all known sessions across projects
    #   Includes a short session suffix column to support quick session targeting workflows
    #   Joins session and project metadata to show scope/worktree context for each entry
    #   Sorts by last update time so the most recent sessions appear first
    # Dependencies:
    #   - opencode CLI for resolving the active database path
    #   - python3 with sqlite3 module for read-only query execution
    #   - column command (optional) for aligned table formatting
    # Arguments:
    #   $1: -x - explicit execution flag required for consistency

    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        aux_tec
        return 0
    fi

    if [ $# -ne 1 ] || [ "$1" != "-x" ]; then
        aux_use
        return 1
    fi

    if ! aux_chk "command" "opencode"; then
        aux_err "opencode command not found"
        return 127
    fi

    if ! aux_chk "command" "python3"; then
        aux_err "python3 command not found"
        return 127
    fi

    local db_path
    db_path=$(_dev_get_opencode_db_path)
    if [ $? -ne 0 ]; then
        aux_err "Could not resolve OpenCode database path"
        return 2
    fi

    aux_info "Collecting OpenCode sessions overview" "component=dev,operation=opencode_session_overview,db_path=$db_path"

    local output
    output=$(python3 - "$db_path" <<'PY'
import sqlite3
import sys

db_path = sys.argv[1]
conn = sqlite3.connect(db_path)
cur = conn.cursor()

query = """
SELECT
  substr(s.id, length(s.id) - 2, 3) AS suffix,
  s.id,
  COALESCE(p.worktree, '(missing_project)') AS project_root,
  s.directory,
  s.title,
  datetime(s.time_updated / 1000, 'unixepoch', 'localtime') AS updated_local
FROM session s
LEFT JOIN project p ON p.id = s.project_id
ORDER BY s.time_updated DESC;
"""

cur.execute(query)
rows = cur.fetchall()
print("suffix\tid\tproject_root\tdirectory\ttitle\tupdated_local")
for row in rows:
    normalized = []
    for value in row:
        if value is None:
            normalized.append("")
        else:
            text = str(value).replace("\t", " ").replace("\n", " ")
            normalized.append(text)
    print("\t".join(normalized))
PY
)
    if [ $? -ne 0 ]; then
        aux_err "Failed to read OpenCode sessions from database"
        return 2
    fi

    if aux_chk "command" "column"; then
        echo "$output" | column -t -s $'\t'
    else
        echo "$output"
    fi

    return 0
}

# Reassigns a single OpenCode session to a target scope using an ID suffix
# opencode session move scope
# <scope_path> <session_id_suffix>
dev_omi() {
    # Technical Description:
    #   Locates a session by matching the trailing ID suffix provided by the caller
    #   Resolves the target project scope from the OpenCode project table using worktree path
    #   Updates session project_id and directory to move the session into the target scope
    #   Rejects ambiguous suffixes and missing scope mappings to avoid accidental reassignment
    # Dependencies:
    #   - opencode CLI for database path resolution
    #   - python3 with sqlite3 module for transactional updates
    #   - Existing OpenCode project record for the target scope path
    # Arguments:
    #   $1: scope_path - target worktree path already known to OpenCode
    #   $2: session_id_suffix - last 3+ alphanumeric characters of the session ID

    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        aux_tec
        return 0
    fi

    if [ $# -ne 2 ]; then
        aux_use
        return 1
    fi

    if ! aux_val "$1" "not_empty"; then
        aux_err "Scope path cannot be empty"
        aux_use
        return 1
    fi

    if ! aux_val "$1" "dir_exists"; then
        aux_err "Scope path does not exist" "component=dev,operation=opencode_move_session,scope_path=$1"
        return 1
    fi

    if ! aux_val "$2" "alphanum"; then
        aux_err "Session suffix must be alphanumeric" "component=dev,operation=opencode_move_session,suffix=$2"
        aux_use
        return 1
    fi

    if ! aux_val "$2" "min_length" "3"; then
        aux_err "Session suffix must be at least 3 characters"
        aux_use
        return 1
    fi

    if ! aux_chk "command" "opencode"; then
        aux_err "opencode command not found"
        return 127
    fi

    if ! aux_chk "command" "python3"; then
        aux_err "python3 command not found"
        return 127
    fi

    local scope_path="$1"
    local suffix="$2"
    local db_path
    db_path=$(_dev_get_opencode_db_path)
    if [ $? -ne 0 ]; then
        aux_err "Could not resolve OpenCode database path"
        return 2
    fi

    aux_warn "Close active OpenCode clients before moving sessions" "component=dev,operation=opencode_move_session"

    local py_output
    py_output=$(python3 - "$db_path" "$suffix" "$scope_path" <<'PY'
import sqlite3
import sys

db_path, suffix, scope_path = sys.argv[1], sys.argv[2], sys.argv[3]
conn = sqlite3.connect(db_path)
cur = conn.cursor()

cur.execute(
    "SELECT id, directory, title FROM session WHERE id LIKE ? ORDER BY time_updated DESC",
    ("%" + suffix,),
)
matches = cur.fetchall()

if len(matches) == 0:
    print("NO_MATCH")
    sys.exit(11)

if len(matches) > 1:
    print("AMBIGUOUS")
    for session_id, directory, title in matches:
        title = (title or "").replace("\t", " ").replace("\n", " ")
        directory = (directory or "").replace("\t", " ").replace("\n", " ")
        print(f"CANDIDATE\t{session_id}\t{directory}\t{title}")
    sys.exit(12)

target_session_id = matches[0][0]

cur.execute("SELECT id FROM project WHERE worktree = ? LIMIT 1", (scope_path,))
project_row = cur.fetchone()
if project_row is None:
    print("MISSING_SCOPE")
    sys.exit(13)

target_project_id = project_row[0]
cur.execute(
    "UPDATE session SET project_id = ?, directory = ? WHERE id = ?",
    (target_project_id, scope_path, target_session_id),
)
conn.commit()

print(f"MOVED\t{target_session_id}\t{target_project_id}\t{scope_path}")
sys.exit(0)
PY
)
    local py_status=$?

    case "$py_status" in
        0)
            local moved_session_id
            moved_session_id=$(echo "$py_output" | awk -F'\t' '/^MOVED\t/ {print $2}')
            aux_info "Session moved successfully" "component=dev,operation=opencode_move_session,session_id=$moved_session_id,scope_path=$scope_path"
            echo "$py_output"
            return 0
            ;;
        11)
            aux_err "No session found for suffix" "component=dev,operation=opencode_move_session,suffix=$suffix"
            return 1
            ;;
        12)
            aux_err "Session suffix is ambiguous; use a longer suffix"
            echo "$py_output" | awk -F'\t' '/^CANDIDATE\t/ {printf "candidate id=%s directory=%s title=%s\n", $2, $3, $4}'
            return 1
            ;;
        13)
            aux_err "Target scope is not registered in OpenCode" "component=dev,operation=opencode_move_session,scope_path=$scope_path"
            aux_info "Open OpenCode once in that path first to register the project" "scope_path=$scope_path"
            return 1
            ;;
        *)
            aux_err "Failed to move session due to database error" "component=dev,operation=opencode_move_session,python_exit=$py_status"
            return 2
            ;;
    esac
}

_dev_get_antigravity_accounts_path() {
    local accounts_path="${HOME}/.config/opencode/antigravity-accounts.json"

    if [[ ! -f "$accounts_path" ]]; then
        return 1
    fi

    echo "$accounts_path"
}

_dev_olb_render() {
    local accounts_path="$1"
    local db_path="$2"

    python3 - "$accounts_path" "$db_path" <<'PY'
import json
import sys
import os
from datetime import datetime, timezone

accounts_path = sys.argv[1]
db_path = sys.argv[2] if len(sys.argv) > 2 and sys.argv[2] else None

with open(accounts_path, "r") as f:
    data = json.load(f)

accounts = data.get("accounts", [])
active_index = data.get("activeIndex", 0)
active_by_family = data.get("activeIndexByFamily", {})

BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
CYAN = "\033[36m"
MAGENTA = "\033[35m"

def bar(fraction, width=10):
    try:
        fraction = float(fraction)
    except (TypeError, ValueError):
        fraction = 0.0
    fraction = max(0.0, min(1.0, fraction))
    filled = int(fraction * width)
    empty = width - filled
    if fraction >= 0.7:
        color = GREEN
    elif fraction >= 0.3:
        color = YELLOW
    else:
        color = RED
    return f"{color}{'█' * filled}{'░' * empty}{RESET}"

def fmt_ts(epoch_ms):
    if not epoch_ms:
        return "n/a"
    return datetime.fromtimestamp(epoch_ms / 1000).strftime("%Y-%m-%d %H:%M:%S")

def fmt_reset(iso_str):
    if not iso_str:
        return "n/a"
    try:
        reset_dt = datetime.fromisoformat(iso_str.replace("Z", "+00:00"))
        now = datetime.now(timezone.utc)
        total_sec = int((reset_dt - now).total_seconds())
        if total_sec <= 0:
            return f"{iso_str[:19]} {RED}(expired){RESET}"
        hours, remainder = divmod(total_sec, 3600)
        minutes = remainder // 60
        return f"{iso_str[:19]} {DIM}(in {hours}h{minutes:02d}m){RESET}"
    except Exception:
        return iso_str[:19]

def fmt_tokens(n):
    if n is None or n == 0:
        return "0"
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.1f}K"
    return str(int(n))

def to_fraction(value):
    try:
        fraction = float(value)
    except (TypeError, ValueError):
        fraction = 0.0
    return max(0.0, min(1.0, fraction))

now_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
print(f"\n{BOLD}ACCOUNT LOAD BALANCING + QUOTA{RESET}  {DIM}{now_str}{RESET}")
print("=" * 68)

if not accounts:
    print(f"\n  {YELLOW}No accounts configured in antigravity-accounts.json{RESET}\n")
    sys.exit(0)

for i, acct in enumerate(accounts):
    email = acct.get("email", "(unknown)")
    enabled = acct.get("enabled", False)
    last_used = acct.get("lastUsed")
    quota = acct.get("cachedQuota", {})
    cli_quota = acct.get("cachedGeminiCliQuota") or acct.get("geminiCliQuota") or {}

    is_default_active = (i == active_index)
    active_families = [fam for fam, idx in active_by_family.items() if idx == i]

    status_tag = f"{GREEN}ENABLED{RESET}" if enabled else f"{RED}DISABLED{RESET}"
    active_tag = f"  {MAGENTA}< DEFAULT ACTIVE{RESET}" if is_default_active else ""

    print(f"\n{BOLD}Account {i + 1}: {email}{RESET}  [{status_tag}]{active_tag}")
    print(f"  Last Used:  {fmt_ts(last_used)}")

    cached_at = acct.get("cachedQuotaUpdatedAt")
    if cached_at:
        age_sec = (datetime.now(timezone.utc) - datetime.fromtimestamp(cached_at / 1000, tz=timezone.utc)).total_seconds()
        if age_sec < 60:
            age_str = f"{int(age_sec)}s ago"
        elif age_sec < 3600:
            age_str = f"{int(age_sec / 60)}m ago"
        else:
            age_str = f"{age_sec / 3600:.1f}h ago"
        age_color = GREEN if age_sec < 300 else (YELLOW if age_sec < 1800 else RED)
        print(f"  Cache Age:  {age_color}{age_str}{RESET}")

    if active_families:
        print(f"  Active for: {CYAN}{', '.join(sorted(active_families))}{RESET}")

    rate_limits = acct.get("rateLimitResetTimes", {})

    if quota:
        print(f"  {BOLD}Antigravity Quota{RESET}")
        print(f"  {'-' * 64}")
        print(f"  {BOLD}{'Family':<16} {'Remaining':<22} {'Reset':<28} {'Mdl':>3}{RESET}")
        print(f"  {'-' * 64}")
        now_utc = datetime.now(timezone.utc)
        for family, info in sorted(quota.items()):
            remaining = to_fraction(info.get("remainingFraction", 0))

            reset_time = info.get("resetTime", "")
            model_count = info.get("modelCount", 0)

            is_reset_passed = False
            is_rl_active = False
            override_reasons = []
            if reset_time:
                try:
                    reset_dt = datetime.fromisoformat(reset_time.replace("Z", "+00:00"))
                    if (reset_dt - now_utc).total_seconds() <= 0:
                        is_reset_passed = True
                        override_reasons.append("resetTime")
                except Exception:
                    pass

            # Check rate-limit status for this family
            rl_flag = ""
            rl_ts = rate_limits.get(family)
            if rl_ts:
                rl_dt = datetime.fromtimestamp(rl_ts / 1000, tz=timezone.utc)
                rl_diff = (rl_dt - now_utc).total_seconds()
                if rl_diff > 0:
                    is_rl_active = True
                    rl_h, rl_rem = divmod(int(rl_diff), 3600)
                    rl_m = rl_rem // 60
                    rl_flag = f" {RED}RL:{rl_h}h{rl_m:02d}m{RESET}"
                else:
                    is_reset_passed = True
                    override_reasons.append("rateLimit")
                    rl_flag = f" {GREEN}RL:ok{RESET}"

            if is_reset_passed and remaining < 1.0:
                remaining = 1.0
                if override_reasons:
                    reason = "+".join(sorted(set(override_reasons)))
                    rl_flag += f" {YELLOW}(OVERRIDE:{reason}){RESET}"
                else:
                    rl_flag += f" {YELLOW}(OVERRIDE){RESET}"

            if is_rl_active and remaining > 0.0:
                remaining = 0.0
                rl_flag += f" {YELLOW}(EFFECTIVE:0%){RESET}"

            pct = f"{int(remaining * 100):>3}%"

            print(f"  {family:<16} {bar(remaining)} {pct}   {fmt_reset(reset_time):<28} {model_count:>3}{rl_flag}")
        print(f"  {'-' * 64}")
    else:
        print(f"  {BOLD}Antigravity Quota{RESET}")
        if cached_at:
            print(f"  {DIM}(no quota data returned in last check){RESET}")
        else:
            print(f"  {DIM}(no quota data cached yet){RESET}")

    cli_models = []
    cli_error = None
    if isinstance(cli_quota, dict):
        models_candidate = cli_quota.get("models", [])
        if isinstance(models_candidate, list):
            cli_models = models_candidate
        cli_error = cli_quota.get("error")
    elif isinstance(cli_quota, list):
        cli_models = cli_quota

    ALLOWED_CLI_MODELS = {
        "gemini-3.1-pro-preview",
        "gemini-3.1-pro-preview_vertex",
        "gemini-3-pro-preview",
        "gemini-3-pro-preview_vertex",
        "gemini-3-flash-preview",
        "gemini-3-flash-preview_vertex"
    }

    if cli_models:
        cli_models = [m for m in cli_models if isinstance(m, dict) and str(m.get("modelId", "")) in ALLOWED_CLI_MODELS]

    print(f"  {BOLD}Gemini CLI Quota{RESET}")
    if cli_models:
        print(f"  {'-' * 64}")
        print(f"  {BOLD}{'Model':<29} {'Remaining':<22} {'Reset':<28}{RESET}")
        print(f"  {'-' * 64}")
        for model in cli_models:
            model_id = str(model.get("modelId", "?"))
            remaining = to_fraction(model.get("remainingFraction", 0))
            reset_time = model.get("resetTime", "")
            pct = f"{int(remaining * 100):>3}%"
            print(f"  {model_id[:29]:<29} {bar(remaining)} {pct}   {fmt_reset(reset_time):<28}")
        print(f"  {'-' * 64}")
    else:
        if cli_error:
            print(f"  {DIM}({cli_error}){RESET}")
        elif cached_at and not cli_models:
            print(f"  {DIM}(no Gemini CLI quota returned in last check){RESET}")
        else:
            print(f"  {DIM}(no Gemini CLI quota cached yet){RESET}")

print(f"\n{BOLD}ROUTING{RESET}")
print("-" * 68)
if active_index < len(accounts):
    default_email = accounts[active_index]["email"]
else:
    default_email = "(none)"
print(f"  Default:        {CYAN}{default_email}{RESET}  (account {active_index + 1})")
for family, idx in sorted(active_by_family.items()):
    fam_email = accounts[idx]["email"] if idx < len(accounts) else "(none)"
    print(f"  {family + ':':<16} {CYAN}{fam_email}{RESET}  (account {idx + 1})")

if db_path and os.path.isfile(db_path):
    import sqlite3
    try:
        conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
        cur = conn.cursor()
        cur.execute('''
            SELECT
                json_extract(data, "$.providerID") as provider,
                json_extract(data, "$.modelID") as model,
                COUNT(*) as cnt,
                SUM(COALESCE(json_extract(data, "$.tokens.input"), 0)) as total_input,
                SUM(COALESCE(json_extract(data, "$.tokens.output"), 0)) as total_output,
                SUM(COALESCE(json_extract(data, "$.tokens.cache.read"), 0)) as cache_read
            FROM message
            WHERE json_extract(data, "$.role") = 'assistant'
              AND json_extract(data, "$.providerID") IS NOT NULL
              AND json_extract(data, "$.modelID") IS NOT NULL
            GROUP BY provider, model
            ORDER BY cnt DESC
        ''')
        rows = cur.fetchall()
        conn.close()
        if rows:
            print(f"\n{BOLD}MODEL USAGE{RESET}  {DIM}(all accounts, all providers){RESET}")
            print("-" * 68)
            print(f"  {BOLD}{'Model':<36} {'Prov':>6} {'Msgs':>5} {'Input':>8} {'Output':>8}{RESET}")
            print(f"  {'-' * 64}")
            for provider, model, cnt, inp, out, cache in rows:
                prov_short = (provider or "?")[:6]
                print(f"  {(model or '?'):<36} {prov_short:>6} {cnt:>5} {fmt_tokens(inp):>8} {fmt_tokens(out):>8}")
            print(f"  {'-' * 64}")
    except Exception as e:
        print(f"\n  {YELLOW}Could not read usage data: {e}{RESET}")

print()
PY
}

# Shows account load balancing dashboard with Antigravity and Gemini CLI quota data
# opencode load balance
# -x (execute) | --watch <seconds>
dev_olb() {
    # Technical Description:
    #   Reads the antigravity-accounts.json to display per-account quota status
    #   Shows Antigravity family quotas and Gemini CLI model quotas when cached
    #   Shows remaining capacity fraction, reset times, and routing per model family
    #   Queries the OpenCode SQLite database for aggregate model usage statistics
    #   Supports --watch mode for periodic dashboard refresh at a given interval
    # Dependencies:
    #   - python3 with json and sqlite3 modules for data processing
    #   - opencode CLI for database path resolution
    #   - antigravity-accounts.json from the antigravity auth plugin
    # Arguments:
    #   $1: -x for one-shot execution, or --watch for periodic polling mode
    #   $2: refresh interval in seconds (required when using --watch)

    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        aux_tec
        return 0
    fi

    local watch_mode=0
    local watch_interval=0

    if [ "$1" = "--watch" ]; then
        if [ $# -ne 2 ]; then
            aux_err "Watch mode requires an interval in seconds" "component=dev,operation=opencode_load_balance"
            aux_use
            return 1
        fi
        if ! [[ "$2" =~ ^[0-9]+$ ]] || [ "$2" -lt 1 ]; then
            aux_err "Watch interval must be a positive integer" "component=dev,operation=opencode_load_balance,value=$2"
            return 1
        fi
        watch_mode=1
        watch_interval="$2"
    elif [ $# -ne 1 ] || [ "$1" != "-x" ]; then
        aux_use
        return 1
    fi

    if ! aux_chk "command" "python3"; then
        aux_err "python3 command not found" "component=dev,operation=opencode_load_balance"
        return 127
    fi

    local accounts_path
    accounts_path=$(_dev_get_antigravity_accounts_path)
    if [ $? -ne 0 ]; then
        aux_err "Antigravity accounts file not found" "component=dev,operation=opencode_load_balance,expected_path=${HOME}/.config/opencode/antigravity-accounts.json"
        return 2
    fi

    local db_path=""
    if aux_chk "command" "opencode"; then
        db_path=$(_dev_get_opencode_db_path 2>/dev/null) || true
        if [ -n "$db_path" ]; then
            aux_dbg "Using OpenCode database for usage stats" "component=dev,operation=opencode_load_balance,db_path=$db_path"
        else
            aux_warn "Could not resolve OpenCode database; usage stats unavailable" "component=dev,operation=opencode_load_balance"
        fi
    fi

    if [ "$watch_mode" -eq 1 ]; then
        aux_info "Starting load balance watch (interval: ${watch_interval}s, Ctrl+C to stop)" "component=dev,operation=opencode_load_balance"
        trap 'return 0' INT
        while true; do
            clear
            _dev_olb_render "$accounts_path" "$db_path"
            sleep "$watch_interval"
        done
    else
        aux_info "Rendering load balance dashboard" "component=dev,operation=opencode_load_balance"
        _dev_olb_render "$accounts_path" "$db_path"
    fi

    return 0
}

# Switches the active Antigravity account for a model family
# opencode account switch
# <family> <account_number>
dev_oas() {
    # Technical Description:
    #   Modifies the activeIndexByFamily mapping in antigravity-accounts.json
    #   Routes a specific model family to a chosen account for load distribution
    #   Validates the account number against available accounts and family name
    #   Creates a timestamped backup of the accounts file before any modification
    # Dependencies:
    #   - python3 with json module for safe JSON read-modify-write
    #   - antigravity-accounts.json from the antigravity auth plugin
    # Arguments:
    #   $1: family - model family name (e.g. claude, gemini, gemini-pro, gemini-flash)
    #   $2: account_number - 1-based account number to activate for the family

    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        aux_tec
        return 0
    fi

    if [ $# -ne 2 ]; then
        aux_use
        return 1
    fi

    if ! aux_val "$1" "not_empty"; then
        aux_err "Family name cannot be empty" "component=dev,operation=opencode_account_switch"
        aux_use
        return 1
    fi

    if ! [[ "$2" =~ ^[0-9]+$ ]] || [ "$2" -lt 1 ]; then
        aux_err "Account number must be a positive integer (1-based)" "component=dev,operation=opencode_account_switch,value=$2"
        aux_use
        return 1
    fi

    if ! aux_chk "command" "python3"; then
        aux_err "python3 command not found" "component=dev,operation=opencode_account_switch"
        return 127
    fi

    local accounts_path
    accounts_path=$(_dev_get_antigravity_accounts_path)
    if [ $? -ne 0 ]; then
        aux_err "Antigravity accounts file not found" "component=dev,operation=opencode_account_switch,expected_path=${HOME}/.config/opencode/antigravity-accounts.json"
        return 2
    fi

    local family="$1"
    local account_num="$2"

    aux_info "Switching account for family" "component=dev,operation=opencode_account_switch,family=$family,account=$account_num"

    local py_output
    py_output=$(python3 - "$accounts_path" "$family" "$account_num" <<'PY'
import json
import sys
import shutil
from datetime import datetime

accounts_path = sys.argv[1]
family = sys.argv[2]
account_num = int(sys.argv[3])

with open(accounts_path, "r") as f:
    data = json.load(f)

accounts = data.get("accounts", [])
account_index = account_num - 1

if account_index < 0 or account_index >= len(accounts):
    print(f"INVALID_ACCOUNT|{account_num}|{len(accounts)}")
    sys.exit(11)

known_families = set()
for acct in accounts:
    for fam in acct.get("cachedQuota", {}):
        known_families.add(fam)
for fam in data.get("activeIndexByFamily", {}):
    known_families.add(fam)

if family not in known_families:
    print(f"UNKNOWN_FAMILY|{family}|{','.join(sorted(known_families))}")
    sys.exit(12)

backup_path = accounts_path + ".backup." + datetime.now().strftime("%Y%m%d_%H%M%S")
shutil.copy2(accounts_path, backup_path)

if "activeIndexByFamily" not in data:
    data["activeIndexByFamily"] = {}
data["activeIndexByFamily"][family] = account_index

with open(accounts_path, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")

email = accounts[account_index].get("email", "(unknown)")
print(f"OK|{family}|{email}|{account_num}|{backup_path}")
sys.exit(0)
PY
)
    local py_status=$?

    case "$py_status" in
        0)
            local switched_family switched_email backup_file
            switched_family=$(echo "$py_output" | awk -F'|' '/^OK\|/ {print $2}')
            switched_email=$(echo "$py_output" | awk -F'|' '/^OK\|/ {print $3}')
            backup_file=$(echo "$py_output" | awk -F'|' '/^OK\|/ {print $5}')
            aux_info "Account switched successfully" "component=dev,operation=opencode_account_switch,family=$switched_family,email=$switched_email"
            echo "Family '$switched_family' now routes to: $switched_email (account $account_num)"
            echo "Backup: $backup_file"
            return 0
            ;;
        11)
            local total
            total=$(echo "$py_output" | awk -F'|' '/^INVALID_ACCOUNT/ {print $3}')
            aux_err "Account number $account_num is out of range (1-$total)" "component=dev,operation=opencode_account_switch"
            return 1
            ;;
        12)
            local known
            known=$(echo "$py_output" | awk -F'|' '/^UNKNOWN_FAMILY/ {print $3}')
            aux_err "Unknown family '$family'; known families: $known" "component=dev,operation=opencode_account_switch"
            return 1
            ;;
        *)
            aux_err "Failed to switch account" "component=dev,operation=opencode_account_switch,python_exit=$py_status"
            return 2
            ;;
    esac
}
