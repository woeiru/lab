# Emits an OpenCode account attribution event for runtime hooks
# opencode account event emit
# -x (execute) | <provider_id> <account_key> [event_type] [source] [account_label]
dev_oae() {
    # Technical Description:
    #   Persists attribution events used by session reporting and audit workflows
    #   Supports explicit arguments and -x runtime-hook mode via OPENCODE_ATTR_* env vars
    #   Normalizes provider families and validates allowed event types before persistence
    # Dependencies:
    #   - opencode CLI for database path resolution
    #   - python3 with sqlite3 module for append-only writes
    # Arguments:
    #   -x                    emit from runtime environment variables
    #   <provider_id>         provider family or id (e.g. antigravity, openai)
    #   <account_key>         stable account key (email or opaque id)
    #   [event_type]          account_selected|token_refreshed|auth_switched (default: account_selected)
    #   [source]              event source tag (default: runtime)
    #   [account_label]       optional human-readable label shown in reports

    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        aux_tec
        return 0
    fi

    local provider_id=""
    local account_key=""
    local account_label=""
    local event_type="account_selected"
    local source="runtime"
    local trace_id="${OPENCODE_ATTR_TRACE_ID:-}"

    if [ "$1" = "-x" ]; then
        if [ $# -ne 1 ]; then
            aux_use
            return 1
        fi

        provider_id="${OPENCODE_ATTR_PROVIDER_ID:-}"
        account_key="${OPENCODE_ATTR_ACCOUNT_KEY:-}"
        account_label="${OPENCODE_ATTR_ACCOUNT_LABEL:-$account_key}"
        event_type="${OPENCODE_ATTR_EVENT_TYPE:-account_selected}"
        source="${OPENCODE_ATTR_SOURCE:-runtime}"
    else
        if [ $# -lt 2 ] || [ $# -gt 5 ]; then
            aux_use
            return 1
        fi

        provider_id="$1"
        account_key="$2"
        event_type="${3:-account_selected}"
        source="${4:-runtime}"
        account_label="${5:-$account_key}"
    fi

    provider_id=$(_dev_normalize_provider_id "$provider_id")
    if ! aux_val "$provider_id" "not_empty" || ! aux_val "$account_key" "not_empty"; then
        aux_err "Provider and account key are required" "component=dev,operation=opencode_account_event_emit"
        aux_use
        return 1
    fi

    if ! _dev_is_supported_account_event_type "$event_type"; then
        aux_err "Unsupported event type '$event_type' (expected: account_selected, token_refreshed, auth_switched)" "component=dev,operation=opencode_account_event_emit"
        return 1
    fi

    _dev_record_account_event "$provider_id" "$account_key" "$account_label" "$event_type" "$source" "$trace_id"
    aux_info "Account attribution event emitted" "component=dev,operation=opencode_account_event_emit,provider_id=$provider_id,event_type=$event_type,source=$source"
    return 0
}

# Emits request-time attribution and runs opencode
# opencode run attributed
# <provider_id> <account_key> [account_label] [--dry-run] -- [opencode_run_args...]
dev_orr() {
    # Technical Description:
    #   Emits an account_selected attribution event immediately before executing opencode run
    #   Provides a practical request-time integration path when upstream runtime hooks are unavailable
    #   Accepts optional account label and passes remaining arguments directly to opencode run
    # Dependencies:
    #   - opencode CLI available on PATH
    #   - Local attribution event persistence via _dev_record_account_event
    # Arguments:
    #   <provider_id>          provider family/id for attribution event
    #   <account_key>          stable account key (email or opaque id)
    #   [account_label]        optional display label
    #   [--dry-run]            emit attribution event without executing opencode run
    #   --                     separator before opencode run arguments
    #   [opencode_run_args...] arguments forwarded to opencode run

    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        aux_tec
        return 0
    fi

    if [ $# -lt 4 ]; then
        aux_use
        return 1
    fi

    local provider_id="$1"
    local account_key="$2"
    local account_label="$2"
    local dry_run=0
    shift 2

    if [ "$1" != "--" ]; then
        account_label="$1"
        shift
    fi

    if [ "$1" = "--dry-run" ]; then
        dry_run=1
        shift
    fi

    if [ "$1" != "--" ]; then
        aux_err "Missing '--' separator before opencode run arguments" "component=dev,operation=opencode_run_attributed"
        aux_use
        return 1
    fi
    shift

    if [ $# -lt 1 ]; then
        aux_err "At least one opencode run argument is required" "component=dev,operation=opencode_run_attributed"
        aux_use
        return 1
    fi

    if ! aux_chk "command" "opencode"; then
        aux_err "opencode command not found"
        return 127
    fi

    _dev_record_account_event "$provider_id" "$account_key" "$account_label" "account_selected" "runtime"

    if [ "$dry_run" -eq 1 ]; then
        aux_info "Dry-run mode: attribution event emitted without opencode run" "component=dev,operation=opencode_run_attributed,provider_id=$provider_id"
        return 0
    fi

    aux_info "Starting attributed opencode run" "component=dev,operation=opencode_run_attributed,provider_id=$provider_id"
    command opencode run "$@"
    return $?
}

# Emits token refresh attribution event
# opencode token refresh event
# <provider_id> <account_key> [account_label] [source]
dev_otr() {
    # Technical Description:
    #   Emits a token_refreshed attribution event for provider/account identity refresh transitions
    #   Supports optional account label and source tag while enforcing validated event semantics
    # Dependencies:
    #   - Local attribution event persistence via _dev_record_account_event
    # Arguments:
    #   <provider_id>          provider family/id
    #   <account_key>          stable account key (email or opaque id)
    #   [account_label]        optional display label (defaults to account_key)
    #   [source]               optional source tag (defaults to connector_event)

    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        aux_tec
        return 0
    fi

    if [ $# -lt 2 ] || [ $# -gt 4 ]; then
        aux_use
        return 1
    fi

    local provider_id="$1"
    local account_key="$2"
    local account_label="${3:-$account_key}"
    local source="${4:-connector_event}"

