#!/bin/bash

# Define directory and file variables
DIR_FUN="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
FILE_FUN=$(basename "$BASH_SOURCE")
BASE_FUN="${FILE_FUN%.*}"
FILEPATH_FUN="${DIR_FUN}/${FILE_FUN}"
CONFIG_FUN="${SITE_CONFIG_FILE}"

# Dynamically create variables based on the base name
eval "FILEPATH_${BASE_FUN}=\$FILEPATH_FUN"
eval "FILE_${BASE_FUN}=\$FILE_FUN"
eval "BASE_${BASE_FUN}=\$BASE_FUN"
eval "CONFIG_${BASE_FUN}=\$CONFIG_FUN"

# Displays an overview of module functions with analyzer formatting
# overview functions
# [ana_laf_flags]
dev_fun() {
    # Technical Description:
    #   Shows the development module function inventory using ana_laf.
    #   Forwards optional ana_laf output flags for formatting/export.
    #   Keeps wrapper behavior consistent with other ops modules.
    # Dependencies:
    #   - ana_laf function
    #   - Read access to development operations module file
    # Arguments:
    #   $@: optional ana_laf flags (-t, -b, -j, --json-dir <dir>)

    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        aux_tec
        return 0
    fi

    if [ $# -gt 0 ] && [ -z "$1" ]; then
        aux_use
        return 1
    fi

    ana_laf "$FILEPATH_dev" "$@"
}

# Displays an overview of module variables from configuration
# overview variables
# -x (execute)
dev_var() {
    # Technical Description:
    #   Shows the development module variable overview using ana_acu in overview mode.
    #   Uses module-local config and analysis path for consistent behavior.
    #   Keeps wrapper behavior consistent with other ops modules.
    # Dependencies:
    #   - ana_acu function
    #   - Read access to configuration files and ops library path
    # Arguments:
    #   $1: -x - explicit execution flag required for consistency

    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        aux_tec
        return 0
    fi

    if [ $# -ne 1 ] || [ "$1" != "-x" ]; then
        aux_use
        return 1
    fi

    ana_acu -o "$CONFIG_dev" "$DIR_FUN/.."
}

_dev_get_opencode_db_path() {
    local db_path
    db_path=$(command opencode db path 2>/dev/null) || return 1

    if ! aux_val "$db_path" "file_exists"; then
        return 1
    fi

    echo "$db_path"
}

# Shows a complete OpenCode session overview across all scopes
# opencode sessions overview
# -x (execute)
_dev_osv_render() {
    local db_path="$1"
    local mode="$2"
    local limit="${3:-0}"
    local best_effort="${4:-0}"

    local output
    output=$(python3 - "$db_path" "$mode" "$limit" "$best_effort" <<'PY'
import sqlite3
import sys
import re

db_path = sys.argv[1]
mode    = sys.argv[2]
limit   = int(sys.argv[3]) if len(sys.argv) > 3 else 0
best_effort = (sys.argv[4] == "1") if len(sys.argv) > 4 else False

conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
cur  = conn.cursor()

def table_exists(cursor, table_name):
    try:
        cursor.execute(
            "SELECT 1 FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1",
            (table_name,),
        )
        return cursor.fetchone() is not None
    except Exception:
        return False

def normalize_provider(provider_id):
    provider = (provider_id or "").strip().lower()
    if provider.startswith("openai"):
        return "openai"
    if provider.startswith("google"):
        return "antigravity"
    if provider.startswith("antigravity"):
        return "antigravity"
    return provider

def compact_account_label(label):
    """Make long placeholder/test account labels easier to scan in USER column."""
    value = str(label or "").strip()
    if not value:
        return "unknown"

    lowered = value.lower()
    if lowered in {"(unknown)", "unknown", "none", "null"}:
        return "unknown"

    if "@" in value:
        local, domain = value.split("@", 1)
        if domain.lower() == "example.com" and local:
            return local

    return value

def normalize_source(source):
    src = (source or "").strip().lower()
    if src == "opencode_runtime":
        return "runtime"
    if src == "shell_wrapper":
        return "wrapper"
    return src

def load_attribution_events(cursor):
    """Load account attribution timeline from opencode_account_event table."""
    events_by_provider = {}
    if not table_exists(cursor, "opencode_account_event"):
        return events_by_provider

    try:
        cursor.execute("PRAGMA table_info(opencode_account_event)")
        cols = {str(row[1]) for row in cursor.fetchall() if len(row) > 1}
        required = {"time_ms", "provider_id", "account_key"}
        if not required.issubset(cols):
            return events_by_provider

        account_label_expr = "account_key"
        if "account_label" in cols:
            account_label_expr = "COALESCE(NULLIF(TRIM(account_label), ''), account_key)"

        source_expr = "'opencode_event'"
        if "source" in cols:
            source_expr = "COALESCE(NULLIF(TRIM(source), ''), 'opencode_event')"

        cursor.execute(
            f"""
            SELECT
                time_ms,
                provider_id,
                account_key,
                {account_label_expr} AS account_label,
                {source_expr} AS source
            FROM opencode_account_event
            WHERE account_key IS NOT NULL
              AND TRIM(account_key) <> ''
              AND provider_id IS NOT NULL
              AND TRIM(provider_id) <> ''
            ORDER BY time_ms ASC
            """
        )

        for row in cursor.fetchall():
            try:
                event_time = int(row[0]) if row[0] is not None else None
            except (TypeError, ValueError):
                event_time = None
            provider = normalize_provider(row[1])
            if event_time is None or not provider:
                continue

            events_by_provider.setdefault(provider, []).append(
                {
                    "time_ms": event_time,
                    "account_key": str(row[2] or "").strip(),
                    "account_label": str(row[3] or "").strip(),
                    "source": normalize_source(str(row[4] or "opencode_event")),
                }
            )
    except Exception:
        return {}

    return events_by_provider

def load_control_account_events(cursor):
    """Legacy best-effort fallback timeline from control_account."""
    events = []
    if not table_exists(cursor, "control_account"):
        return events

    try:
        cursor.execute("PRAGMA table_info(control_account)")
        cols = {str(row[1]) for row in cursor.fetchall() if len(row) > 1}
        if not {"email", "time_updated"}.issubset(cols):
            return events

        cursor.execute(
            """
            SELECT email, time_updated
            FROM control_account
            WHERE email IS NOT NULL AND TRIM(email) <> ''
            ORDER BY time_updated ASC
            """
        )

        for row in cursor.fetchall():
            try:
                event_time = int(row[1]) if row[1] is not None else None
            except (TypeError, ValueError):
                event_time = None
            if event_time is None:
                continue
            events.append(
                {
                    "time_ms": event_time,
                    "account_label": str(row[0] or "").strip(),
                    "source": "control_account",
                }
            )
    except Exception:
        return []

    return events

def resolve_session_user(first_prompt_ms, provider_id, attribution_events, legacy_events, allow_best_effort=False):
    unknown = ("unk", "none", "none")
    provider = normalize_provider(provider_id)
    if not provider:
        return unknown

    provider_events = attribution_events.get(provider, [])
    if first_prompt_ms is not None and provider_events:
        before = [evt for evt in provider_events if evt["time_ms"] <= first_prompt_ms]
        if before:
            pick = before[-1]
            label = pick["account_label"] or pick["account_key"] or "unk"
            return (compact_account_label(label), pick["source"], "high")

        if allow_best_effort:
            after = [evt for evt in provider_events if evt["time_ms"] > first_prompt_ms]
            if after:
                pick = after[0]
                label = pick["account_label"] or pick["account_key"] or "unk"
                return (compact_account_label(label), pick["source"], "low")

    if allow_best_effort and first_prompt_ms is not None and legacy_events:
        before = [evt for evt in legacy_events if evt["time_ms"] <= first_prompt_ms]
        if before:
            pick = before[-1]
            label = pick["account_label"] or "unk"
            return (compact_account_label(label), pick["source"], "low")

        after = [evt for evt in legacy_events if evt["time_ms"] > first_prompt_ms]
        if after:
            pick = after[0]
            label = pick["account_label"] or "unk"
            return (compact_account_label(label), pick["source"], "low")

    return unknown

attribution_events = load_attribution_events(cur)
control_account_events = load_control_account_events(cur)

limit_clause = f"LIMIT {limit}" if limit > 0 else ""

has_message_table = table_exists(cur, "message")

if has_message_table:
    query = f"""
    SELECT
      substr(s.id, length(s.id) - 2, 3) AS suffix,
      s.id,
      COALESCE(p.worktree, '(missing_project)') AS project_root,
      s.directory,
      s.title,
      datetime(s.time_updated / 1000, 'unixepoch', 'localtime') AS updated_local,
      datetime(fm.first_user_ms / 1000, 'unixepoch', 'localtime') AS first_prompt_local,
      fm.first_user_ms,
      COALESCE(mu.provider, '') AS provider,
      COALESCE(mu.model, '') AS model,
      COALESCE(mu.total_input, 0) AS input_tokens,
      COALESCE(mu.total_output, 0) AS output_tokens
    FROM session s
    LEFT JOIN project p ON p.id = s.project_id
    LEFT JOIN (
      SELECT
        session_id,
        MAX(CASE WHEN json_extract(data, '$.role') = 'assistant' THEN json_extract(data, '$.providerID') END) AS provider,
        MAX(CASE WHEN json_extract(data, '$.role') = 'assistant' THEN json_extract(data, '$.modelID') END) AS model,
        SUM(CASE WHEN json_extract(data, '$.role') = 'assistant' THEN COALESCE(json_extract(data, '$.tokens.input'), 0) ELSE 0 END) AS total_input,
        SUM(CASE WHEN json_extract(data, '$.role') = 'assistant' THEN COALESCE(json_extract(data, '$.tokens.output'), 0) ELSE 0 END) AS total_output
      FROM message
      GROUP BY session_id
    ) mu ON mu.session_id = s.id
    LEFT JOIN (
      SELECT
        session_id,
        MIN(CASE WHEN json_extract(data, '$.role') = 'user' THEN time_created END) AS first_user_ms
      FROM message
      GROUP BY session_id
    ) fm ON fm.session_id = s.id
    ORDER BY s.time_updated DESC
    {limit_clause};
    """
    cur.execute(query)
else:
    query = f"""
    SELECT
      substr(s.id, length(s.id) - 2, 3) AS suffix,
      s.id,
      COALESCE(p.worktree, '(missing_project)') AS project_root,
      s.directory,
      s.title,
      datetime(s.time_updated / 1000, 'unixepoch', 'localtime') AS updated_local,
      '' AS first_prompt_local,
      NULL AS first_user_ms,
      '' AS provider,
      '' AS model,
      0 AS input_tokens,
      0 AS output_tokens
    FROM session s
    LEFT JOIN project p ON p.id = s.project_id
    ORDER BY s.time_updated DESC
    {limit_clause};
    """
    cur.execute(query)

rows_raw = cur.fetchall()

rows = []
for row in rows_raw:
    suffix, sid, project_root, directory, title, updated_local, first_prompt_local, first_user_ms, provider, model, inp, out = row
    user_email, source, confidence = resolve_session_user(
        first_user_ms,
        provider,
        attribution_events,
        control_account_events,
        allow_best_effort=best_effort,
    )
    rows.append((
        suffix,
        sid,
        project_root,
        directory,
        title,
        updated_local,
        first_prompt_local or "",
        user_email,
        source,
        confidence,
        model,
        inp,
        out,
    ))
conn.close()

# ── plain TSV mode ────────────────────────────────────────────────────────────
if mode != "-t":
    print("suffix\tid\tproject_root\tdirectory\ttitle\tupdated_local\tfirst_prompt_local\tuser\tsrc\tconf\tmodel\tinput\toutput")
    for row in rows:
        normalized = []
        for value in row:
            if value is None:
                normalized.append("")
            else:
                normalized.append(str(value).replace("\t", " ").replace("\n", " "))
        print("\t".join(normalized))
    sys.exit(0)

# ── bordered table mode (-t) ──────────────────────────────────────────────────
# Balanced truecolor palette (designed for dark and light terminals)
RESET   = "\033[0m"
BOLD    = "\033[1m"
DIM     = "\033[2m"

def fg(r, g, b):
    return f"\033[38;2;{r};{g};{b}m"

C_BORDER  = fg(118, 118, 118)          # Neutral border, medium contrast
C_HEADER  = BOLD + fg(108, 108, 108)   # Header neutral for mixed backgrounds
C_SUFFIX  = fg(30,  156, 164)          # Muted teal (saturated, less bright)
C_PROJECT = fg(52,  112, 206)          # Muted cobalt (saturated, less bright)
C_DIR     = fg(69,  98,  176)          # Slightly darker blue for separation
C_TITLE   = fg(132, 132, 132)          # Body neutral text
C_DATE    = fg(186, 132, 44)           # Muted amber
C_MODEL   = fg(166, 88,  142)          # Muted berry
C_TOKENS  = fg(52,  146, 94)           # Muted green

ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")

def vlen(s):
    return len(ANSI_RE.sub("", s))

def clip(s, width, keep_end=False):
    """Trim a plain string to width; optionally keep end with leading ellipsis."""
    s = str(s).replace("\t", " ").replace("\n", " ")
    if len(s) <= width:
        return s
    if width <= 1:
        return "…"[:width]
    if keep_end:
        return "…" + s[-(width - 1):]
    return s[:width - 1] + "…"

def cell(text, width, color="", rjust=False, keep_end=False):
    """Return a colored, fixed-width cell (plain text in, padded out)."""
    clipped = clip(text, width, keep_end=keep_end)
    colored = color + clipped + (RESET if color else "")
    pad = width - len(clipped)
    if rjust:
        return (" " * pad) + colored
    return colored + (" " * pad)

def fmt_tokens(n):
    try:
        n = int(n)
    except (TypeError, ValueError):
        return "0"
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.1f}K"
    return str(n)

def fmt_date(s):
    """Drop seconds from the datetime string to save space."""
    s = str(s) if s else ""
    return s[:16]  # "YYYY-MM-DD HH:MM"

# Column widths (visible characters)
W = {
    "sfx":  3,
    "proj": 12,
    "dir":  12,
    "title":48,
    "date": 12,
    "first":12,
    "user": 13,
    "src":  7,
    "conf": 4,
    "model":11,
    "in":    7,
    "out":   7,
}

SEP   = f" {C_BORDER}│{RESET} "
HSEP  = "─"

def hline(left, mid, right):
    parts = []
    for key in W:
        parts.append(HSEP * (W[key] + 2))
    inner = (C_BORDER + mid + RESET).join(parts)
    print(C_BORDER + left + inner + right + RESET)

# Header
hline("┌", "┬", "┐")

headers = [
    cell("SFX",     W["sfx"],   C_HEADER),
    cell("PROJECT",  W["proj"],  C_HEADER),
    cell("DIR",     W["dir"],   C_HEADER),
    cell("TITLE",   W["title"], C_HEADER),
    cell("UPDATED", W["date"],  C_HEADER),
    cell("FIRST",   W["first"], C_HEADER),
    cell("USER",    W["user"],  C_HEADER),
    cell("SRC",     W["src"],   C_HEADER),
    cell("CONF",    W["conf"],  C_HEADER),
    cell("MODEL",   W["model"], C_HEADER, rjust=True),
    cell("IN",      W["in"],    C_HEADER, rjust=True),
    cell("OUT",     W["out"],   C_HEADER, rjust=True),
]
print(f"{C_BORDER}│{RESET} " + SEP.join(headers) + f" {C_BORDER}│{RESET}")

hline("├", "┼", "┤")

# Rows
for row in rows:
    suffix, _full_id, proj, directory, title, updated, first_prompt, user, src, conf, model, inp, out = row

    cols = [
        cell(suffix or "",        W["sfx"],   C_SUFFIX),
        cell(proj or "",          W["proj"],  C_PROJECT),
        cell(directory or "",     W["dir"],   C_DIR),
        cell(title or "",         W["title"], C_TITLE),
        cell(fmt_date(updated),   W["date"],  C_DATE, keep_end=True),
        cell(fmt_date(first_prompt), W["first"], C_DATE, keep_end=True),
        cell(user or "",          W["user"],  C_TITLE),
        cell(src or "",           W["src"],   C_TITLE),
        cell(conf or "",          W["conf"],  C_TITLE),
        cell(model or "",         W["model"], C_MODEL, rjust=True, keep_end=True),
        cell(fmt_tokens(inp),     W["in"],    C_TOKENS, rjust=True),
        cell(fmt_tokens(out),     W["out"],   C_TOKENS, rjust=True),
    ]
    print(f"{C_BORDER}│{RESET} " + SEP.join(cols) + f" {C_BORDER}│{RESET}")

hline("└", "┴", "┘")
PY
)
    if [ $? -ne 0 ]; then
        aux_err "Failed to read OpenCode sessions from database" "component=dev,operation=opencode_session_overview"
        return 2
    fi

    if [ "$mode" = "-t" ]; then
        echo "$output"
    elif aux_chk "command" "column"; then
        echo "$output" | column -t -s $'\t'
    else
        echo "$output"
    fi
}

# Shows a complete OpenCode session overview across all scopes
# opencode sessions overview
# -x (execute) | -t (table) | --watch <seconds> | -l <count> | --best-effort
dev_osv() {
    # Technical Description:
    #   Reads the OpenCode SQLite database and prints all known sessions across projects
    #   Includes a short session suffix column to support quick session targeting workflows
    #   Joins session and project metadata to show scope/worktree context for each entry
    #   Joins aggregated token usage (model, input, output) from assistant messages per session
    #   Sorts by last update time so the most recent sessions appear first
    #   In -t mode renders a compact bordered table with Konsole-palette truecolor columns
    #   Supports --watch mode for periodic refresh, stackable with either output flag
    #   Supports -l <N> to limit output to the N most-recent sessions by timestamp
    #   Strict attribution is default; use --best-effort to allow low-confidence fallback
    # Dependencies:
    #   - opencode CLI for resolving the active database path
    #   - python3 with sqlite3 module for read-only query execution
    #   - column command (optional, used in plain -x mode) for aligned table formatting
    # Arguments:
    #   -x                    plain TSV output (column-aligned when column(1) is available)
    #   -t                    compact bordered table with colors and trimmed columns
    #   --watch <seconds>     (optional) refresh interval; clears screen between renders
    #   -l <count>            (optional) limit to the N most-recent sessions
    #   --best-effort         (optional) include low-confidence attribution fallbacks

    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        aux_tec
        return 0
    fi

    local mode=""
    local watch_mode=0
    local watch_interval=0
    local limit=0
    local best_effort=0

    # Flexible argument parsing — all flags are stackable in any order
    while [ $# -gt 0 ]; do
        case "$1" in
            -x|-t)
                if [ -n "$mode" ]; then
                    aux_err "Only one output mode (-x or -t) may be specified" "component=dev,operation=opencode_session_overview"
                    return 1
                fi
                mode="$1"
                shift
                ;;
            --watch)
                if [ $# -lt 2 ]; then
                    aux_err "Watch mode requires an interval in seconds" "component=dev,operation=opencode_session_overview"
                    aux_use
                    return 1
                fi
                if ! [[ "$2" =~ ^[0-9]+$ ]] || [ "$2" -lt 1 ]; then
                    aux_err "Watch interval must be a positive integer" "component=dev,operation=opencode_session_overview,value=$2"
                    return 1
                fi
                watch_mode=1
                watch_interval="$2"
                shift 2
                ;;
            -l)
                if [ $# -lt 2 ]; then
                    aux_err "Limit flag -l requires a count argument" "component=dev,operation=opencode_session_overview"
                    aux_use
                    return 1
                fi
                if ! [[ "$2" =~ ^[0-9]+$ ]] || [ "$2" -lt 1 ]; then
                    aux_err "Limit count must be a positive integer" "component=dev,operation=opencode_session_overview,value=$2"
                    return 1
                fi
                limit="$2"
                shift 2
                ;;
            --best-effort)
                best_effort=1
                shift
                ;;
            *)
                aux_use
                return 1
                ;;
        esac
    done

    # Output mode is required
    if [ -z "$mode" ]; then
        aux_use
        return 1
    fi

    if ! aux_chk "command" "opencode"; then
        aux_err "opencode command not found"
        return 127
    fi

    if ! aux_chk "command" "python3"; then
        aux_err "python3 command not found"
        return 127
    fi

    local db_path
    db_path=$(_dev_get_opencode_db_path)
    if [ $? -ne 0 ]; then
        aux_err "Could not resolve OpenCode database path"
        return 2
    fi

    if [ "$watch_mode" -eq 1 ]; then
        aux_info "Starting session overview watch (interval: ${watch_interval}s, Ctrl+C to stop)" "component=dev,operation=opencode_session_overview,mode=$mode,limit=$limit,best_effort=$best_effort"
        trap 'return 0' INT
        while true; do
            clear
            _dev_osv_render "$db_path" "$mode" "$limit" "$best_effort"
            sleep "$watch_interval"
        done
    else
        aux_info "Collecting OpenCode sessions overview" "component=dev,operation=opencode_session_overview,db_path=$db_path,mode=$mode,limit=$limit,best_effort=$best_effort"
        _dev_osv_render "$db_path" "$mode" "$limit" "$best_effort"
    fi

    return 0
}

# Reassigns a single OpenCode session to a target scope using an ID suffix
# opencode session move scope
# <scope_path> <session_id_suffix>
dev_omi() {
    # Technical Description:
    #   Locates a session by matching the trailing ID suffix provided by the caller
    #   Resolves the target project scope from the OpenCode project table using worktree path
    #   Updates session project_id and directory to move the session into the target scope
    #   Rejects ambiguous suffixes and missing scope mappings to avoid accidental reassignment
    # Dependencies:
    #   - opencode CLI for database path resolution
    #   - python3 with sqlite3 module for transactional updates
    #   - Existing OpenCode project record for the target scope path
    # Arguments:
    #   $1: scope_path - target worktree path already known to OpenCode
    #   $2: session_id_suffix - last 3+ alphanumeric characters of the session ID

    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        aux_tec
        return 0
    fi

    if [ $# -ne 2 ]; then
        aux_use
        return 1
    fi

    if ! aux_val "$1" "not_empty"; then
        aux_err "Scope path cannot be empty"
        aux_use
        return 1
    fi

    if ! aux_val "$1" "dir_exists"; then
        aux_err "Scope path does not exist" "component=dev,operation=opencode_move_session,scope_path=$1"
        return 1
    fi

    if ! aux_val "$2" "alphanum"; then
        aux_err "Session suffix must be alphanumeric" "component=dev,operation=opencode_move_session,suffix=$2"
        aux_use
        return 1
    fi

    if ! aux_val "$2" "min_length" "3"; then
        aux_err "Session suffix must be at least 3 characters"
        aux_use
        return 1
    fi

    if ! aux_chk "command" "opencode"; then
        aux_err "opencode command not found"
        return 127
    fi

    if ! aux_chk "command" "python3"; then
        aux_err "python3 command not found"
        return 127
    fi

    local scope_path="$1"
    local suffix="$2"
    local db_path
    db_path=$(_dev_get_opencode_db_path)
    if [ $? -ne 0 ]; then
        aux_err "Could not resolve OpenCode database path"
        return 2
    fi

    aux_warn "Close active OpenCode clients before moving sessions" "component=dev,operation=opencode_move_session"

    local py_output
    py_output=$(python3 - "$db_path" "$suffix" "$scope_path" <<'PY'
import sqlite3
import sys

db_path, suffix, scope_path = sys.argv[1], sys.argv[2], sys.argv[3]
conn = sqlite3.connect(db_path)
cur = conn.cursor()

cur.execute(
    "SELECT id, directory, title FROM session WHERE id LIKE ? ORDER BY time_updated DESC",
    ("%" + suffix,),
)
matches = cur.fetchall()

if len(matches) == 0:
    print("NO_MATCH")
    sys.exit(11)

if len(matches) > 1:
    print("AMBIGUOUS")
    for session_id, directory, title in matches:
        title = (title or "").replace("\t", " ").replace("\n", " ")
        directory = (directory or "").replace("\t", " ").replace("\n", " ")
        print(f"CANDIDATE\t{session_id}\t{directory}\t{title}")
    sys.exit(12)

target_session_id = matches[0][0]

cur.execute("SELECT id FROM project WHERE worktree = ? LIMIT 1", (scope_path,))
project_row = cur.fetchone()
if project_row is None:
    print("MISSING_SCOPE")
    sys.exit(13)

target_project_id = project_row[0]
cur.execute(
    "UPDATE session SET project_id = ?, directory = ? WHERE id = ?",
    (target_project_id, scope_path, target_session_id),
)
conn.commit()

print(f"MOVED\t{target_session_id}\t{target_project_id}\t{scope_path}")
sys.exit(0)
