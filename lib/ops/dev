_dev_apply_account_denylist() {
    local accounts_path
    accounts_path=$(_dev_get_antigravity_accounts_path) || return 0

    local denylist_path
    denylist_path=$(_dev_get_antigravity_denylist_path) || return 0

    if ! aux_chk "command" "python3" 2>/dev/null; then
        return 0
    fi

    local py_output
    py_output=$(python3 - "$accounts_path" "$denylist_path" <<'PY'
import json
import shutil
import sys
from datetime import datetime

accounts_path = sys.argv[1]
denylist_path = sys.argv[2]

try:
    with open(denylist_path, "r", encoding="utf-8") as f:
        denied = {
            line.split("#", 1)[0].strip().lower()
            for line in f
            if line.split("#", 1)[0].strip()
        }
except Exception:
    sys.exit(0)

if not denied:
    sys.exit(0)

try:
    with open(accounts_path, "r", encoding="utf-8") as f:
        data = json.load(f)
except Exception:
    sys.exit(0)

accounts = data.get("accounts", [])
if not isinstance(accounts, list) or not accounts:
    sys.exit(0)

disabled_indices = []
disabled_emails = []

for idx, account in enumerate(accounts):
    if not isinstance(account, dict):
        continue

    email = str(account.get("email", "")).strip()
    if not email:
        continue

    if email.lower() not in denied:
        continue

    if account.get("enabled", True) is False:
        continue

    account["enabled"] = False
    disabled_indices.append(idx)
    disabled_emails.append(email)

if not disabled_indices:
    print("NO_CHANGE")
    sys.exit(0)

enabled_indices = [
    idx for idx, account in enumerate(accounts)
    if isinstance(account, dict) and account.get("enabled", True) is not False
]

if not enabled_indices:
    print(f"NO_ENABLED_FALLBACK|{','.join(disabled_emails)}")
    sys.exit(11)

backup_path = accounts_path + ".backup." + datetime.now().strftime("%Y%m%d_%H%M%S")
shutil.copy2(accounts_path, backup_path)

fallback_index = enabled_indices[0]
fallback_email = str(accounts[fallback_index].get("email", "(unknown)"))
disabled_set = set(disabled_indices)
rerouted = []

if data.get("activeIndex") in disabled_set:
    data["activeIndex"] = fallback_index
    rerouted.append("default")

active_by_family = data.get("activeIndexByFamily")
if not isinstance(active_by_family, dict):
    active_by_family = {}

for family, idx in list(active_by_family.items()):
    if idx in disabled_set:
        active_by_family[family] = fallback_index
        rerouted.append(str(family))

data["accounts"] = accounts
data["activeIndexByFamily"] = active_by_family

with open(accounts_path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2)
    f.write("\n")

print(
    f"UPDATED|{','.join(disabled_emails)}|{backup_path}|"
    f"{fallback_email}|{','.join(rerouted)}"
)
sys.exit(0)
PY
    )
    local py_status=$?

    case "$py_status" in
        0)
            if [[ "$py_output" == UPDATED\|* ]]; then
                local disabled_emails backup_file fallback_email rerouted_targets
                disabled_emails=$(echo "$py_output" | awk -F'|' '/^UPDATED\|/ {print $2}')
                backup_file=$(echo "$py_output" | awk -F'|' '/^UPDATED\|/ {print $3}')
                fallback_email=$(echo "$py_output" | awk -F'|' '/^UPDATED\|/ {print $4}')
                rerouted_targets=$(echo "$py_output" | awk -F'|' '/^UPDATED\|/ {print $5}')

                aux_info "Applied antigravity account denylist" "component=dev,operation=opencode_account_denylist,disabled=$disabled_emails,fallback_email=$fallback_email"
                if [ -n "$rerouted_targets" ]; then
                    aux_info "Re-routed active mappings after denylist update" "component=dev,operation=opencode_account_denylist,targets=$rerouted_targets"
                fi
                aux_dbg "Denylist backup created" "component=dev,operation=opencode_account_denylist,backup=$backup_file"
            fi
            return 0
            ;;
        11)
            local blocked_emails
            blocked_emails=$(echo "$py_output" | awk -F'|' '/^NO_ENABLED_FALLBACK\|/ {print $2}')
            aux_warn "Denylist would disable all accounts; skipping automatic disable" "component=dev,operation=opencode_account_denylist,blocked=$blocked_emails"
            return 0
            ;;
        *)
            aux_warn "Failed to apply antigravity account denylist" "component=dev,operation=opencode_account_denylist,python_exit=$py_status"
            return 0
            ;;
    esac
}

_dev_provider_from_family() {
    local family="${1:-}"

    case "${family,,}" in
        openai*)
            echo "openai"
            ;;
        *)
            echo "antigravity"
            ;;
    esac
}

_dev_normalize_provider_id() {
    local provider_id="${1:-}"
    local normalized="${provider_id,,}"

    if [[ "$normalized" == openai* ]]; then
        echo "openai"
        return 0
    fi

    if [[ "$normalized" == google* ]]; then
        echo "antigravity"
        return 0
    fi

    if [[ "$normalized" == antigravity* ]]; then
        echo "antigravity"
        return 0
    fi

    echo "$normalized"
    return 0
}

