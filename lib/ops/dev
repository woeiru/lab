_dev_oqu_render() {
    local accounts_path="$1"

    python3 - "$accounts_path" <<'PY'
import json
import re
import sys
from datetime import datetime, timezone

accounts_path = sys.argv[1]

with open(accounts_path, "r") as f:
    data = json.load(f)

accounts = data.get("accounts", [])

BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"

OQU_DASHBOARD_WIDTH = 64
OQU_TABLE_WIDTH = 64
OQU_COL_WIDTHS = (22, 15, 25)
ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")

def visible_len(text):
    return len(ANSI_RE.sub("", text))

def ansi_trim(text, width):
    if width <= 0:
        return ""

    out = []
    visible = 0
    i = 0
    while i < len(text) and visible < width:
        if text[i] == "\x1b":
            match = ANSI_RE.match(text, i)
            if match:
                out.append(match.group(0))
                i = match.end()
                continue
        out.append(text[i])
        visible += 1
        i += 1

    truncated = i < len(text)
    rendered = "".join(out)
    if truncated and "\x1b[" in rendered and not rendered.endswith(RESET):
        rendered += RESET
    return rendered

def ansi_ljust(text, width):
    trimmed = ansi_trim(text, width)
    pad = width - visible_len(trimmed)
    if pad > 0:
        return trimmed + (" " * pad)
    return trimmed

def oqu_row(model, remaining, reset):
    model_cell = ansi_ljust(str(model), OQU_COL_WIDTHS[0])
    remaining_cell = ansi_ljust(str(remaining), OQU_COL_WIDTHS[1])
    reset_cell = ansi_ljust(str(reset), OQU_COL_WIDTHS[2])
    row = f"{model_cell} {remaining_cell} {reset_cell}"
    return ansi_trim(row, OQU_TABLE_WIDTH)

def bar(fraction, width=10):
    try:
        fraction = float(fraction)
    except (TypeError, ValueError):
        fraction = 0.0
    fraction = max(0.0, min(1.0, fraction))
    filled = int(fraction * width)
    empty = width - filled
    if fraction >= 0.7:
        color = GREEN
    elif fraction >= 0.3:
        color = YELLOW
    else:
        color = RED
    return f"{color}{'█' * filled}{'░' * empty}{RESET}"

def fmt_reset(iso_str):
    if not iso_str:
        return "n/a"
    base = iso_str[:16].replace("T", " ")
    try:
        reset_dt = datetime.fromisoformat(iso_str.replace("Z", "+00:00"))
        now = datetime.now(timezone.utc)
        total_sec = int((reset_dt - now).total_seconds())
        if total_sec <= 0:
            return f"{base} {RED}(exp){RESET}"
        hours, remainder = divmod(total_sec, 3600)
        minutes = remainder // 60
        return f"{base} {DIM}({hours}h{minutes:02d}){RESET}"
    except Exception:
        return base

def to_fraction(value):
    try:
        fraction = float(value)
    except (TypeError, ValueError):
        fraction = 0.0
    return max(0.0, min(1.0, fraction))

now_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
print(f"\n{BOLD}GEMINI CLI QUOTA{RESET}  {DIM}{now_str}{RESET}")
print("=" * OQU_DASHBOARD_WIDTH)

if not accounts:
    print(f"\n  {YELLOW}No accounts configured in antigravity-accounts.json{RESET}\n")
    sys.exit(0)

for i, acct in enumerate(accounts):
    email = acct.get("email", "(unknown)")
    enabled = acct.get("enabled", False)
    cli_quota = acct.get("cachedGeminiCliQuota") or acct.get("geminiCliQuota") or {}
    cached_at = acct.get("cachedQuotaUpdatedAt")

    status_tag = f"{GREEN}ENABLED{RESET}" if enabled else f"{RED}DISABLED{RESET}"

    print(f"\n{BOLD}Account {i + 1}: {email}{RESET}  [{status_tag}]")

    cli_models = []
    cli_error = None
    if isinstance(cli_quota, dict):
        models_candidate = cli_quota.get("models", [])
        if isinstance(models_candidate, list):
            cli_models = models_candidate
        cli_error = cli_quota.get("error")
    elif isinstance(cli_quota, list):
        cli_models = cli_quota

    ALLOWED_CLI_MODELS = {
        "gemini-3.1-pro-preview",
        "gemini-3.1-pro-preview_vertex",
        "gemini-3-pro-preview",
        "gemini-3-pro-preview_vertex",
        "gemini-3-flash-preview",
        "gemini-3-flash-preview_vertex"
    }

    if cli_models:
        cli_models = [m for m in cli_models if isinstance(m, dict) and str(m.get("modelId", "")) in ALLOWED_CLI_MODELS]

    if cli_models:
        print(f"  {'-' * OQU_TABLE_WIDTH}")
        print(f"  {BOLD}{oqu_row('Model', 'Remaining', 'Reset')}{RESET}")
        print(f"  {'-' * OQU_TABLE_WIDTH}")
        for model in cli_models:
            model_id = str(model.get("modelId", "?"))
            remaining = to_fraction(model.get("remainingFraction", 0))
            reset_time = model.get("resetTime", "")
            pct = f"{int(remaining * 100):>3}%"
            remaining_cell = f"{bar(remaining)} {pct}"
            print(f"  {oqu_row(model_id, remaining_cell, fmt_reset(reset_time))}")
        print(f"  {'-' * OQU_TABLE_WIDTH}")
    else:
        if cli_error:
            print(f"  {DIM}({cli_error}){RESET}")
        elif cached_at and not cli_models:
            print(f"  {DIM}(no Gemini CLI quota returned in last check){RESET}")
        else:
            print(f"  {DIM}(no Gemini CLI quota cached yet){RESET}")

print()
PY
}

_dev_olb_render() {
    local accounts_path="$1"
    local db_path="$2"

    python3 - "$accounts_path" "$db_path" <<'PY'
import json
import sys
import os
import re
from datetime import datetime, timezone

accounts_path = sys.argv[1]
db_path = sys.argv[2] if len(sys.argv) > 2 and sys.argv[2] else None

with open(accounts_path, "r") as f:
    data = json.load(f)

accounts = data.get("accounts", [])
active_index = data.get("activeIndex", 0)
active_by_family = data.get("activeIndexByFamily", {})

BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
CYAN = "\033[36m"
MAGENTA = "\033[35m"

HIDDEN_FAMILIES = {"gemini-flash"}  # comment out entries to show them again

QUOTA_TABLE_WIDTH = 64
QUOTA_COL_WIDTHS = (14, 15, 29, 3)
MODEL_TABLE_WIDTH = 64
MODEL_COL_WIDTHS = (34, 6, 5, 7, 8)
ROUTING_TABLE_WIDTH = 64
ROUTING_COL_WIDTHS = (15, 48)
DASHBOARD_WIDTH = 64
ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")

def visible_len(text):
    return len(ANSI_RE.sub("", text))

def ansi_trim(text, width):
    if width <= 0:
        return ""

    out = []
    visible = 0
    i = 0
    while i < len(text) and visible < width:
        if text[i] == "\x1b":
            match = ANSI_RE.match(text, i)
            if match:
                out.append(match.group(0))
                i = match.end()
                continue
        out.append(text[i])
        visible += 1
        i += 1

    truncated = i < len(text)
    rendered = "".join(out)
    if truncated and "\x1b[" in rendered and not rendered.endswith(RESET):
        rendered += RESET
    return rendered

def ansi_ljust(text, width):
    trimmed = ansi_trim(text, width)
    pad = width - visible_len(trimmed)
    if pad > 0:
        return trimmed + (" " * pad)
    return trimmed

def ansi_rjust(text, width):
    trimmed = ansi_trim(text, width)
    pad = width - visible_len(trimmed)
    if pad > 0:
        return (" " * pad) + trimmed
    return trimmed

def quota_row(family, remaining_cell, reset_cell, mdl):
    family_cell = ansi_ljust(str(family), QUOTA_COL_WIDTHS[0])
    rem_cell = ansi_ljust(remaining_cell, QUOTA_COL_WIDTHS[1])
    reset_col = ansi_ljust(reset_cell, QUOTA_COL_WIDTHS[2])
    mdl_cell = ansi_rjust(str(mdl), QUOTA_COL_WIDTHS[3])
    row = f"{family_cell} {rem_cell} {reset_col} {mdl_cell}"
    return ansi_trim(row, QUOTA_TABLE_WIDTH)

def model_row(model, provider, msgs, inp, out):
    model_cell = ansi_ljust(str(model), MODEL_COL_WIDTHS[0])
    provider_cell = ansi_ljust(str(provider), MODEL_COL_WIDTHS[1])
    msgs_cell = ansi_rjust(str(msgs), MODEL_COL_WIDTHS[2])
    input_cell = ansi_rjust(str(inp), MODEL_COL_WIDTHS[3])
    output_cell = ansi_rjust(str(out), MODEL_COL_WIDTHS[4])
    row = f"{model_cell} {provider_cell} {msgs_cell} {input_cell} {output_cell}"
    return ansi_trim(row, MODEL_TABLE_WIDTH)

def routing_row(label, value):
    label_cell = ansi_ljust(str(label), ROUTING_COL_WIDTHS[0])
    value_cell = ansi_ljust(str(value), ROUTING_COL_WIDTHS[1])
    row = f"{label_cell} {value_cell}"
    return ansi_trim(row, ROUTING_TABLE_WIDTH)

def bar(fraction, width=10):
    try:
        fraction = float(fraction)
    except (TypeError, ValueError):
        fraction = 0.0
    fraction = max(0.0, min(1.0, fraction))
    filled = int(fraction * width)
    empty = width - filled
    if fraction >= 0.7:
        color = GREEN
    elif fraction >= 0.3:
        color = YELLOW
    else:
        color = RED
    return f"{color}{'█' * filled}{'░' * empty}{RESET}"

def fmt_ts(epoch_ms):
    if not epoch_ms:
        return "n/a"
    return datetime.fromtimestamp(epoch_ms / 1000).strftime("%Y-%m-%d %H:%M:%S")

def fmt_reset(iso_str):
    if not iso_str:
        return "n/a"
    base = iso_str[:16].replace("T", " ")
    try:
        reset_dt = datetime.fromisoformat(iso_str.replace("Z", "+00:00"))
        now = datetime.now(timezone.utc)
        total_sec = int((reset_dt - now).total_seconds())
        if total_sec <= 0:
            return f"{base} {RED}(exp){RESET}"
        hours, remainder = divmod(total_sec, 3600)
        minutes = remainder // 60
        return f"{base} {DIM}({hours}h{minutes:02d}m){RESET}"
    except Exception:
        return base

def to_fraction(value):
    try:
        fraction = float(value)
    except (TypeError, ValueError):
        fraction = 0.0
    return max(0.0, min(1.0, fraction))

def fmt_tokens(n):
    if n is None or n == 0:
        return "0"
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.1f}K"
    return str(int(n))

now_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
