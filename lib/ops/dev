        if rows:
            print(f"\n{TITLE}MODEL USAGE{RESET}  {DIM}(all accounts, all providers){RESET}")
            print(f"  {'-' * MODEL_TABLE_WIDTH}")
            header = model_row("Model", "Prov", "Msgs", "Input", "Output")
