GREEN = fg(52, 146, 94)      # muted green
YELLOW = fg(186, 132, 44)    # muted amber
RED = fg(176, 76, 76)        # muted red
CYAN = fg(30, 156, 164)      # muted teal
MAGENTA = fg(166, 88, 142)   # muted berry
