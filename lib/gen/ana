        echo "Error: Target file '$target_file' does not exist."
        return 1
    fi

    local lab_dir="${LAB_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}"
    local val_dir="${lab_dir}/val"
    
    if [[ ! -d "$val_dir" ]]; then
        echo "Error: Validation directory '$val_dir' not found."
        return 1
    fi

    local target_basename=$(basename "$target_file")
    local test_files=()
    
    # Use standard while read loop to collect files properly
    while IFS= read -r -d '' t_file; do
        test_files+=("$t_file")
    done < <(find "$val_dir" -type f \( -name "${target_basename}_test.sh" -o -name "${target_basename}_*test.sh" \) -print0 2>/dev/null)

    local col_width_1=45 # Test File
    local col_width_2=12 # Test Count
    local col_width_3=15 # Test Type
    local col_width_4=12 # Status

    _ana_tst_truncate_string() {
        local str="$1"
        local max_length="$2"
        if [ "${#str}" -gt "$max_length" ]; then
            printf "%.*s.." "$((max_length-2))" "$str"
        else
            printf "%-${max_length}s" "$str"
        fi
    }

    _ana_tst_print_separator() {
        local total_width=$((col_width_1 + col_width_2 + col_width_3 + col_width_4 + 13))
        printf "+%s+\n" "$(printf '%*s' $total_width '' | tr ' ' '-')"
    }

    _ana_tst_print_row() {
        printf "| %s | %s | %s | %s |\n" \
            "$(_ana_tst_truncate_string "$1" "$col_width_1")" \
            "$(_ana_tst_truncate_string "$2" "$col_width_2")" \
            "$(_ana_tst_truncate_string "$3" "$col_width_3")" \
            "$(_ana_tst_truncate_string "$4" "$col_width_4")"
    }

    local target_display="${target_file#$lab_dir/}"
    target_display="${target_display#/}"
    
    # Prepare JSON array
    local json_test_entries=()
    
    if [[ ${#test_files[@]} -eq 0 ]]; then
        _ana_tst_print_separator
        _ana_tst_print_row "No test files found for '$target_basename'" "" "" ""
        _ana_tst_print_separator
    else
        _ana_tst_print_separator
        _ana_tst_print_row "Test File" "Count" "Type" "Status"
        _ana_tst_print_separator

        for t_file in "${test_files[@]}"; do
            local t_display="${t_file#$lab_dir/}"
            t_display="${t_display#/}"
            
            # Count logic
            local run_test_count=$(grep -c -E '^[[:space:]]*run_test[[:space:]]+' "$t_file" 2>/dev/null || echo "0")
            local it_count=$(grep -c -E '^[[:space:]]*it[[:space:]]+"' "$t_file" 2>/dev/null || echo "0")
            local func_count=$(grep -c -E '^[[:space:]]*(function[[:space:]]+)?test_[a-zA-Z0-9_]*[[:space:]]*\(\)' "$t_file" 2>/dev/null || echo "0")
            
            local test_count=0
            local test_type="Unknown"
            
            if [[ "$run_test_count" -gt 0 ]]; then
                test_count=$run_test_count
                test_type="run_test"
            elif [[ "$it_count" -gt 0 ]]; then
                test_count=$it_count
                test_type="BDD (it)"
            elif [[ "$func_count" -gt 0 ]]; then
                test_count=$func_count
                test_type="test_*()"
            fi

            local test_status="Unknown"
            local log_file="${t_file%.sh}.log"
            if [[ -f "$log_file" ]]; then
                if grep -q "FAILURE" "$log_file"; then
                    test_status="Failed"
                else
                    test_status="Passed"
                fi
            fi

            _ana_tst_print_row "$t_display" "$test_count" "$test_type" "$test_status"
            
            if $json_mode; then
                json_test_entries+=("    {\"file\":\"$t_display\",\"count\":$test_count,\"type\":\"$test_type\",\"status\":\"$test_status\"}")
            fi
        done
        _ana_tst_print_separator
    fi

    # Output JSON if requested
    if $json_mode; then
        local tmp_dir="$lab_dir/.tmp/doc"
        mkdir -p "$tmp_dir"
        
        local json_filename="${target_display//\//_}.json"
        local json_file="$tmp_dir/$json_filename"
        
        [[ -f "$json_file" ]] && rm -f "$json_file"
        
        # Build JSON string
        local json_content="{"
        json_content+="\"analysis_type\": \"test_coverage\","
        json_content+="\"target\": \"$target_display\","
        json_content+="\"timestamp\": \"$(date -Iseconds)\","
        json_content+="\"test_suites\": ["
        
        # Add array elements
        for i in "${!json_test_entries[@]}"; do
            json_content+="${json_test_entries[$i]}"
            if [[ $i -lt $((${#json_test_entries[@]} - 1)) ]]; then
                json_content+=","
            fi
        done
        
        json_content+="]}"
        
        echo "$json_content" > "$json_file"
        echo "JSON output written to: $json_file"
    fi
    echo ""
}

# Analyzes error handling and exit codes in a file or specific function
# analyze errors
# <file name> [function name] [-j]
ana_err() {
    local file_name=""
    local target_func=""
    local json_mode=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -j)
                json_mode=true
                shift
                ;;
            *)
                if [ -z "$file_name" ]; then
                    file_name="$1"
                elif [ -z "$target_func" ]; then
                    target_func="$1"
                fi
                shift
                ;;
        esac
    done

    if [ -z "$file_name" ]; then
        aux_use
        return 1
    fi

    if [[ ! -f "$file_name" ]]; then
        echo "Error: Cannot read file '$file_name'"
        return 1
    fi

    local col_width_func=25
    local col_width_type=10
    local col_width_code=45
    local col_width_loc=6

    local current_func=""
    local line_number=0
    local -a results=()

    while IFS= read -r line || [[ -n "$line" ]]; do
        ((line_number++))
        
        # Check start of function
        if [[ $line =~ ^([a-zA-Z_][a-zA-Z0-9_-]*)[[:space:]]*\(\)[[:space:]]*\{? ]]; then
            current_func="${BASH_REMATCH[1]}"
            continue
        fi
        
        # Check end of function
        if [[ -n "$current_func" ]] && [[ $line =~ ^\} ]]; then
            current_func=""
            continue
        fi

        if [[ -n "$current_func" ]]; then
            if [[ -n "$target_func" ]] && [[ "$current_func" != "$target_func" ]]; then
                continue
            fi
            
            local err_type=""
            local err_msg=""
            
            if [[ $line =~ (^|[[:space:]])(return|exit)[[:space:]]+([^[:space:]\;]+) ]]; then
                err_type="${BASH_REMATCH[2]}"
                err_msg="${BASH_REMATCH[3]}"
            elif [[ $line =~ (^|[[:space:]])(aux_err|aux_warn|aux_val)[[:space:]]+(.*) ]]; then
                err_type="${BASH_REMATCH[2]}"
                err_msg="${BASH_REMATCH[3]}"
                
                # Cleanup
                err_msg="${err_msg%; then}"
                err_msg="${err_msg%;}"
                err_msg="${err_msg%% ||*}"
                # Strip leading/trailing spaces
                err_msg=$(echo "$err_msg" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                # Strip leading/trailing quotes if it is fully wrapped
                if [[ $err_msg =~ ^\"(.*)\"$ ]] || [[ $err_msg =~ ^\'(.*)\'$ ]]; then
                    err_msg="${BASH_REMATCH[1]}"
                fi
            fi
            
            if [[ -n "$err_type" ]]; then
                # Store it with | delimiter
                results+=("${current_func}|${err_type}|${err_msg}|${line_number}")
            fi
        fi
    done < "$file_name"

    if $json_mode; then
        local lab_dir="${LAB_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}"
        local tmp_dir="$lab_dir/.tmp/doc"
        mkdir -p "$tmp_dir"
        
        local relative_path="${file_name#$lab_dir/}"
        local json_filename="${relative_path//\//_}.err.json"
        if [[ -n "$target_func" ]]; then
             json_filename="${relative_path//\//_}.${target_func}.err.json"
        fi
        local json_file="$tmp_dir/$json_filename"
        
        [[ -f "$json_file" ]] && rm -f "$json_file"
        
        echo "{" > "$json_file"
        echo "  \"file\": \"$file_name\"," >> "$json_file"
        if [[ -n "$target_func" ]]; then
             echo "  \"target_function\": \"$target_func\"," >> "$json_file"
        fi
        echo "  \"errors\": [" >> "$json_file"
        
        local first_item=true
        local item func type msg loc msg_json
        for item in "${results[@]}"; do
            IFS='|' read -r func type msg loc <<< "$item"
            
            if [[ "$first_item" == false ]]; then
                echo "    ," >> "$json_file"
            fi
            first_item=false
            
            # Escape quotes and backslashes for json
            msg_json=$(echo "$msg" | sed 's/\\/\\\\/g' | sed 's/"/\\"/g' | sed "s/'/\\\\'/g")
            
            echo "    {" >> "$json_file"
            echo "      \"function\": \"$func\"," >> "$json_file"
            echo "      \"type\": \"$type\"," >> "$json_file"
            echo "      \"message\": \"$msg_json\"," >> "$json_file"
            echo "      \"location\": $loc" >> "$json_file"
            echo "    }" >> "$json_file"
        done
        
        echo "  ]" >> "$json_file"
        echo "}" >> "$json_file"
        
        echo "JSON output written to: $json_file"
        echo ""
    else
        # Print table header
        local total_width=$((col_width_func + col_width_type + col_width_code + col_width_loc + 13))
        local separator_line="+$(printf '%*s' "$total_width" '' | tr ' ' '-')+"

        _ana_err_truncate() {
            local str="$1"
            local width="$2"
            if [ ${#str} -gt $width ]; then
                echo "${str:0:$((width-2))}.."
            else
                printf "%-${width}s" "$str"
            fi
        }
        
        echo "$separator_line"
        printf "| %s | %s | %s | %s |\n" \
            "$(_ana_err_truncate "Function" $col_width_func)" \
            "$(_ana_err_truncate "Type" $col_width_type)" \
            "$(_ana_err_truncate "Message/Code" $col_width_code)" \
            "$(_ana_err_truncate "Line" $col_width_loc)"
        echo "$separator_line"
        
        local item func type msg loc
        for item in "${results[@]}"; do
            IFS='|' read -r func type msg loc <<< "$item"
            printf "| %s | %s | %s | %s |\n" \
                "$(_ana_err_truncate "$func" $col_width_func)" \
                "$(_ana_err_truncate "$type" $col_width_type)" \
                "$(_ana_err_truncate "$msg" $col_width_code)" \
                "$(_ana_err_truncate "$loc" $col_width_loc)"
        done
        echo "$separator_line"
        echo ""
    fi
}

# Internal helper to truncate and pad ana_scp columns
