# Prevent multiple sourcing
[[ -n "${AUX_LOADED:-}" ]] && return 0
readonly AUX_LOADED=1
# Provides function introspection, variable analysis, documentation generation,
# and system monitoring capabilities for the lab environment.
#
# Dependencies: 
#   - Bash 4.0+, standard UNIX utilities (awk, grep, sed, find, wc)
#   - lib/core/col (centralized color management) - optional but recommended
#
# Color Integration:
#   - Uses centralized color management from lib/core/col if available
#   - Falls back to local color definitions if col module not loaded
#   - Colors are automatically integrated via backward compatibility aliases
#
# Main Functions:
#   aux_fun, aux_var - Overview summaries
#   aux_log, aux_dbg - Consolidated logging operations (all to aux.log/aux.json)
#   aux_info, aux_warn, aux_err - Convenience logging functions  
#   aux_ffl - File operations
#   aux_use, aux_tec - Help system
#   aux_val, aux_chk - Validation and checks
#   aux_cmd, aux_ask - Command execution and user interaction
#   aux_arr - Array manipulation utilities
#
# Function Categories:
#   Overview:     aux_fun, aux_var
#   Logging:      aux_log, aux_dbg, aux_info, aux_warn, aux_err (all consolidated)
#   Utilities:    aux_ffl
#   Help System:  aux_use, aux_tec
#   Validation:   aux_val, aux_chk
#   Execution:    aux_cmd
#   Interaction:  aux_ask
#   Data:         aux_arr
#
# Usage: source lib/gen/aux
